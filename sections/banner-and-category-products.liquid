{%- liquid
  assign section_id = section.id
  assign heading_text = section.settings.heading | default: 'NEW ARRIVALS'
  assign subtext_text = section.settings.subtext | default: '40% OFF ON SELECTED ITEMS'
  assign collection = collections[section.settings.collection]

  assign columns_desktop = section.settings.columns
  assign columns_mobile = section.settings.columns_mobile | plus: 0
  assign products_to_display = section.settings.items_to_show | default: columns_desktop | plus: 0
  if products_to_display < 1
    assign products_to_display = columns_desktop
  endif
  if collection != blank and collection.all_products_count < products_to_display
    assign products_to_display = collection.all_products_count
  endif

  assign columns_tablet = columns_desktop | minus: 1
  if columns_desktop < 3 or request.design_mode
    assign columns_tablet = columns_desktop
  endif
  assign button_label = section.settings.button_label
  assign button_link = collection.url
  assign columns_mobile = section.settings.columns_mobile | plus: 0
  assign header_layout = 'vertical'
  assign controls_position = section.settings.controls_position | default: 'middle-center'
  assign row_gap = section.settings.row_gap | default: 'inherit'

  assign enable_swipe_mobile = false
  if section.settings.swipe_on_mobile and products_to_display > columns_mobile
    assign enable_swipe_mobile = true
  endif

  assign item_css_class = 'f-column'

  assign enable_slider = false
  if section.settings.enable_slider and products_to_display > columns_desktop
    assign enable_slider = true
    assign item_css_class = item_css_class | append: ' swiper-slide'
  endif
-%}
{%- capture image_sizes -%}
(max-width: 767px) calc((100vw - 30px) / {{ columns_mobile }}),
(max-width: 1023px) calc((100vw - 30px) / {{ columns_tablet }}),
{{ settings.page_width | divided_by: columns_desktop }}px
{%- endcapture -%}

<section class="products-banner products-banner--{{ section_id }} section-{{ section.id }}">
  <div class="products-banner__hero">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2200
        | image_tag:
          class: 'products-banner__hero-image',
          loading: 'lazy',
          sizes: '100vw',
          widths: '640, 900, 1200, 1600, 2200',
          alt: heading_text
      }}
    {%- else -%}
      <div class="products-banner__hero-placeholder"></div>
    {%- endif -%}
    {%- if section.settings.hero_image_mobile != blank -%}
      {{
        section.settings.hero_image_mobile
        | image_url: width: 2200
        | image_tag:
          class: 'products-banner__hero-image-mobile',
          loading: 'lazy',
          sizes: '100vw',
          widths: '640, 900, 1200, 1600, 2200',
          alt: heading_text
      }}
    {%- endif -%}
    <div class="products-banner__hero-overlay"></div>
    <div class="products-banner__hero-content">
      {%- if section.settings.line1 -%}
        <div class="line1"></div>
      {%- endif -%}
      <h2 class="products-banner__title">{{ heading_text }}</h2>
      <div class="products-banner__badge-container">
        <div class="products-banner__badge">
          <p class="products-banner__badge_text">{{ subtext_text }}</p>
        </div>
        {%- if section.settings.line2 -%}
          <div class="line2"></div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="products-banner__section-content">
    <grid-list class="products-banner__grid-list block relative swiper-show-nav-on-hover">
      <featured-collection
        class="products-banner__carousel block{% if enable_slider %} swiper{% endif %}{% if enable_swipe_mobile %} swipe-mobile swipe-mobile--{{ section.settings.columns_mobile }}-cols{% endif %}"
        data-section-id="{{ section.id }}"
        {% if enable_slider %}
          data-enable-slider="true"
          data-items="{{ columns_desktop }}"
          data-tablet-items="{{ columns_tablet }}"
          data-slider-wrapper=".products-banner__items"
          {% if header_layout == 'standing-column' %}
            data-calc-heading-column-height="true"
          {%- else -%}
            data-calc-button-position="true"
          {% endif %}
        {% endif %}
      >
        <div
          class="products-banner__items products-list f-grid f-grid-{{ columns_mobile }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns_desktop }}-cols products-banner__items--gap-{{ section.settings.column_gap | default: '16' }} products-banner__items--gap-mobile-{{ section.settings.column_gap_mobile | default: section.settings.column_gap | default: '16' }} f-grid--row-gap-{{ row_gap }}{% if enable_slider %} swiper-wrapper{% endif %}{% if enable_swipe_mobile %} swipe-mobile__inner{% endif %}"
        >
          {%- for product in collection.products limit: products_to_display -%}
            <div class="{{ item_css_class }}">
              {%- render 'card-product',
                product: product,
                image_sizes: image_sizes,
                image_ratio: section.settings.pcard_image_ratio,
                section_index: section.index,
                index: forloop.index,
                hide_similar_icon: true
              -%}
            </div>
          {%- else -%}
            {%- for i in (1..products_to_display) -%}
              <div class="{{ item_css_class }}">
                {% render 'card-product-placeholder', image_ratio: section.settings.pcard_image_ratio %}
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </featured-collection>
      {%- if enable_slider and header_layout != 'standing-column' -%}
        <div class="products-banner__swiper-controls swiper-controls swiper-controls--{{ controls_position }} hidden md:block">
          <button
            class="products-banner__swiper-button-prev swiper-button-prev btn"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {% render 'icon-slider-prev' %}
          </button>
          <button
            class="products-banner__swiper-button-next swiper-button-next btn"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {% render 'icon-slider-next' %}
          </button>
        </div>
      {%- endif -%}
      {%- if button_label != blank -%}
        <div class="section__footer flex items-center justify-center">
          <a
            class="
              w-full  flex items-center justify-center view-more-button-featured-collection
              {% comment %} {{ button_style }}  {% endcomment %}
            "
            {% if button_link != blank %}
              href="{{ button_link }}"
            {% else %}
              aria-disabled="true"
            {% endif %}
          >
            {{- button_label -}}
            {% render 'icon-arrow-right' %}
          </a>
        </div>
      {%- endif -%}
    </grid-list>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');

  .products-banner--{{ section_id }} {
    background: #fff;
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .products-banner--{{ section_id }} .products-banner__hero {
    position: relative;
    overflow: hidden;
  }

  .products-banner--{{ section_id }} .products-banner__hero-image,
  .products-banner--{{ section_id }} .products-banner__hero-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .products-banner--{{ section_id }} .products-banner__hero-image-mobile {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }

  .products-banner--{{ section_id }} .products-banner__hero-placeholder {
    background: linear-gradient(180deg, #7d8482 0%, #222729 55%, #111416 100%);
  }

  .products-banner--{{ section_id }} .products-banner__hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .products-banner--{{ section_id }} .products-banner__hero-content {
    position: absolute;
    bottom: 30px;
    text-align: center;
    z-index: 2;
    width: 100%;
    max-height: max-content;
    display:flex;
    flex-direction:column;
    gap:28px;
    align-items:center;
  }
  .products-banner__grid-list{
    padding: {{ section.settings.padding_top_products }}px {{ section.settings.padding_horizontal_products }}px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-8 {
    --column-gap: 8px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-12 {
    --column-gap: 12px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-16 {
    --column-gap: 16px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-20 {
    --column-gap: 20px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-24 {
    --column-gap: 24px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-mobile-8 {
    --column-gap-mobile: 8px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-mobile-16 {
    --column-gap-mobile: 16px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-mobile-20 {
    --column-gap-mobile: 20px;
  }
  .products-banner--{{ section_id }} .products-banner__items--gap-mobile-24 {
    --column-gap-mobile: 24px;
  }
  .products-banner--{{ section_id }} .products-banner__title {
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: 60px;
    line-height: 48px;
    letter-spacing: 0.01em;
    text-align: center;
    vertical-align: middle;
    color: #FFFFFF;
  }
  .products-banner__badge-container{
    margin:0 auto;
    width:calc(100% - 2rem);
    position:relative;
  }
  .products-banner--{{ section_id }} .products-banner__badge {
    padding-top: 10px;
    padding-right: 20px;
    padding-bottom: 10px;
    padding-left: 20px;
    background:white;
    margin:0px;
    max-width:max-content;
    margin:0 auto;
    z-index:5;
    position:relative;

  }
  .products-banner--{{ section_id }} .products-banner__badge_text {
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: 32px;
    line-height: 35px;
    letter-spacing: 0.01em;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    color:#453D2B;
    margin:0px;
  }

  .products-banner--{{ section_id }} .products-banner__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    background: transparent;
    padding: 20px 64px;
    position: absolute;
    bottom: 0px;
    left:0px;
    right: 0px;
  }

  .products-banner--{{ section_id }} .products-banner__card {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    background: #14181a;
    min-height: 22rem;
  }

  .products-banner--{{ section_id }} .products-banner__card-image,
  .products-banner--{{ section_id }} .products-banner__card-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .products-banner--{{ section_id }} .products-banner__card-placeholder {
    background: linear-gradient(180deg, #b8bec4 0%, #7f878e 60%, #30363b 100%);
  }

  .products-banner--{{ section_id }} .products-banner__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 11, 12, 0.03) 52%, rgba(8, 9, 10, 0.86) 100%);
    pointer-events: none;
  }

  .products-banner--{{ section_id }} .products-banner__card-label {
    position: absolute;
    bottom: 2rem;
    z-index: 2;
    color: #ffffff;
    text-transform: uppercase;
    width: 100% ;
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: 32px;
    line-height: 130%;
    letter-spacing: 0%;
    text-align: center;
    vertical-align: middle;

  }
  .subtext{
    font-family: 'Montserrat',sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 130%;
    color:white;
  }
  .products-banner--{{ section_id }} .products-banner__card:hover .products-banner__card-image {
    transform: scale(1.03);
  }
  .line2{
    width:100%;
    border: 1px solid var(--Stroke-Light, #FFFFFF1A);
    position:absolute;
    bottom:50%;
    transform:translateY(-50%);
    z-index:2;

  }
  .line1{
    width: calc(100% - 2rem);
    border: 1px solid var(--Stroke-Light, #FFFFFF1A);
    top:-3rem;
    position:absolute;
  }
  @media (max-width: 767px) {
     .products-banner--{{ section_id }} {
      background: #fff;
      position: relative;
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .products-banner--{{ section_id }} .products-banner__title {
      font-size: 32px;
      line-height: 32px;
      max-width:260px;
    }
    .products-banner--{{ section_id }} .products-banner__hero-content{
      gap:8px;
      bottom: 40px;
    }
    .products-banner--{{ section_id }} .products-banner__badge {
      padding:0px;
      background:#fff;
      margin:0 auto;
    }
    .products-banner--{{ section_id }} .products-banner__badge_text {
      font-size: 16px;
      line-height: 19px;
      color:#453D2B;
      text-align:center;
    }
    .products-banner__grid-list{
      padding: {{ section.settings.padding_top_products_mobile }}px {{ section.settings.padding_horizontal_products_mobile }}px;
    }

    .products-banner--{{ section_id }} .products-banner__hero {
      min-height: 32rem;
    }
    .line2{

    }
    .line1{
      display: none !important;
    }

    .products-banner--{{ section_id }} .products-banner__hero-image,
    .products-banner--{{ section_id }} .products-banner__hero-placeholder {
      min-height: 32rem;
    }
    .products-banner--{{ section_id }} .products-banner__hero-image {
      display: none;
    }
    .products-banner--{{ section_id }} .products-banner__hero-image-mobile {
      display: block;
      min-height: 32rem;
    }

    .products-banner--{{ section_id }} .products-banner__badge {
      font-size: 1.2rem;
      padding: 0.45rem 0.8rem;
    }

    .products-banner--{{ section_id }} .products-banner__grid {
      padding:16px;
      gap:12px;
    }

    .products-banner--{{ section_id }} .products-banner__card,
    .products-banner--{{ section_id }} .products-banner__card-image,
    .products-banner--{{ section_id }} .products-banner__card-placeholder {
      min-height: 14rem;
      object-fit: cover;
    }
    .products-banner--{{ section_id }} .products-banner__card-label {
      font-size: 1.3rem;
      bottom: 1rem;
    }
    .subtext{
      font-size:1rem;
    }
  }
</style>
<script src="{{ 'featured-collection.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Banner and products",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero Background Image mobile"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "40% OFF ON SELECTED ITEMS"
    },
    {
      "type": "checkbox",
      "id": "line1",
      "label": "Line before heading",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "line2",
      "label": "Line center of sub heading",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.all.collection.label"
    },
    {
      "type": "number",
      "id": "items_to_show",
      "label": "items to show desktop"
    },
    {
      "type": "number",
      "id": "items_to_show_mobile",
      "label": "items to show mobile"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.all.grid.columns_desktop.label",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "column_gap",
      "options": [
        {
          "value": "8",
          "label": "8px"
        },
        {
          "value": "12",
          "label": "12px"
        },
        {
          "value": "16",
          "label": "16px"
        },
        {
          "value": "20",
          "label": "20px"
        },
        {
          "value": "24",
          "label": "24px"
        }
      ],
      "default": "16",
      "label": "Column gap (desktop)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.all.button.button_label.label",
      "info": "t:sections.all.button.button_label.info"
    },
    {
      "type": "select",
      "id": "row_gap",
      "options": [
        {
          "value": "inherit",
          "label": "t:sections.all.grid.row_gap.options__inherit.label"
        },
        {
          "value": "none",
          "label": "t:sections.all.grid.row_gap.options__none.label"
        },
        {
          "value": "extra-small",
          "label": "t:sections.all.grid.row_gap.options__xs.label"
        },
        {
          "value": "small",
          "label": "t:sections.all.grid.row_gap.options__sm.label"
        },
        {
          "value": "medium",
          "label": "t:sections.all.grid.row_gap.options__md.label"
        },
        {
          "value": "large",
          "label": "t:sections.all.grid.row_gap.options__lg.label"
        },
        {
          "value": "extra-large",
          "label": "t:sections.all.grid.row_gap.options__xl.label"
        }
      ],
      "default": "inherit",
      "label": "t:sections.all.grid.row_gap.label"
    },
    {
      "type": "select",
      "id": "column_gap_mobile",
      "options": [
        {
          "value": "8",
          "label": "8px"
        },
        {
          "value": "12",
          "label": "12px"
        },
        {
          "value": "16",
          "label": "16px"
        },
        {
          "value": "20",
          "label": "20px"
        },
        {
          "value": "24",
          "label": "24px"
        }
      ],
      "default": "16",
      "label": "Column gap (mobile)"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "t:sections.all.carousel.enable_carousel",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": true,
      "label": "t:sections.all.mobile.swipe_on_mobile.label"
    },
    {
      "type": "range",
      "id": "padding_horizontal_products",
      "label": "Padding horizontal products",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_horizontal_products_mobile",
      "label": "Padding horizontal products mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_products",
      "label": "Padding top products",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_products_mobile",
      "label": "Padding top products mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Banner and products"
    }
  ]
}
{% endschema %}
