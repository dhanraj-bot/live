<style>
  .mobile-app-banner {
    width: 100%;
    background: linear-gradient(135deg, {{ section.settings.banner_bg_color }} 0%, {{ section.settings.banner_bg_color_secondary }} 100%);
    z-index: 9998;
    padding: 1rem 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }


  .mobile-app-banner__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 100%;
    gap: 2rem;
  }

  .mobile-app-banner__content {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mobile-app-banner__text {
    flex: 1;
  }
  .mobile-app-banner__title {
    font-size: 14px;
    color: #ffffff;
}
  .mobile-app-banner__subtitle {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    line-height: 1.3;
  }

  .mobile-app-banner__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mobile-app-banner__button {
    background: transparent;
    color: #fff;
    border: 1.5px solid #fff;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: all 0.2s ease;
    padding: 8px;
    font-size: 12px !important;
    letter-spacing: normal;
    height: 100% !important;
    line-height: normal;
    border-radius: 4px;
}
  /* Tablet and Desktop - Hide banner */
  @media screen and (min-width: 768px) {
    .mobile-app-banner {
      display: none !important;
    }
  }

  /* Small mobile optimization */
  @media screen and (max-width: 360px) {
    .mobile-app-banner__icon svg {
      width: 1.25rem;
      height: 1.25rem;
    }

    .mobile-app-banner__subtitle {
      font-size: 0.6875rem;
    }
  }

</style>

{%- if section.settings.enable_banner -%}
<div 
  class="mobile-app-banner" 
  id="mobileAppBanner"
>
  <div class="mobile-app-banner__container">
    <div class="mobile-app-banner__content">
      <div class="mobile-app-banner__text">
        {% if section.settings.banner_title != blank %}
        <h3 class="mobile-app-banner__title">{{ section.settings.banner_title | default: 'Download Our App & Get 10% Additional Cashback On All Orders' }}</h3>
        {% endif %}
        {% if section.settings.banner_subtitle != blank %}
        <p class="mobile-app-banner__subtitle">{{ section.settings.banner_subtitle | default: 'Best shopping experience on mobile' }}</p>
        {% endif %}
        </div>
    </div>
    <div class="mobile-app-banner__actions">
      <a href="{{ section.settings.appurl }}" class="mobile-app-banner__button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="feather feather-smartphone"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
         {{ section.settings.button_text | default: 'OPEN APP' }}
      </a>
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Mobile App Banner",
  "tag": "section",
  "class": "section-mobile-app-banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_banner",
      "label": "Enable Mobile App Banner",
      "default": true,
      "info": "Show fixed banner on mobile devices only"
    },
    {
      "type": "header",
      "content": "Banner Content"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "Banner Title",
      "default": "Download Our App & Get 10% Additional Cashback On All Orders",
      "info": "Main headline text for the banner"
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner Subtitle",
      "default": "Best shopping experience on mobile",
      "info": "Secondary text below the title"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "OPEN APP",
      "info": "Text displayed on the button"
    },
    {
      "type": "header",
      "content": "Banner Style"
    },
    {
      "type": "color",
      "id": "banner_bg_color",
      "label": "Background Color (Primary)",
      "default": "#E74C3C",
      "info": "Primary gradient color for banner background"
    },
    {
      "type": "color",
      "id": "banner_bg_color_secondary",
      "label": "Background Color (Secondary)",
      "default": "#C0392B",
      "info": "Secondary gradient color for banner background"
    },
    {
      "type": "header",
      "content": "App Store URLs"
    },
    {
      "type": "text",
      "id": "appurl",
      "label": "App URL",
    },
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "paragraph",
      "content": "The banner will always show on mobile devices. When clicked, it tries to open the app if installed, otherwise redirects to the appropriate app store (Google Play for Android, App Store for iOS)."
    }
  ],
  "presets": [
    {
      "name": "Mobile App Banner"
    }
  ]
}
{% endschema %}