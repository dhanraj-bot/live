    color:#453D2B;
    margin:0px;
  }

  .time-tacking-deals--{{ section_id }} .time-tacking-deals__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    background: transparent;
    padding: 20px 64px;
    position: absolute;
    bottom: 0px;
    left:0px;
    right: 0px;
  }
  
  @media (max-width: 767px) {
     .time-tacking-deals--{{ section_id }} {
