    }
  }
</style>
<script src="{{ 'featured-collection.js' | asset_url }}" defer="defer"></script>
<script>
  (function () {
    var sectionEl = document.querySelector('.time-tacking-deals--{{ section_id }}');
    if (!sectionEl) return;

    var countdownEl = sectionEl.querySelector('[data-time-ticking-countdown]');
    if (!countdownEl) return;

    var hoursEl = countdownEl.querySelector('[data-ttd-hours]');
    var minutesEl = countdownEl.querySelector('[data-ttd-minutes]');
    var secondsEl = countdownEl.querySelector('[data-ttd-seconds]');
    if (!hoursEl || !minutesEl || !secondsEl) return;

    var hours = parseInt(sectionEl.dataset.timerHours, 10) || 0;
    var minutes = parseInt(sectionEl.dataset.timerMinutes, 10) || 0;
    var seconds = parseInt(sectionEl.dataset.timerSeconds, 10) || 0;
    var totalSeconds = hours * 3600 + minutes * 60 + seconds;

    var formatTwoDigits = function (value) {
      return String(Math.max(0, value)).padStart(2, '0');
    };

    var updateCountdown = function () {
      var remainingHours = Math.floor(totalSeconds / 3600);
      var remainingMinutes = Math.floor((totalSeconds % 3600) / 60);
      var remainingSeconds = totalSeconds % 60;

      hoursEl.textContent = formatTwoDigits(remainingHours);
      minutesEl.textContent = formatTwoDigits(remainingMinutes);
      secondsEl.textContent = formatTwoDigits(remainingSeconds);
    };

    if (sectionEl._timeTickingDealsInterval) {
      window.clearInterval(sectionEl._timeTickingDealsInterval);
    }

    updateCountdown();
    if (totalSeconds <= 0) return;

    sectionEl._timeTickingDealsInterval = window.setInterval(function () {
      totalSeconds -= 1;
      if (totalSeconds < 0) {
        totalSeconds = 0;
        updateCountdown();
        window.clearInterval(sectionEl._timeTickingDealsInterval);
        return;
      }
      updateCountdown();
    }, 1000);
  })();
</script>

