      line-height: 130%;

    }
    .time-taking-deals-time__value{
    font-size: 12px;
      line-height: 15px;
    }
    .time-taking-deals-time__label{
      font-size: 12px;
      line-height: 15px;
    }
    .time-taking-deals-time__label:not(:last-child) {
      margin-right: 4px;
    }
    .time-tacking-deals__grid-list{
      padding: {{ section.settings.padding_top_products_mobile }}px {{ section.settings.padding_horizontal_products_mobile }}px;
    }

    .time-tacking-deals--{{ section_id }} .time-tacking-deals__badge {
      font-size: 1.2rem;
      padding: 0.45rem 0.8rem;
    }
     .time-container{
      flex-direction:column;
      align-items: center;
      justify-content:center;
      gap: 8px;
      padding: 0 {{ section.settings.padding_horizontal_products }}px;
    }
    .horizontal-line1{
      display: none;
    }
    .horizontal-line2{
     display: none;
    }
    .time-tacking-deals--{{ section_id }} .time-tacking-deals__grid {
