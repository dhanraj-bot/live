{%- liquid
  assign section_id = section.id
  assign collection = collections[section.settings.collection]

  assign columns_desktop = section.settings.columns
  assign columns_mobile = section.settings.columns_mobile | plus: 0
  assign products_to_display = section.settings.items_to_show | default: columns_desktop | plus: 0
  if products_to_display < 1
    assign products_to_display = columns_desktop
  endif
  if collection != blank and collection.all_products_count < products_to_display
    assign products_to_display = collection.all_products_count
  endif

  assign columns_tablet = columns_desktop | minus: 1
  if columns_desktop < 3 or request.design_mode
    assign columns_tablet = columns_desktop 
  endif
  assign button_label = section.settings.button_label
  assign button_link = collection.url
  assign columns_mobile = section.settings.columns_mobile | plus: 0
  assign header_layout = 'vertical'
  assign controls_position = section.settings.controls_position | default: 'middle-center'
  assign row_gap = section.settings.row_gap | default: 'inherit'
  assign timer_hours = section.settings.timer_hours | default: 1 | plus: 0
  assign timer_minutes = section.settings.timer_minutes | default: 24 | plus: 0
  assign timer_seconds = section.settings.timer_seconds | default: 53 | plus: 0
  assign timer_hours_display = timer_hours | prepend: '00' | slice: -2, 2
  assign timer_minutes_display = timer_minutes | prepend: '00' | slice: -2, 2
  assign timer_seconds_display = timer_seconds | prepend: '00' | slice: -2, 2

  assign enable_swipe_mobile = false
  if section.settings.swipe_on_mobile and products_to_display > columns_mobile
    assign enable_swipe_mobile = true
  endif

  assign item_css_class = 'f-column'

  assign enable_slider = false
  if section.settings.enable_slider and products_to_display > columns_desktop
    assign enable_slider = true
    assign item_css_class = item_css_class | append: ' swiper-slide'
  endif
-%}
{%- capture image_sizes -%}
(max-width: 767px) calc((100vw - 30px) / {{ columns_mobile }}),
(max-width: 1023px) calc((100vw - 30px) / {{ columns_tablet }}),
{{ settings.page_width | divided_by: columns_desktop }}px
{%- endcapture -%}

<section
  class="time-tacking-deals time-tacking-deals--{{ section_id }} section-{{ section.id }}"
  data-timer-hours="{{ timer_hours }}"
  data-timer-minutes="{{ timer_minutes }}"
  data-timer-seconds="{{ timer_seconds }}"
>
  <div class="time-container">
    <div class="horizontal-line1"></div>
    <div class="time-taking-deals-heading">{{ section.settings.heading }}</div>
    <div class="time-taking-deals-time" data-time-ticking-countdown>
      <span class="time-taking-deals-time__value" data-ttd-hours>{{ timer_hours_display }}</span>
      <span class="time-taking-deals-time__label">{{ section.settings.hours_label | default: 'H' }}</span>
      <span class="time-taking-deals-time__value" data-ttd-minutes>{{ timer_minutes_display }}</span>
      <span class="time-taking-deals-time__label">{{ section.settings.minutes_label | default: 'M' }}</span>
      <span class="time-taking-deals-time__value" data-ttd-seconds>{{ timer_seconds_display }}</span>
      <span class="time-taking-deals-time__label">{{ section.settings.seconds_label | default: 'S' }}</span>
    </div>
    <div class="horizontal-line2"></div>
  </div>
  <div class="time-tacking-deals__section-content">
    <grid-list class="time-tacking-deals__grid-list block relative swiper-show-nav-on-hover">
      <featured-collection
        class="time-tacking-deals__carousel block{% if enable_slider %} swiper{% endif %}{% if enable_swipe_mobile %} swipe-mobile swipe-mobile--{{ section.settings.columns_mobile }}-cols{% endif %}"
        data-section-id="{{ section.id }}"
        {% if enable_slider %}
          data-enable-slider="true"
          data-items="{{ columns_desktop }}"
          data-tablet-items="{{ columns_tablet }}"
          data-slider-wrapper=".time-tacking-deals__items"
          {% if header_layout == 'standing-column' %}
            data-calc-heading-column-height="true"
          {%- else -%}
            data-calc-button-position="true"
          {% endif %}
        {% endif %}
      >
        <div
          class="time-tacking-deals__items products-list f-grid f-grid-{{ columns_mobile }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns_desktop }}-cols time-tacking-deals__items--gap-{{ section.settings.column_gap | default: '16' }} time-tacking-deals__items--gap-mobile-{{ section.settings.column_gap_mobile | default: section.settings.column_gap | default: '16' }} f-grid--row-gap-{{ row_gap }}{% if enable_slider %} swiper-wrapper{% endif %}{% if enable_swipe_mobile %} swipe-mobile__inner{% endif %}"
        >
          {%- for product in collection.products limit: products_to_display -%}
            <div class="{{ item_css_class }}">
              {%- render 'card-product',
                product: product,
                image_sizes: image_sizes,
                image_ratio: section.settings.pcard_image_ratio,
                section_index: section.index,
                index: forloop.index,
                hide_similar_icon: true
              -%}
            </div>
          {%- else -%}
            {%- for i in (1..products_to_display) -%}
              <div class="{{ item_css_class }}">
                {% render 'card-product-placeholder', image_ratio: section.settings.pcard_image_ratio %}
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </featured-collection>
      {%- if enable_slider and header_layout != 'standing-column' -%}
        <div class="time-tacking-deals__swiper-controls swiper-controls swiper-controls--{{ controls_position }} hidden md:block">
          <button
            class="time-tacking-deals__swiper-button-prev swiper-button-prev btn"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {% render 'icon-slider-prev' %}
          </button>
          <button
            class="time-tacking-deals__swiper-button-next swiper-button-next btn"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {% render 'icon-slider-next' %}
          </button>
        </div>
      {%- endif -%}
      {%- if button_label != blank -%}
        <div class="section__footer flex items-center justify-center">
          <a
            class="
              w-full  flex items-center justify-center view-more-button-featured-collection
              {% comment %} {{ button_style }}  {% endcomment %}
            "
            {% if button_link != blank %}
              href="{{ button_link }}"
            {% else %}
              aria-disabled="true"
            {% endif %}
          >
            {{- button_label -}}
            {% render 'icon-arrow-right' %}
          </a>
        </div>
      {%- endif -%}
    </grid-list>
  </div>
</section>

<style>
