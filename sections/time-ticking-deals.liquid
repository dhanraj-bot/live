  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-8 {
    --column-gap: 8px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-12 {
    --column-gap: 12px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-16 {
    --column-gap: 16px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-20 {
    --column-gap: 20px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-24 {
    --column-gap: 24px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-mobile-8 {
    --column-gap-mobile: 8px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-mobile-16 {
    --column-gap-mobile: 16px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-mobile-20 {
    --column-gap-mobile: 20px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__items--gap-mobile-24 {
    --column-gap-mobile: 24px;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__title {
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: 60px;
    line-height: 48px;
    letter-spacing: 0.01em;
    text-align: center;
    vertical-align: middle;
    color: #FFFFFF;
  }
  .time-tacking-deals__badge-container{
    margin:0 auto;
    width:calc(100% - 2rem);
    position:relative;
  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__badge {
    padding-top: 10px;
    padding-right: 20px;
    padding-bottom: 10px;
    padding-left: 20px;
    background:white;
    margin:0px;
    max-width:max-content;
    margin:0 auto;
    z-index:5;
    position:relative;

  }
  .time-tacking-deals--{{ section_id }} .time-tacking-deals__badge_text {
