{% style %}
  .popular-category-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
    background: {{ section.settings.background_color }};
  }

  .popular-category__heading-{{ section.id }} {
    margin: 0 0 24px;
    text-align: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    line-height: 130%;
    letter-spacing: 0.04em;
    color: #453D2B;
    text-transform: uppercase;
  }

  .popular-category__wrapper-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .popular-category__arrow-{{ section.id }} {
    border: none;
    background: transparent;
    cursor: pointer;
    width: 32px;
    height: 32px;
    flex: 0 0 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #453D2B;
    z-index: 2;
    padding: 0;
  }

  .popular-category__arrow-{{ section.id }} svg {
    width: 16px;
    height: 16px;
  }

  /* ── DESKTOP SLIDER ── */
  .popular-category__slider-{{ section.id }} {
    overflow: hidden;
    width: 100%;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .popular-category__track-{{ section.id }} {
    display: flex;
    width: 100%;
  }

  .popular-category__item-{{ section.id }} {
    text-decoration: none;
    color: inherit;
    border-right: 1px solid rgba(0, 0, 0, 0.1);
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 10px 14px 8px;
    min-height: 74px;
    flex: 0 0 calc(100% / {{ section.settings.desktop_columns }});
    min-width: calc(100% / {{ section.settings.desktop_columns }});
    box-sizing: border-box;
  }

  .popular-category__item-{{ section.id }}:last-child {
    border-right: none;
  }

  .popular-category__image-wrap-{{ section.id }} {
    width: 42px;
    height: 48px;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .popular-category__image-{{ section.id }} {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .popular-category__placeholder-{{ section.id }} {
    width: 42px;
    height: 48px;
    background: #e6e6e6;
  }

  .popular-category__title-{{ section.id }} {
    margin: 0;
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    line-height: 1.3;
    color: #453D2B;
    text-align: center;
  }

  /* ── MOBILE — max-width: 768px ── */
  @media screen and (max-width: 768px) {
    .popular-category-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
    }

    .popular-category__heading-{{ section.id }} {
      font-size: 16px;
      margin-bottom: 20px;
    }

    /* Hide arrows on mobile — user swipes to scroll */
    .popular-category__arrow-{{ section.id }} {
      display: none;
    }

    /* Slider becomes horizontally scrollable on mobile */
    .popular-category__slider-{{ section.id }} {
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      border-top: 1px solid rgba(0, 0, 0, 0.1);
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .popular-category__slider-{{ section.id }}::-webkit-scrollbar {
      display: none;
    }

    /*
      2 fixed rows, columns auto-generated and flow left→right.
      Each column = 1/3 of the viewport so 3 cols are visible at once.
      More items simply create more columns the user scrolls into.
    */
    .popular-category__track-{{ section.id }} {
      display: grid;
      grid-template-rows: repeat(2, auto);
      grid-auto-flow: column;
      grid-auto-columns: calc(100% / 3);
      width: max-content;
      min-width: 100%;
    }

    /* Every item gets right + bottom border to form the grid lines */
    .popular-category__item-{{ section.id }} {
      flex: unset;
      min-width: unset;
      width: 100%;
      min-height: 108px;
      padding: 12px 8px;
      border-right: 1px solid rgba(0, 0, 0, 0.1);
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
      box-sizing: border-box;
    }

    /* Bottom row items (every even-positioned item in column flow): remove bottom border */
    .popular-category__item-{{ section.id }}:nth-child(2n) {
      border-bottom: none;
    }

    .popular-category__image-wrap-{{ section.id }} {
      width: 48px;
      height: 56px;
      margin-bottom: 10px;
    }

    .popular-category__title-{{ section.id }} {
      font-size: 13px;
    }
  }
{% endstyle %}

<div class="popular-category-{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h1 class="popular-category__heading-{{ section.id }}">
      {{ section.settings.heading }}
    </h1>
  {% endif %}

  <div class="popular-category__wrapper-{{ section.id }}">
    {%- if section.blocks.size > 6 -%}
      <button
        class="popular-category__arrow-{{ section.id }} popular-category__prev-{{ section.id }}"
        type="button"
        aria-label="Previous categories"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M15 18L9 12L15 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}

    <div class="popular-category__slider-{{ section.id }}" id="PopularCategorySlider-{{ section.id }}">
      <div class="popular-category__track-{{ section.id }}">
        {% for block in section.blocks %}
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="popular-category__item-{{ section.id }}"
            {{ block.shopify_attributes }}
          >
            <div class="popular-category__image-wrap-{{ section.id }}">
              {% assign image_class = 'popular-category__image-' | append: section.id %}
              {% assign image_alt = block.settings.title | default: 'Category image' %}

              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 300
                  | image_tag: class: image_class, loading: 'lazy', alt: image_alt
                }}
              {% else %}
                <div class="popular-category__placeholder-{{ section.id }}"></div>
              {% endif %}
            </div>

            {% if block.settings.title != blank %}
              <h2 class="popular-category__title-{{ section.id }}">
                {{ block.settings.title }}
              </h2>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    </div>

    {%- if section.blocks.size > 6 -%}
      <button
        class="popular-category__arrow-{{ section.id }} popular-category__next-{{ section.id }}"
        type="button"
        aria-label="Next categories"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M9 18L15 12L9 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const slider = document.getElementById('PopularCategorySlider-{{ section.id }}');
    if (!slider) return;

    const prevBtn = document.querySelector('.popular-category__prev-{{ section.id }}');
    const nextBtn = document.querySelector('.popular-category__next-{{ section.id }}');

    // Only activate JS scroll on desktop
    function isDesktop() {
      return window.innerWidth > 768;
    }

    function getScrollAmount() {
      return slider.clientWidth * 0.8;
    }

    prevBtn?.addEventListener('click', function () {
      if (!isDesktop()) return;
      slider.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn?.addEventListener('click', function () {
      if (!isDesktop()) return;
      slider.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  });
</script>

{% schema %}
{
  "name": "Popular Category Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "POPULAR CATEGORY"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop visible columns",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right (desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "label": "Padding left (mobile)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "label": "Padding right (mobile)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "T-Shirts"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Popular Category Slider",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
