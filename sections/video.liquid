{%- liquid
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image
-%}
<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.video_ratio == 'adapt' %}
      {%- if poster != null -%}
      --media-ratio: {{ poster.aspect_ratio }};
      {%- else -%}
      --media-ratio: 16/9;
      {%- endif -%}
    {% else -%}
      --media-ratio: {{ section.settings.video_ratio }};
    {%- endif -%}
  }
  .section-video .blocks-radius{
    max-height:800px;
    position:relative;
  }
  #shopify-section-{{ section.id }} .video-section__overlay {
    position: absolute;
    left:10px;
    right:10px;
    bottom:10px;
    z-index: 2;
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .video-section__overlay-subheading {
    padding-bottom:16px;
    font-family: 'Montserrat',sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 17px;
    letter-spacing: 0.23em;
    text-align: center;
    width:100%;
    color:#fff;
    border-bottom:1px solid #FFFFFF1A;
    margin:0px;
  }

  #shopify-section-{{ section.id }} .video-section__overlay-heading {
    padding:10px 0px;
    text-align: center;
    width:100%;
    border-bottom:1px solid #FFFFFF1A;
    font-family: 'Bebas Neue',sans-serif;
    font-weight: 400;
    font-size: 60px;
    line-height: 42px;
    color:#FFF;
    letter-spacing: 0.01em;
  }

  #shopify-section-{{ section.id }} .video-section__overlay-link {
    font-family: 'Bebas Neue',sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 100%;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color:#FFF;
    padding:10px 0px;
    width:100%;
    display:flex;
    align-items:center;
    justify-content:center;
    border-bottom:1px solid #FFFFFF1A;
    cursor:pointer;
    z-index:10;
    position:relative;
    pointer-events: auto;
    text-decoration: none;
    gap: 6px;
  }
  #shopify-section-{{ section.id }} .video-section__overlay-link svg{
    margin-left:4px;
    margin-bottom:1px;
  }
  #shopify-section-{{ section.id }} .video-section__overlay-link svg path {
    fill: currentColor;
    color: #fff;
  }
   @media(max-width:768px){
     #shopify-section-{{ section.id }} .video-section__overlay-subheading {
      padding-bottom:10px;
      font-size: 11px;
      line-height: 14px;
    }
    #shopify-section-{{ section.id }} .video-section__overlay-heading {
      font-size: 44px;
      line-height: 36px;
    }
    #shopify-section-{{ section.id }} .video-section__overlay-link {
      font-size: 12px;
      line-height: 14px;
    }
    #shopify-section-{{ section.id }} .video-section__overlay-link svg{
      height:16px;
      width:16px;
    }
  }
  @media(max-width:425px){
  .section-video .blocks-radius{
      min-height:400px;
    }
    .media-container{
      --media-ratio: 16/15;
    }
  }
</style>

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

<div class="section-video section--padding">
  <div class="relative{% if section.settings.container == 'fixed' %} page-width{% endif %}">
    <div class="blocks-radius">
      <parallax-element
        class="block media-container"
        {% if section.settings.enable_parallax %}
          data-parallax="0.3" data-parallax-direction="{{ section.settings.parallax_direction }}"
        {% endif %}
      >
        <motion-element data-motion="zoom-out" class="relative block media media--adapt">
          {%- capture sizes -%}{% if section.settings.container == 'full' %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
          {%- render 'video',
            sizes: sizes,
            video: section.settings.video,
            video_url: section.settings.video_url,
            muted: section.settings.enable_video_autoplay,
            autoplay: section.settings.enable_video_autoplay,
            controls: true,
            loop: section.settings.enable_video_looping,
            description: section.settings.description,
            cover_image: section.settings.cover_image,
            show_play_button: true
          -%}
        </motion-element>
      </parallax-element>
    </div>
    {%- if section.settings.show_overlay_text -%}
      <div class="video-section__overlay">
        {%- if section.settings.overlay_subheading != blank -%}
          <p class="video-section__overlay-subheading">{{ section.settings.overlay_subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.overlay_heading1 != blank -%}
          <h2 class="video-section__overlay-heading">{{ section.settings.overlay_heading1 | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.overlay_heading2 != blank -%}
          <h2 class="video-section__overlay-heading">{{ section.settings.overlay_heading2 | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.overlay_link_label != blank -%}
          <a
            class="video-section__overlay-link"
            {% if section.settings.overlay_link != blank %}
              href="{{ section.settings.overlay_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.overlay_link_label | escape }}
            {% render 'icon-arrow-right' %}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Video",
  "settings": [
    {
      "type": "paragraph",
      "content": "[Read How-to](https://foxecom.link/534ZYP9)"
    },
    {
      "type": "header",
      "content": "t:sections.all.general.name"
    },
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full",
          "label": "t:sections.all.container.options__full.label"
        },
        {
          "value": "fixed",
          "label": "t:sections.all.container.options__fixed.label"
        }
      ],
      "default": "fixed",
      "label": "t:sections.all.container.label"
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__1.content"
    },
    {
      "type": "video",
      "label": "t:sections.video.settings.video.label",
      "id": "video"
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__2.content",
      "info": "t:sections.video.settings.paragraph.content"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["vimeo", "youtube"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "t:sections.video.settings.video_url.label",
      "info": "t:sections.video.settings.video_url.info"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.video.settings.cover_image.label"
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "t:sections.video.settings.video_ratio.label",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.video.settings.video_ratio.options__1.label"
        },
        {
          "value": "1/1",
          "label": "t:sections.video.settings.video_ratio.options__2.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.video.settings.video_ratio.options__3.label"
        },
        {
          "value": "4/5",
          "label": "t:sections.video.settings.video_ratio.options__4.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.video.settings.video_ratio.options__5.label"
        },
        {
          "value": "9/16",
          "label": "t:sections.video.settings.video_ratio.options__6.label"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.video.settings.description.label",
      "info": "t:sections.video.settings.description.info"
    },
    {
      "type": "header",
      "content": "Overlay text"
    },
    {
      "type": "checkbox",
      "id": "show_overlay_text",
      "label": "Enable overlay text",
      "default": false
    },
    {
      "type": "text",
      "id": "overlay_subheading",
      "label": "Subheading",
      "default": "POWERLOOK PRESENTS"
    },
    {
      "type": "text",
      "id": "overlay_heading1",
      "label": "Heading1",
      "default": "BEYOND"
    },
    {
      "type": "text",
      "id": "overlay_heading2",
      "label": "Heading2",
      "default": "ORDINARY"
    },
    {
      "type": "text",
      "id": "overlay_link_label",
      "label": "Link label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "overlay_link",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_video_autoplay",
      "label": "t:sections.video.settings.enable_video_autoplay.label",
      "info": "t:sections.video.settings.enable_video_autoplay.info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "t:sections.video.settings.enable_video_looping.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.all.enable_parallax_effect.label"
    },
    {
      "type": "select",
      "id": "parallax_direction",
      "label": "t:sections.all.parallax_direction.label",
      "options": [
        {
          "value": "vertical",
          "label": "t:sections.all.parallax_direction.options__1.label"
        },
        {
          "value": "horizontal",
          "label": "t:sections.all.parallax_direction.options__2.label"
        },
        {
          "value": "zoom",
          "label": "t:sections.all.parallax_direction.options__3.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:sections.all.divider.content"
    },
    {
      "type": "checkbox",
      "id": "show_section_divider",
      "default": false,
      "label": "t:sections.all.divider.settings.show_divider.label"
    },
    {
      "type": "select",
      "id": "divider_width",
      "options": [
        {
          "value": "fixed",
          "label": "t:sections.all.container.options__fixed.label"
        },
        {
          "value": "full",
          "label": "t:sections.all.container.options__full.label"
        }
      ],
      "default": "fixed",
      "label": "t:sections.all.divider.settings.divider_width.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.video.name"
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  }
}
{% endschema %}
