<script type="text/javascript">
  {% comment %} function trackMoEngageOrderCancelled() {
    // Check if MoEngage is available
    if (typeof Moengage !== 'undefined' && Moengage.track_event) {
      // Get the cancellation reason from the modal dropdown
      let cancellationReason = 'User initiated cancellation'; // Default fallback
      const cancelReasonSelect = document.getElementById('cancel_reason');
      //console.log('Cancel reason select element:', cancelReasonSelect);
      //console.log('Cancel reason select value:', cancelReasonSelect ? cancelReasonSelect.value : 'Element not found');
      if (cancelReasonSelect && cancelReasonSelect.value) {
        cancellationReason = cancelReasonSelect.value;
      //  console.log('Selected cancellation reason:', cancellationReason);
        
        // If "Others" is selected, get the custom reason from input field
        if (cancelReasonSelect.value === 'Others') {
          const otherReasonInput = document.getElementById('other_cancel_reason');
          if (otherReasonInput && otherReasonInput.value.trim()) {
          //  console.log('Other reason input element:', otherReasonInput);
        //  console.log('Other reason input value:', otherReasonInput ? otherReasonInput.value : 'Element not found');
            cancellationReason = otherReasonInput.value.trim();
           // console.log('Custom cancellation reason:', cancellationReason);
          }
        }
      } else {
      //  console.log('No cancellation reason selected or element not found');
      }

      // Prepare product details
      const productDetails = [];
      {% for item in order.line_items %}
        console.log('item.sku', item.sku, item);
        productDetails.push({
          product_id: {{ item.sku | escape }},
          product_title: "{{ item.product.title | escape }}",
          variant_id: {{ item.variant_id }},
          quantity: {{ item.quantity }},
          price: {{ item.final_line_price | divided_by: 100.0 }}
        });
      {% endfor %}

      // Track the event with all required attributes
      Moengage.track_event('Order Cancelled', {
        'Cancellation Reason': cancellationReason,
        'Order Amount': {{ order.total_price | divided_by: 100.0 }},
        'Product Details': productDetails,
        'Order ID': '{{ order.name }}',
        'Order Date': '{{ order.created_at | date: "%Y-%m-%d" }}',
        'Customer ID': '{{ customer.id }}',
        'Currency': '{{ order.currency }}',
        'Total Items': {{ order.line_items.size }},
        'Financial Status': '{{ order.financial_status }}',
        'Fulfillment Status': '{{ order.fulfillment_status }}'
      });
    } else {
    //  console.log('MoEngage not available for tracking order cancellation');
    }
  }

