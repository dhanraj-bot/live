{{ 'customer.css' | asset_url | stylesheet_tag }}

<style>
.order-details-container { display: grid; grid-template-columns: 2fr 1fr; gap: 38px; }
.order-header span { position: relative; font-size: 13px; display: inline-block; font-weight: 500; color: #75777d; }
.order-details-container .product-item { display: flex; gap: 15px; margin-bottom: 28px; margin-top: 20px; }
.order-details-container .product-item img { width: 66px; height: 100%; border-radius: 2px; }
.order-details-container .product-info h4 { font-size: 14px; font-weight: 600; padding-bottom: 8px; padding-top: 8px; }
.order-details-container .product-info p { margin: 2px 0; font-size: 12px; }
.order-details-container .sale-note { color: #d93025; font-size: 12px; }
.order-details-container .tracking-status { padding: 20px 0 30px; border-bottom: 1px solid #efefef; }
.status { padding: 5px 10px; border-radius: 20px; font-weight: bold; }
.status.ordered { background: #e0f7e9; color: #2d8a4f; }
.status.cancelled { background: #fdecea; color: #d93025; }
.summary-box { display: block; width: auto; margin-top: 50px; padding-left: 66px; border-left: 1px solid #efefef; height: 100%; }
.summary-box h3 { display: block; color: #252931; font-size: 16px; font-weight: 600; margin-bottom: 40px; }
.summary-box p { display: flex; justify-content: space-between; margin: 5px 0; }
.delivery-box { margin-top: 25px; display: flex; gap: 20px; }
.delivery-box h3 { margin-bottom: 5px; display: block; color: #252931; font-size: 16px; font-weight: 600; }
.order-header h1.customer__title span { font-size: 24px; margin-bottom: 10px; font-weight: 600; color: #111d2d; line-height: normal; }
.details_aligned_ctmdata { opacity: .72; color: #252931; font-size: 12px; font-weight: 500; display: flex; align-items: center; line-height: normal; }
.order-header { margin-bottom: 40px; line-height: normal; }
.delivery-box p { color: #252931; font-size: 14px; }
p.contact_details_order { font-weight: 600; }
.delivery_payment_info, .delivery_type_info { width: 50%; }
.details_aligned_ctmdata span {margin: 0px 4px;}
.inline-swatch { display:inline-block; width:15px; height:15px; border-radius:2px; border:none; box-shadow: 0 0 0 1px #c2c2c280; margin-left: 2px; }
.order-actions-btns {margin-top: 30px;}
.order-actions-btns a {font-size: 100%;}
/* Mobile & small tablet adjustments */
@media (max-width: 1024px) {
  .order-details-container {
    grid-template-columns: 1fr;
    gap: 0px;
  }
  .summary-box {
    padding-left: 0;
    border-left: none;
    margin-top: 20px;
  }

  .delivery-box {
    flex-direction: column;
    gap: 10px;
  }

  .delivery_payment_info,
  .delivery_type_info {
    width: 100%;
  }
}

/* Smaller mobile phones */
@media (max-width: 767px) {
.order-header h1.customer__title span {
  font-size: 20px;
}
.order-header span {
  font-size: 12px;
  {% comment %} display: block; {% endcomment %}
  margin-top: 5px;
}
.order-details-container .product-item img {
  max-width: 60px;
  height: auto;
}
.order-details-container .product-info h4 {
  font-size: 12px;
  padding-top: 0;
  line-height: normal;
}
.details_aligned_ctmdata {
  font-size: 11px;
  flex-wrap: wrap;
  line-height: 1.4;
}
.order-details-container .tracking-status {
  padding: 10px 0 20px;
}
.summary-box p {
  font-size: 13px;
}
.summary-box h3,
.delivery-box h3 {
  font-size: 15px;
}
.tracking-status {
  flex-direction: column;
  align-items: flex-start;
}
.order-actions-btns a { 
  padding: 0 20px;
}
}
</style>

<div class="customer order section section--padding" style="--section-padding-top: {{ section.settings.padding_top }}px;--section-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="order-details-container">
  
      <!-- Left Column -->
      <div>
        <!-- Order Header -->
        <div class="order-header">
          <h1 class="customer__title">
            <span>Order Details</span>
            <td>
              {% unless order.cancelled %}
              <a target='_blank' 
                href='/apps/download-pdf/orders/d7bfea227c4cb4d3b84c/{{ order.id | times: 6664 }}/{{ order.name | handleize }}.pdf'
              >Download Invoice</a>
            {% endunless %}
            </td>
          </h1>
          <span>Ordered on {{ order.created_at | date: "%d %b, %Y" }} &nbsp;|&nbsp; Order ID {{ order.name }}</span>
        </div>
          {% assign tracking_num = '' %}
                    {%- for line_item in order.line_items -%}
                      {%- if line_item.fulfillment.tracking_number -%}
                        {% assign tracking_num = line_item.fulfillment.tracking_number %}
                        {%- endif -%}
              {%- endfor -%}
            
          {% if tracking_num != '' %}
            <iframe
              width="100%"
              height="450"
              src="https://powerlook.clickpost.ai/?app_only=true&waybill={{ tracking_num }}"
              title="ClickPost"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            ></iframe>

          {% endif %}

        <!-- Product List -->
        {% for item in order.line_items %}
          {% assign size_value = '' %}
          {% assign color_value = '' %}
          {% assign other_pairs = '' %}
          {% for opt_name in item.product.options %}
            {% capture opt_val %}
              {% if forloop.index == 1 %}{{ item.variant.option1 }}
              {% elsif forloop.index == 2 %}{{ item.variant.option2 }}
              {% else %}{{ item.variant.option3 }}{% endif %}
            {% endcapture %}
            {% assign dn = opt_name | downcase %}
            {% assign ov = opt_val | strip %}
            {% if ov != blank %}
              {% if dn contains 'size' %}
                {% assign size_value = ov %}
              {% elsif dn contains 'color' or dn contains 'colour' %}
                {% assign color_value = ov %}
              {% else %}
                {% if other_pairs == '' %}
                  {% assign other_pairs = opt_name | append: ': ' | append: ov %}
                {% else %}
                  {% assign other_pairs = other_pairs | append: ' · ' | append: opt_name | append: ': ' | append: ov %}
                {% endif %}
              {% endif %}
            {% endif %}
          {% endfor %}

          <div class="product-item">
            {% if item.image %}
              <a href="{{ item.url }}"><img src="{{ item.image | img_url: '200x' }}" alt="{{ item.product.title }}" width="" height=""></a>
            {% endif %}
            <div class="product-info">
              <a href="{{ item.url }}"><h4>{{ item.product.title }}</h4></a>

              <div class="details_aligned_ctmdata">
                {{ item.final_line_price | money }}
                {% if color_value != blank %}
                  <span>·</span>
                  Color: <span class="inline-swatch" style="background: {{ color_value }};"></span>
                {% endif %}
                {% if size_value != blank %}
                  <span>·</span>Size: {{ size_value }}
                {% endif %}
                {% if other_pairs != blank %}
                  <span>·</span> {{ other_pairs }}
                {% endif %}
                {% if item.quantity %}
                  <span>·</span>{{ item.quantity }} Item(s) 
                {% endif %}
                {% if item.sku %}
                  <span>·</span> SKU: {{ item.sku }}
                {% endif %}
              </div>

              {% if item.properties._no_return_exchange == 'true' %}
                <p class="order_sale-note" style="color:red;">This is a sale item and cannot be returned or exchanged.</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}

        <!-- Tracking Status -->
        <div class="tracking-status">
{% if order.financial_status == 'refunded' or order.financial_status == 'partially_refunded' or order.fulfillment_status == 'returned' %}
  <span class="btn btn--primary">Order returned</span> 
{% else %}
           {% if order.cancelled %}
            <span class="btn btn--primary">Order Cancelled</span>
          {% else %}
 {% assign tracking = false %}
          {%- for line_item in order.line_items -%}
            {%- if line_item.fulfillment.tracking_number -%}
               {% assign tracking = true %}
               {%- endif -%}
    {%- endfor -%}
    {% if tracking %}
  <a class="OrderListItems_tracks btn btn--primary" target="_blank" href="https://powerlook.clickpost.ai/my-order?order_id={{ order.name | remove:'#' }}">
    <img alt="Track Order" loading="lazy" src="https://cdn.shopify.com/s/files/1/0750/2685/8234/files/location_9989d91e-ec82-4307-b4db-53264a0e2df7.svg?v=1755166151">
    <span>Track order</span>
  </a>
  {% endif %}
  {% endif %}
 {% endif %}
        </div>

        <!-- Delivery Address + Payment Method -->
        <div class="delivery-box">
          <div class="delivery_type_info">
            <h3>Delivery Address</h3>
            {{ order.shipping_address | format_address }}
            {% if order.customer.phone %}
              <p class="contact_details_order">Contact: {{ order.customer.phone }}</p>
            {% endif %}
          </div>
          <div class="delivery_payment_info">
            <h3>Payment Method</h3>
            <p style="min-height: 30px;">
            {% if order.unique_gateways %}
            {% for gateway in order.unique_gateways %}
            
            {% case gateway %}
            {% when "cash_on_delivery" %}
            Cash on Delivery
            {% when "razorpay" %}
            Razorpay
            {% when "manual" %}
            Manual Payment
            {% else %}
            {{ gateway | replace: "_", " " | capitalize }}
            {% endcase %}
            
            {% endfor %}
            {% endif %} 
            </p>

             {% if tracking_num != '' %}
              <div class="tracking_number_info">
              <p class="contact_details_order">Tracking Number:  {{ tracking_num }}</p> 
              </div>
              {% endif %}

          </div>
         
        </div>
      </div>

      <!-- Right Column: Order Summary -->
      <div class="summary-box">
        <h3>Order Summary</h3>

        <p><span>Total MRP</span> <span>{{ order.line_items_subtotal_price | money }}</span></p>

        {% if order.total_discounts > 0 %}
          <p><span>Discount</span> <span>-{{ order.total_discounts | money }}</span></p>
        {% endif %}

        {% assign total_tax = 0 %}
        {% for tax in order.tax_lines %}
          {% assign total_tax = total_tax | plus: tax.price %}
        {% endfor %}
        <p><span>Estimated Tax</span> <span>{{ total_tax | divided_by: 100.0 | round: 2 }}</span></p>

        {% assign shipping_total = 0 %}
        {% for m in order.shipping_methods %}
          {% assign shipping_total = shipping_total | plus: m.price %}
        {% endfor %}
        {% if shipping_total > 0 %}
          <p><span>Shipping Fee</span> <span>{{ shipping_total | money }}</span></p>
        {% endif %}

        {% if order.total_duties %}
          <p><span>Duties</span> <span>{{ order.total_duties | money }}</span></p>
        {% endif %}

        {% if gateways contains 'Cash on Delivery' %}
          <p><span>COD Fee</span><span>{{ 100 | money }}</span></p>
        {% endif %}
        
        <p><strong>Order Total</strong> <strong>{{ order.total_price | money_with_currency }}</strong></p>
 
          {% unless order.cancelled %}
          <div class="order-actions-btns"> 
            <!-- start Cancellable app code -->
            {% assign cancellable_cutoff_time = order.metafields.cancellable.cutoff_timestamp | date: '%s' %}
            {% if uncancellable_finance_status contains order.financial_status or uncancellable_fulfillment_status contains order.fulfillment_status or order.cancelled or order.tags contains 'cannot-cancel' or cancellable_today_time > cancellable_cutoff_time %}
              {% assign can_cancel = false %}
            {% elsif time_limit_seconds > 0 %}
              {% assign limit_time = order.created_at | date: '%s' | plus: time_limit_seconds %}
              {% if cancellable_today_timestamp > limit_time %}
                {% assign can_cancel = false %}
              {% else %}
                {% assign can_cancel = true %}
              {% endif %}
            {% else %}
              {% assign can_cancel = true %}
            {% endif %}


            {% if can_cancel %}
              {% comment %} Hide cancel button for exchange orders {% endcomment %}
              {% assign has_exchange_order_tag = false %}
              {% for tag in order.tags %}
                {% if tag contains 'EXCHANGE_ORDER' %}
                  {% assign has_exchange_order_tag = true %}
                  {% break %}
                {% endif %}
              {% endfor %}
              {% unless has_exchange_order_tag %}
              <div id="cancellable-button-rows" style="display: inline-block;">
                <!-- the cancel button -->
              {% unless order.fulfillment_status == 'shipped' %}
                <button class="button btn btn--primary cstm-order-cancel" aria-label="Cancel order" data-action="cancel" data-order="{{ order.id }}" data-shop="{{ shop.permanent_domain }}" onclick="window.cancellable_product_ids = '{{ order.line_items | map: 'product_id' | join: ','}}'; window.cancellable_token = '{{ order.confirmation_number }}'; window.cancellable_customer_id = '{{ customer.id }}'; window.cancellable_order_id = '{{ order.id }}'; cancellable_show_cancel_modal();">Cancel Order</button>
              {% endunless %}
              </div>
              {% endunless %}
            {% elsif order.cancelled %}
            <span>Cancelled</span>
            {% endif %}
          <!-- end Cancellable app code -->

 {% comment %} {% unless order.financial_status == 'refunded' or order.financial_status == 'partially_refunded' or order.fulfillment_status == 'returned' %}         
 <!-- Return/Exchange code -->
 {% if order.fulfillment_status == 'fulfilled' %}
  {% assign return_base_date = '' %}
  {% assign has_delivery_tag = false %}
  
  {% comment %} Check for delivery date in order tags {% endcomment %}
  {% for tag in order.tags %}
    {% if tag contains 'Deliverydate_' %}
      {% assign has_delivery_tag = true %}
      {% assign delivery_date_string = tag | remove: 'Deliverydate_' %}
      {% assign return_base_date = delivery_date_string | date: "%s" | times: 1 %}
      {% break %}
    {% endif %}
  {% endfor %}
  
  {% comment %} If no delivery date tag, use fulfillment date {% endcomment %}
  {% if has_delivery_tag == false %}
    {% for line_item in order.line_items %}
      {% if line_item.fulfillment %}
        {% assign return_base_date = line_item.fulfillment.created_at | date: "%s" | times: 1 %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}
  
  {% comment %} Calculate 10 days period and check if button should be shown {% endcomment %}
  {% if return_base_date != '' %}
    {% assign seven_days_later = return_base_date | plus: 864000 %}
    {% assign current_time = 'now' | date: "%s" | times: 1 %}
    
    {% if current_time <= seven_days_later %}
      <button onclick="requestReturn(this, '{{ shop.domain }}', '{{ order.id }}', '{{ customer.id }}')" 
              class="return-btn button btn btn--primary" 
              data-order='{{ order.id }}'>
        Return / Exchange
      </button>
    {% else %}
      <p class="return_exchange_messages">Return / Exchange period has expired.</p>
    {% endif %}
  {% endif %}
{% endif %}
 <!-- Return/Exchange code -->
  {% endunless %} {% endcomment %}

  {% unless order.financial_status == 'refunded' or order.financial_status == 'partially_refunded' or order.fulfillment_status == 'returned' %}
  <!-- Return/Exchange code -->
  {% if order.fulfillment_status == 'fulfilled' %}

    {% assign delivered_date = blank %}
    {% assign history = order.metafields.appbrew.history %}

    {% if history != blank %}

      {% comment %} Split history into individual lines/entries {% endcomment %}
      {% assign history_string = history | append: '' %}
      {% assign history_lines = history_string | newline_to_br | split: '<br />' %}

      {% comment %} Loop through all lines and capture the LATEST DELIVERED entry {% endcomment %}
      {% for line in history_lines %}
      {% if line contains 'DELIVERED' %}
      {% assign cleaned_line = line | strip | replace: '	', ' ' %}
      {% assign parts = cleaned_line | split: ' ' %}

      {% comment %} The timestamp is the last non-empty part of the line {% endcomment %}
          {% for part in parts reversed %}
              {% assign trimmed = part | strip %}
                {% if trimmed contains 'T' and trimmed contains 'Z' %}
                  {% assign delivered_date = trimmed %}
                {% break %}
              {% endif %}
          {% endfor %}
        {% endif %}
      {% endfor %}

    {% endif %}

    {% comment %} Only proceed if we found a DELIVERED entry with a valid date {% endcomment %}
    {% if delivered_date != blank %}

      {% assign delivered_timestamp = delivered_date | date: "%s" | plus: 0 %}
      {% assign expiry_timestamp = delivered_timestamp | plus: 864000 %}
      {% assign now_timestamp = 'now' | date: "%s" | plus: 0 %}

      {% if now_timestamp <= expiry_timestamp %}
        <button onclick="requestReturn(this, '{{ shop.domain }}', '{{ order.id }}', '{{ customer.id }}')" class="return-btn button btn btn--primary" data-order='{{ order.id }}'>
          Return / Exchange
        </button>
      {% else %}
        <p class="return_exchange_messages">The return/exchange period has expired.</p>
      {% endif %}

    {% endif %} 
  {% endif %}
<!-- Return/Exchange code -->
{% endunless %}

          </div>
          {% endunless %}
      </div>

    </div>
  </div>
</div>

