    // Try multiple times to get the values as the modal might be in different states
    let attempts = 0;
    const maxAttempts = 5;
    const tryToTrack = () => {
      attempts++;
      //console.log(`Attempt ${attempts} to track cancellation reason`);
      const cancelReasonSelect = document.getElementById('cancel_reason');
      if (cancelReasonSelect && cancelReasonSelect.value && cancelReasonSelect.value !== '') {
       // console.log('Found cancellation reason, proceeding with tracking');
        trackMoEngageOrderCancelled();
      } else if (attempts < maxAttempts) {
       // console.log(`Attempt ${attempts} failed, retrying in 200ms...`);
        setTimeout(tryToTrack, 200);
      } else {
       // console.log('Max attempts reached, tracking with default reason');
        trackMoEngageOrderCancelled();
      }
    };
    tryToTrack();
  }

  // Override the cancellable_cancel_clicked function to add tracking
  if (typeof cancellable_cancel_clicked !== 'undefined') {
    const originalCancellableCancelClicked = cancellable_cancel_clicked;
    cancellable_cancel_clicked = function() {
      // Track the MoEngage event first
      trackCancellationOnProceed();
      // Then call the original function
      return originalCancellableCancelClicked.apply(this, arguments);
    };
  } else {  
