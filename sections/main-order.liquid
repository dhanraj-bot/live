<!-- start Cancellable app code, this is for checking the order financial status and time limit for cancellation -->
{% assign uncancellable_finance_status = "refunded,partially_refunded,voided" | split:"," %}
{% assign uncancellable_fulfillment_status = "fulfilled,partial" | split:"," %}
{% assign cancellable_today_time = 'now' | date: '%s' %}
{% assign cancellable_today_timestamp = 'now' | date: '%s' | plus: 0 %}
{% assign time_limit_seconds = shop.metafields.cancellable.time_limit_seconds.value | plus: 0 %}
<!-- end Cancellable app code -->

