{%- liquid
  assign section_id = section.id
  assign heading_text = section.settings.heading | default: ''
  assign subtext_text = section.settings.subtext | default: ''
-%}

<section class="triple-banner triple-banner--{{ section_id }}">
  <div class="triple-banner__hero">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2200
        | image_tag:
          class: 'triple-banner__hero-image',
          loading: 'lazy',
          sizes: '100vw',
          widths: '640, 900, 1200, 1600, 2200',
          alt: heading_text
      }}
    {%- else -%}
      <div class="triple-banner__hero-placeholder"></div>
    {%- endif -%}
    {%- if section.settings.hero_image_mobile != blank -%}
      {{
        section.settings.hero_image_mobile
        | image_url: width: 2200
        | image_tag:
          class: 'triple-banner__hero-image-mobile',
          loading: 'lazy',
          sizes: '100vw',
          widths: '640, 900, 1200, 1600, 2200',
          alt: heading_text
      }}
    {%- endif -%}
    <div class="triple-banner__hero-overlay"></div>
  </div>

  <div class="triple-banner__grid">
    <a href="{{ section.settings.left_link | default: '#' }}" class="triple-banner__card">
      {%- if section.settings.left_image != blank -%}
        {{
          section.settings.left_image
          | image_url: width: 1200
          | image_tag:
            class: 'triple-banner__card-image',
            loading: 'lazy',
            sizes: '(max-width: 767px) 100vw, 50vw',
            widths: '480, 640, 900, 1200',
            alt: section.settings.left_text
        }}
      {%- else -%}
        <div class="triple-banner__card-placeholder"></div>
      {%- endif -%}
      <div class="triple-banner__card-overlay"></div>
      <div class="triple-banner__card-label">
        <span>{{ section.settings.left_text }}</span>
        {% if section.settings.left_sub_text %}
          <div class="subtext">{{ section.settings.left_sub_text }}</div>
        {% endif %}
      </div>
    </a>

    <a href="{{ section.settings.right_link | default: '#' }}" class="triple-banner__card">
      {%- if section.settings.right_image != blank -%}
        {{
          section.settings.right_image
          | image_url: width: 1200
          | image_tag:
            class: 'triple-banner__card-image',
            loading: 'lazy',
            sizes: '(max-width: 767px) 100vw, 50vw',
            widths: '480, 640, 900, 1200',
            alt: section.settings.right_text
        }}
      {%- else -%}
        <div class="triple-banner__card-placeholder"></div>
      {%- endif -%}
      <div class="triple-banner__card-overlay"></div>
      <div class="triple-banner__card-label flex flex-col items-center">
        <span>{{ section.settings.right_text }}</span>
        {% if section.settings.right_sub_text %}
          <div class="subtext">{{ section.settings.right_sub_text }}</div>
        {% endif %}
      </div>
    </a>
    <div class="triple-banner__hero-content">
      {%- if section.settings.line1 -%}
        <div class="line1"></div>
      {%- endif -%}
      <h2 class="triple-banner__title">{{ heading_text }}</h2>
      <div class="triple-banner__badge-container">
        <div class="triple-banner__badge">
          <p class="triple-banner__badge_text">{{ subtext_text }}</p>
        </div>
        {%- if section.settings.line2 -%}
          <div class="line2"></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');

  .triple-banner--{{ section_id }} {
    background: #1a1d1f;
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .triple-banner--{{ section_id }} .triple-banner__hero {
    position: relative;
    overflow: hidden;
  }

  .triple-banner--{{ section_id }} .triple-banner__hero-image,
  .triple-banner--{{ section_id }} .triple-banner__hero-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .triple-banner--{{ section_id }} .triple-banner__hero-image-mobile {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }

  .triple-banner--{{ section_id }} .triple-banner__hero-placeholder {
    background: linear-gradient(180deg, #7d8482 0%, #222729 55%, #111416 100%);
  }

  .triple-banner--{{ section_id }} .triple-banner__hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .triple-banner--{{ section_id }} .triple-banner__hero-content {
    position: absolute;
    top: -160px;
    text-align: center;
    z-index: 2;
    width: 100%;
    max-height: max-content;
    display:flex;
    flex-direction:column;
    gap:28px;
    align-items:center;
  }

  .triple-banner--{{ section_id }} .triple-banner__title {
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: 60px;
    line-height: 48px;
    letter-spacing: 0.01em%;
    text-align: center;
    vertical-align: middle;
    color: #FFFFFF;
  }
  .triple-banner__badge-container{
    margin:0 auto;
    width:calc(100% - 2rem);
    position:relative;
  }
  .triple-banner--{{ section_id }} .triple-banner__badge {
    padding-top: 10px;
    padding-right: 20px;
    padding-bottom: 10px;
    padding-left: 20px;
    background:white;
    margin:0px;
    max-width:max-content;
    margin:0 auto;
    z-index:5;
    position:relative;

  }
  .triple-banner--{{ section_id }} .triple-banner__badge_text {
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: 32px;
    line-height: 35px;
    letter-spacing: 0.01em;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    color:#453D2B;
    margin:0px;
  }

  .triple-banner--{{ section_id }} .triple-banner__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    background: transparent;
    padding: 20px 64px;
    position: absolute;
    bottom: 0px;
    left:0px;
    right: 0px;
  }

  .triple-banner--{{ section_id }} .triple-banner__card {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    background: #14181a;
    min-height: 22rem;
  }

  .triple-banner--{{ section_id }} .triple-banner__card-image,
  .triple-banner--{{ section_id }} .triple-banner__card-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .triple-banner--{{ section_id }} .triple-banner__card-placeholder {
    background: linear-gradient(180deg, #b8bec4 0%, #7f878e 60%, #30363b 100%);
  }

  .triple-banner--{{ section_id }} .triple-banner__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 11, 12, 0.03) 52%, rgba(8, 9, 10, 0.86) 100%);
    pointer-events: none;
  }

  .triple-banner--{{ section_id }} .triple-banner__card-label {
    position: absolute;
    bottom: 2rem;
    z-index: 2;
    color: #ffffff;
    text-transform: uppercase;
    width: 100% ;
    font-family: "Bebas Neue", sans-serif;
    font-weight: 400;
    font-size: 32px;
    line-height: 130%;
    letter-spacing: 0%;
    text-align: center;
    vertical-align: middle;

  }
  .subtext{
    font-family: 'Montserrat',sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 130%;
    color:white;
  }
  .triple-banner--{{ section_id }} .triple-banner__card:hover .triple-banner__card-image {
    transform: scale(1.03);
  }
  .line2{
    width:100%;
    border: 1px solid var(--Stroke-Light, #FFFFFF1A);
    position:absolute;
    bottom:50%;
    transform:translateY(-50%);
    z-index:2;

  }
  .line1{
    width: calc(100% - 2rem);
    border: 1px solid var(--Stroke-Light, #FFFFFF1A);
    top:-3rem;
    position:absolute;
  }
  @media (max-width: 767px) {
     .triple-banner--{{ section_id }} {
      background: #1a1d1f;
      position: relative;
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .triple-banner--{{ section_id }} .triple-banner__title {
      font-size: 44px;
      line-height: 44px;
      max-width:240px;
    }
    .triple-banner--{{ section_id }} .triple-banner__hero-content{
      gap:8px;
    }
    .triple-banner--{{ section_id }} .triple-banner__badge {
      padding:0px;
      background:transparent;
      margin:0 auto;
    }
    .triple-banner--{{ section_id }} .triple-banner__badge_text {
      font-size: 16px;
      line-height: 19px;
      color:white;
      text-align:center;
    }
    .triple-banner--{{ section_id }} .triple-banner__hero-content {
      top:-140px;
    }
    .triple-banner--{{ section_id }} .triple-banner__hero {
      min-height: 32rem;
    }
    .line2{
      display: none !important;
    }
    .line1{
      display: none !important;
    }

    .triple-banner--{{ section_id }} .triple-banner__hero-image,
    .triple-banner--{{ section_id }} .triple-banner__hero-placeholder {
      min-height: 32rem;
    }
    .triple-banner--{{ section_id }} .triple-banner__hero-image {
      display: none;
    }
    .triple-banner--{{ section_id }} .triple-banner__hero-image-mobile {
      display: block;
      min-height: 32rem;
    }

    .triple-banner--{{ section_id }} .triple-banner__hero-content {
      bottom: 1.6rem;
      width:100%;
    }

    .triple-banner--{{ section_id }} .triple-banner__badge {
      font-size: 1.2rem;
      padding: 0.45rem 0.8rem;
    }

    .triple-banner--{{ section_id }} .triple-banner__grid {
      padding:16px;
      gap:12px;
    }

    .triple-banner--{{ section_id }} .triple-banner__card,
    .triple-banner--{{ section_id }} .triple-banner__card-image,
    .triple-banner--{{ section_id }} .triple-banner__card-placeholder {
      min-height: 14rem;
      object-fit: cover;
    }
    .triple-banner--{{ section_id }} .triple-banner__card-label {
      font-size: 1.3rem;
      bottom: 1rem;
    }
    .subtext{
      font-size:1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Triple image banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero Background Image mobile"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Left Text"
    },
    {
      "type": "text",
      "id": "left_sub_text",
      "label": "Left sub Text"
    },
    {
      "type": "url",
      "id": "left_link",
      "label": "Left Link"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Image"
    },
    {
      "type": "text",
      "id": "right_text",
      "label": "Right Text"
    },
    {
      "type": "text",
      "id": "right_sub_text",
      "label": "Right Sub Text"
    },
    {
      "type": "url",
      "id": "right_link",
      "label": "Right Link"
    },
    {
      "type": "checkbox",
      "id": "line1",
      "label": "Line before heading",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "line2",
      "label": "Line center of sub heading",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Triple image banner"
    }
  ]
}
{% endschema %}
