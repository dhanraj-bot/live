{%- liquid
  assign header_layout = section.settings.header_layout
  assign show_all_button_on_top = section.settings.show_all_button_on_top

  assign nav_style = section.settings.tabs_nav_style | default: 'design-1'
  assign nav_button_class = ''
  assign nav_button_text_class = ''
  if nav_style == 'design-2'
    assign nav_button_class = nav_button_class | append: ' btn--inherit'
    assign nav_button_text_class = nav_button_text_class | append: ' h2'
  endif

  assign limit = section.settings.limit
  assign enable_infinite_scroll = section.settings.enable_infinite_scroll
  assign columns_desktop = section.settings.columns

  assign infinite_scroll_render_buffer_batches = 4
  assign infinite_scroll_render_buffer = section.settings.infinite_scroll_batch | times: infinite_scroll_render_buffer_batches
  assign infinite_scroll_render_limit = limit | plus: infinite_scroll_render_buffer
  assign infinite_scroll_render_limit = section.settings.infinite_scroll_max_products | at_most: infinite_scroll_render_limit

  assign columns_tablet = columns_desktop | minus: 1
  if columns_desktop < 3 or request.design_mode
    assign columns_tablet = columns_desktop
  endif

  assign columns_mobile = section.settings.columns_mobile | plus: 0
  assign enable_swipe_mobile = section.settings.swipe_on_mobile

  assign is_metro = false
  if section.settings.grid_layout == 'metro'
    assign is_metro = true
  endif
-%}
{%- if is_metro -%}
  {%- render 'product-grid-metro-style',
    section_id: section.id,
    columns_desktop: columns_desktop,
    columns_tablet: columns_tablet,
    columns_mobile: columns_mobile
  -%}
{%- endif -%}
{%- capture image_sizes -%}
(max-width: 767px) calc((100vw - 30px) / {{ columns_mobile }}),
(max-width: 1023px) calc((100vw - 30px) / {{ columns_tablet }}),
{{ settings.page_width | divided_by: columns_desktop }}px
{%- endcapture -%}
{{ 'component-tabs.css' | asset_url | stylesheet_tag }}
{% style %}
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .section--product-tabs {
      padding-left: var(--section-padding-left);
      padding-right: var(--section-padding-right);
    }
  }
  @media (max-width: 767.98px) {
    #shopify-section-{{ section.id }} .tabs__panel {
      padding-inline: 16px;
    }
  }
  @media(min-width:768px){

    #shopify-section-{{ section.id }} .new-arrivals-tab:hover .tabs__tab-name {
      background-color: inherit !important;
      color: inherit !important;
    }
  }
  #shopify-section-{{ section.id }} .product-tabs__item--hidden {
    display: none !important;
  }
  #shopify-section-{{ section.id }} .product-tabs__infinite-sentinel {
    width: 100%;
    min-height: 24px;
  }
  #shopify-section-{{ section.id }} .product-tabs__infinite-loader {
    display: none;
    align-items: center;
    justify-content: center;
    color: #453d2b;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    line-height: 1.2;
    font-weight: 500;
    padding:16px 0px;
  }
  #shopify-section-{{ section.id }} .tabs__content[data-infinite-loading='true'] .product-tabs__infinite-loader {
    display: flex;
  }
{% endstyle %}

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

<div
  class="section section-{{ section.id }} section--padding section--product-tabs page-width color-{{ section.settings.color_scheme }}"
  style="--section-padding-top: {{ section.settings.padding_top }}px;--section-padding-bottom: {{ section.settings.padding_bottom }}px;--section-padding-left: {{ section.settings.padding_left }}px;--section-padding-right: {{ section.settings.padding_right }}px;"
  data-id="{{ section.id }}"
  data-section-name="section--product-tabs"
>
  {%- if header_layout == 'vertical' -%}
    <h2 class="new-arrivals-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.blocks.size > 0 -%}
    <tabs-component class="tabs tabs__nav-{{ nav_style }}">
      {%- liquid
        assign header_alignment = settings.section_header_alignment | replace: 'left', 'start' | replace: 'right', 'end'
        assign header_alignment_mobile = settings.section_header_alignment_mobile | replace: 'left', 'start' | replace: 'right', 'end'
        if header_alignment_mobile == 'inherit'
          assign header_alignment_mobile = header_alignment
        endif
        assign tab_header_class = 'flex md:justify-' | append: header_alignment | append: ' justify-' | append: header_alignment_mobile
        if header_layout == 'horizontal' or show_all_button_on_top
          assign tab_header_class = 'flex flex-col md:flex-row md:justify-between md:items-center' | append: ' items-' | append: header_alignment_mobile
          if header_alignment == 'end'
            assign tab_header_class = tab_header_class | append: ' md:flex-row-reverse'
          endif
        endif
      -%}
      <motion-element
        class="tabs__header tabs__header--{{ header_layout }} {{ tab_header_class }}"
        data-motion="fade-up"
      >
        {%- if header_layout == 'horizontal' -%}
          {% render 'section-heading', section_settings: section.settings %}
        {%- endif -%}
        <div class="tabs__nav-wrap">
          <div class="tabs__nav" role="tablist">
            {%- for block in section.blocks -%}
              {%- liquid
                assign collection = block.settings.collection
                if block.settings.title != blank
                  assign tab_name = block.settings.title
                else
                  if collection != blank
                    assign tab_name = collection.title
                  else
                    assign tab_name = 'Tab ' | append: forloop.index
                  endif
                endif
              -%}
              <button
                class="tabs__tab focus-inset{{ nav_button_class }} new-arrivals-tab"
                role="tab"
                id="{{- block.id -}}"
                {{ block.shopify_attributes }}
              >
                <span class="tabs__tab-name">{{- tab_name -}}</span>
              </button>
            {%- endfor -%}
          </div>
        </div>
        {%- if section.settings.button_label != blank and show_all_button_on_top -%}
          <div class="section__btn hidden md:block">
            <a
              class="btn {{ section.settings.button_style }}"
              {% if section.settings.button_link != blank %}
                href="{{ section.settings.button_link }}"
              {% else %}
                aria-disabled="true"
              {% endif %}
            >
              {{- section.settings.button_label -}}
            </a>
          </div>
        {%- endif -%}
      </motion-element>
      <div class="tabs__panel">
        {%- for block in section.blocks -%}
          {%- assign collection = block.settings.collection -%}
          <div
            class="tabs__content"
            id="tab-{{ block.id }}"
            data-index="{{ forloop.index0 }}"
            data-infinite-enabled="{{ enable_infinite_scroll }}"
            data-infinite-initial="{{ limit }}"
            data-infinite-batch="{{ section.settings.infinite_scroll_batch }}"
            role="tabpanel"
            {% unless forloop.first %}
              hidden
            {% endunless %}
          >
            <grid-list class="block{% if enable_swipe_mobile %} swipe-mobile swipe-mobile--{{ section.settings.columns_mobile }}-cols{% endif %}">
              <div class="products-list f-grid f-grid-{{ columns_mobile }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns_desktop }}-cols f-grid--gap-{{ section.settings.column_gap }} f-grid--row-gap-{{ section.settings.row_gap }}{% if enable_swipe_mobile %} swipe-mobile__inner{% endif %}">
                {%- if collection != blank -%}
                  {%- liquid
                    assign products_render_limit = limit
                    if enable_infinite_scroll
                      assign products_render_limit = infinite_scroll_render_limit
                    endif
                  -%}

                  {%- for product in collection.products limit: limit -%}
                    <div class="f-column" data-tab-product-item>
                      {%- if is_metro -%}
                        {%- render 'card-product-metro',
                          product: product,
                          image_sizes: image_sizes,
                          image_ratio: section.settings.pcard_image_ratio,
                          quick_view_suffix: block.id,
                          section_index: section.index,
                          index: forloop.index,
                          index0: forloop.index0,
                          columns_desktop: columns_desktop,
                          columns_tablet: columns_tablet,
                          columns_mobile: columns_mobile
                        -%}
                      {%- else -%}
                        {%- render 'card-product',
                          product: product,
                          image_sizes: image_sizes,
                          image_ratio: section.settings.pcard_image_ratio,
                          quick_view_suffix: block.id,
                          section_index: section.index,
                          index: forloop.index,
                          hide_similar_icon: true,
                        -%}
                      {%- endif -%}
                    </div>
                  {%- endfor -%}

                  {%- if enable_infinite_scroll and products_render_limit > limit -%}
                    <template data-infinite-items-template>
                      {%- for product in collection.products limit: products_render_limit offset: limit -%}
                        <div class="f-column" data-tab-product-item>
                          {%- if is_metro -%}
                            {%- render 'card-product-metro',
                              product: product,
                              image_sizes: image_sizes,
                              image_ratio: section.settings.pcard_image_ratio,
                              quick_view_suffix: block.id,
                              section_index: section.index,
                              index: forloop.index,
                              index0: forloop.index0,
                              columns_desktop: columns_desktop,
                              columns_tablet: columns_tablet,
                              columns_mobile: columns_mobile
                            -%}
                          {%- else -%}
                            {%- render 'card-product',
                              product: product,
                              image_sizes: image_sizes,
                              image_ratio: section.settings.pcard_image_ratio,
                              quick_view_suffix: block.id,
                              section_index: section.index,
                              index: forloop.index,
                              hide_similar_icon: true,
                            -%}
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                    </template>
                  {%- endif -%}

                {%- else -%}
                  {%- for i in (1..limit) -%}
                    <div class="f-column">
                      {% render 'card-product-placeholder', image_ratio: section.settings.pcard_image_ratio %}
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </grid-list>
            {%- if enable_infinite_scroll and collection != blank and collection.products_count > limit and products_render_limit > limit -%}
              <div class="product-tabs__infinite-sentinel" data-infinite-sentinel aria-hidden="true"></div>
              <div class="product-tabs__infinite-loader" data-infinite-loader>Loading products...</div>
            {%- endif -%}
            {% if block.settings.collectionLink and section.settings.button_label != blank %}
              <div class="text-center all-product">
                <a class="flex items-center justify-center gap-2 view-more-button w-full" href="{{ block.settings.collectionLink }}">
                  {{- section.settings.button_label -}}
                  {% render 'icon-arrow-right' %}
                </a>
              </div>
            {% endif %}
          </div>
        {%- endfor -%}
      </div>
    </tabs-component>
  {%- endif -%}
</div>
{%- if enable_infinite_scroll -%}
  <script src="{{ 'product-tabs-infinite-scroll.js' | asset_url }}" defer></script>
{%- endif -%}
