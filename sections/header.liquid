<link
  rel="stylesheet"
  href="{{ 'component-custom-card.css' | asset_url }}"
  media="print"
  fetchpriority="low"
  onload="this.media='all'"
>
<script src="{{ 'header.min.js' | asset_url }}" defer="defer"></script>
{%- liquid
  assign header_layout = section.settings.header_layout
  assign sticky_header = section.settings.sticky_header
  assign menu = section.settings.menu
  assign menu_mobile = section.settings.menu_mobile
  assign logo_mobile_position = section.settings.logo_mobile_position
  assign enable_transparent_header = section.settings.enable_transparent_header
  assign classes = 'header section--padding grid items-center' | append: ' header--' | append: header_layout
  assign classes = classes | append: ' color-' | append: section.settings.color_scheme
  assign classes = classes | append: ' header-mobile--' | append: logo_mobile_position

  if section.settings.container == 'fixed'
    assign classes = classes | append: ' page-width'
  else
    assign classes = classes | append: ' w-full'
  endif

  if section.settings.show_sperator_line
    assign classes = classes | append: ' header--show-sperator-line'
  endif

  if header_layout == 'center-split'
    assign link_split_count = section.settings.menu.links.size | times: 1.0 | divided_by: 2 | round
  endif

  if menu_mobile == blank
    assign menu_mobile = menu
  endif

  assign is_collection_page = false
  if request.page_type == 'collection' and collection.title != blank
    assign is_collection_page = true
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --logo-width: {{ settings.logo_width }}px;
    --logo-width-mobile: {{ settings.logo_width_mobile }}px;
    --color-transparent: {{ section.settings.transparent_header_color.red }},{{ section.settings.transparent_header_color.green }},{{ section.settings.transparent_header_color.blue }};
  }
{% endstyle %}
<style>
  .announcement-bar-timer {
    position: relative;
    width: 100%;
    background-color: var(--ab-bg-color);
    color: var(--ab-text-color);
    z-index: 21;
    padding: 0.75rem 1rem;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .announcement-bar-timer.is-hidden {
    display: none;
  }

  /* Adjust header position when announcement bar is visible */
  .header-sticky {
    transition: top 0.3s ease;
  }

  .announcement-bar-timer__container {
    max-width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    position: relative;
  }
  .wkh-icon {
    height: 36px;
    width: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sign-in-button {
    border: none;
    color: #fbfaf9;
    background-color: #202020;
    border-radius: 0px;
    outline: none;
    padding: 2px 16px;
    height: 32px !important;
    width: 71px !important;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 11px;
    line-height: 100%;
  }
  .announcement-bar-timer__content {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
    font-size: var(--font-body-size);
  }

  .announcement-bar-timer__countdown {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-variant-numeric: tabular-nums;
  }

  .countdown-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .countdown-value {
    font-size: var(--font-body-size);
    line-height: 1;
    min-width: 1.5rem;
    text-align: center;
  }

  .countdown-label {
    font-size: 10px;
    text-transform: uppercase;
    margin-top: 0.125rem;
  }

  .countdown-separator {
    font-size: 1.125rem;
    font-weight: 700;
    opacity: 0.6;
    padding: 0 0.125rem;
  }

  .announcement-bar-timer__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--ab-button-bg);
    color: var(--ab-button-text);
    padding: 0.4rem 1rem;
    border-radius: 0.25rem;
    text-decoration: none;
    font-size: 12px;
  }

  .announcement-bar-timer__close {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--ab-text-color);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .announcement-bar-timer__close:hover {
    opacity: 1;
  }
  .header-sticky header.header_timer {
    display: block;
    padding: 0 !important;
  }
  .header_timer div#night-theme-switcher-container {
    top: 135px !important;
  }
  #get-app-btn-mobile{
    display:none;
  }
  /* Mobile Responsive */
  @media screen and (max-width: 768px) {
    .announcement-bar-timer {
      padding: 0.625rem 0.75rem;
    }
    .header_timer div#night-theme-switcher-container {
      top: 63px !important;
    }
    .announcement-bar-timer__content {
      font-size: 11px;
      gap: 1rem;
    }

    .countdown-value {
      font-size: 10px;
    }

    .countdown-separator {
      font-size: 0.875rem;
    }

    .countdown-label {
      font-size: 8px;
    }

    .announcement-bar-timer__button {
      font-size: 10px;
    }

    .announcement-bar-timer__close {
      padding: 0.375rem;
    }
    .sign-in-button{
      display:none;
    }
    #get-app-btn-mobile{
      /* display:none !important; */
      border: none;
      color: #F6F6F6;
      background-color: #453D2B;
      border-radius: 0px;
      outline: none;
      padding: 2px 16px;
      height: 44px !important;
      width: 100% !important;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Montserrat', sans-serif;
      font-weight: 500;
      font-size: 14px;
      line-height: 100%;
      text-transform: capitalize;
    }
  }
  @media(min-width:768px){
    .hide-on-desktop{
      display:none;
    }
  }
</style>
{%- if section.settings.enable_timer -%}
  <div
    class="announcement-bar-timer"
    id="announcement-bar-{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-end-date="{{ section.settings.end_date }}"
    data-end-time="{{ section.settings.end_time }}"
    data-start-date="{{ section.settings.start_date }}"
    data-start-time="{{ section.settings.start_time }}"
    style="
      --ab-bg-color: {{ section.settings.background_color }};
      --ab-text-color: {{ section.settings.text_color }};
      --ab-button-bg: {{ section.settings.button_background }};
      --ab-button-text: {{ section.settings.button_text_color }};
    "
  >
    <div class="announcement-bar-timer__container">
      <div class="announcement-bar-timer__content">
        {%- if section.settings.label_text != blank -%}
          <span class="announcement-bar-timer__label">{{ section.settings.label_text }}</span>
        {%- endif -%}

        <div class="announcement-bar-timer__countdown" id="countdown-{{ section.id }}">
          <span class="countdown-unit">
            <span class="countdown-value" data-days>00</span>
            {%- if section.settings.show_labels -%}
              <span class="countdown-label">{{ section.settings.days_label }}</span>
            {%- endif -%}
          </span>
          <span class="countdown-separator">:</span>
          <span class="countdown-unit">
            <span class="countdown-value" data-hours>00</span>
            {%- if section.settings.show_labels -%}
              <span class="countdown-label">{{ section.settings.hours_label }}</span>
            {%- endif -%}
          </span>
          <span class="countdown-separator">:</span>
          <span class="countdown-unit">
            <span class="countdown-value" data-minutes>00</span>
            {%- if section.settings.show_labels -%}
              <span class="countdown-label">{{ section.settings.minutes_label }}</span>
            {%- endif -%}
          </span>
          <span class="countdown-separator">:</span>
          <span class="countdown-unit">
            <span class="countdown-value" data-seconds>00</span>
            {%- if section.settings.show_labels -%}
              <span class="countdown-label">{{ section.settings.seconds_label }}</span>
            {%- endif -%}
          </span>
        </div>

        {%- if section.settings.button_text != blank and section.settings.button_url != blank -%}
          <a
            href="{{ section.settings.button_url }}"
            class="announcement-bar-timer__button"
            {% if section.settings.button_new_tab %}
              target="_blank" rel="noopener"
            {% endif %}
          >
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
{% endif %}
<header
  data-section-id="{{ section.id }}"
  class="  {{ classes }}"
  {% if request.page_type == 'index' %}
    data-enable-transparent="{{ enable_transparent_header }}"
  {% endif %}
  {% if sticky_header != 'none' %}
    is="sticky-header" data-sticky-type="{{ sticky_header }}"
  {% else %}
    is="basic-header"
  {% endif %}
>
  {%- if header_layout != 'center-split' -%}
    <div class="header__icons header__icons--left lg:justify-start z-1 lg:hidden{% if logo_mobile_position == 'left' %} hidden{% endif %}">
      <div class="header__buttons flex items-center">
        {%- if is_collection_page -%}
          <button
            type="button"
            class="header-back-button btn btn--inherit flex items-center justify-center lg:hidden"
            aria-label="Back"
            onclick="if (window.history.length > 1) { window.history.back(); } else { window.location.href = '{{ routes.root_url }}'; }"
          >
            <span class="header-back-button__icon">
              {%- render 'icon-arrow-right', size: 'large' -%}
            </span>
          </button>
        {%- elsif menu_mobile != blank -%}
          <button
            class="menu-drawer-button btn btn--inherit flex items-center justify-center lg:hidden"
            aria-controls="MenuDrawer"
            aria-label="{{ 'accessibility.menu_drawer' | t }}"
          >
            {%- render 'icon-hamburger', size: 'large' -%}
          </button>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
  {%- if header_layout == 'center-split' -%}
    <div class="header__icons header__icons--left lg:justify-start z-1 !lg:hidden{% if logo_mobile_position == 'left' %} hidden lg:flex{% endif %}">
      <div class="header__buttons flex items-center justify-start">
        {%- if menu_mobile != blank -%}
          <button
            class="menu-drawer-button btn btn--inherit flex items-center justify-center lg:hidden{% if logo_mobile_position == 'left' %} hidden{% endif %}"
            aria-controls="MenuDrawer"
            aria-label="{{ 'accessibility.menu_drawer' | t }}"
          >
            {%- render 'icon-hamburger', size: 'large' -%}
          </button>
        {%- endif -%}
      </div>
    </div>
    <div class="header__navigation hidden lg:flex lg:justify-end">
      {% render 'desktop-menu', menu: section.settings.menu, limit: link_split_count, blocks: section.blocks %}
    </div>
  {%- endif -%}

  {%- if request.page_type == 'index' -%}
    <h1 class="header__logo flex justify-center z-1">
  {%- else -%}
    <div class="header__logo flex justify-center z-1{% if request.page_type == 'collection' and collection.title != blank %} header__logo--with-collection-title{% endif %}">
  {%- endif -%}
  <a
    href="{{ routes.root_url }}"
    class="h3 relative flex{% unless settings.logo %} header__logo--text{% else %} header__logo--image{% endunless %}"
  >
    {%- if settings.logo != blank -%}
      {%- liquid
        assign logo = settings.logo
        assign logo_width = settings.logo_width
        assign logo_width_2x = settings.logo_width | times: 2

        assign logo_mobile = settings.logo_mobile
        assign logo_width_mobile = settings.logo_width_mobile
        assign logo_width_mobile_2x = settings.logo_width_mobile | times: 2

        assign logo_transparent = settings.logo_transparent
        assign logo_transparent_mobile = settings.logo_transparent_mobile

        if logo_mobile == blank
          assign logo_mobile = logo
        endif

        if logo_transparent == blank
          assign logo_transparent = logo
        endif

        if logo_transparent_mobile == blank
          if logo_transparent == blank
            assign logo_transparent_mobile = logo_mobile
          else
            assign logo_transparent_mobile = logo_transparent
          endif
        endif
      -%}
      {%- if logo_mobile -%}
        <img
          srcset="{{ logo_mobile | image_url: width: logo_width_mobile }} 1x, {{ logo_mobile | image_url: width: logo_width_mobile_2x }} 2x"
          src="{{ logo_mobile | image_url: width: logo_width_mobile }}"
          loading="eager"
          width="24px"
          height="24px"
          alt="{{ logo_mobile.alt | default: shop.name | escape }}"
          class="logo header__logo--mobile md:hidden"
        >
      {%- endif -%}
      <img
        srcset="{{ logo | image_url: width: logo_width }} 1x, {{ logo | image_url: width: logo_width_2x }} 2x"
        src="{{ logo | image_url: width: logo_width }}"
        loading="eager"
        width="{{ logo.width }}"
        height="{{ logo.height }}"
        alt="{{ logo.alt | default: shop.name | escape }}"
        class="logo header__logo--desktop md:block"
      >
      {%- if enable_transparent_header and logo_transparent != blank -%}
        {%- if logo_transparent != blank -%}
          <img
            srcset="{{ logo_transparent | image_url: width: logo_width }} 1x, {{ logo_transparent | image_url: width: logo_width_2x }} 2x"
            src="{{ logo_transparent | image_url: width: logo_width }}"
            loading="eager"
            width="{{ logo_transparent.width }}"
            height="{{ logo_transparent.height }}"
            alt="{{ logo_transparent.alt | default: shop.name | escape }}"
            class="logo header__logo--desktop header__logo--transparent hidden md:block absolute"
          >
        {%- endif -%}
        {%- if logo_transparent_mobile != blank -%}
          <img
            srcset="{{ logo_transparent_mobile | image_url: width: logo_width_mobile }} 1x, {{ logo_transparent_mobile | image_url: width: logo_width_mobile_2x }} 2x"
            src="{{ logo_transparent_mobile | image_url: width: logo_width_mobile }}"
            loading="eager"
            width="{{ logo_transparent_mobile.width }}"
            height="{{ logo_transparent_mobile.height }}"
            alt="{{ logo_transparent_mobile.alt | default: shop.name | escape }}"
            class="logo header__logo--mobile header__logo--transparent md:hidden absolute"
          >
        {%- endif -%}
      {%- endif -%}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </a>
  {%- if request.page_type == 'collection' and collection.title != blank -%}
    <div data-facet-loading class="header__collection-title data_title_count hide-on-desktop">
      <div class="cstm_collection_title">
        <h2>{{ collection.title }}</h2>
      </div>
      <p class="m-0 header__collection-count" role="status">
        {%- liquid
          if collection.results_count
            echo 'products.facets.filters_selected' | t: terms: collection.terms, count: collection.results_count
          elsif collection.products_count == collection.all_products_count
            echo 'products.facets.product_count_simple' | t: count: collection.products_count
          else
            echo 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count
          endif
        -%}
      </p>
    </div>
  {%- endif -%}
  {%- if request.page_type == 'index' -%}
    </h1>
  {%- else -%}
    </div>
  {%- endif -%}

  {%- if section.settings.menu != blank -%}
    {%- if header_layout == 'center-split' -%}
      <div class="header__navigation header__navigation--split hidden lg:flex">
        {% render 'desktop-menu', menu: section.settings.menu, blocks: section.blocks, offset: link_split_count %}
      </div>
    {%- else -%}
      <div class="header__navigation hidden lg:flex">
        {% render 'desktop-menu', menu: section.settings.menu, blocks: section.blocks %}
      </div>
    {%- endif -%}
  {%- endif -%}

  <div class="header__icons header__icons--right flex justify-end z-1">
    <div class="header__buttons flex items-center justify-center">
      <a
        href="{{ routes.search_url }}"
        class="search-drawer-button flex items-center justify-center{% if header_layout == 'center-split' and logo_mobile_position == 'center' %} lg:flex{% endif %}"
        aria-controls="SearchDrawer"
        aria-label="{{ 'general.search.search' | t }}"
      >
        {%- render 'icon-search', size: 'large' -%}
      </a>
      <a
        href="{{ routes.cart_url }}"
        class="cart-drawer-button cart-drawer-button-header flex items-center justify-center relative"
      >
        {%- render 'icon-cart', size: 'large', name: settings.cart_icon -%}
        <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
        <cart-count
          class="cart-count cart-count--absolute font-body-bolder{% if cart.item_count > 99 %} cart-count--small-medium{% endif %}"
          aria-label="{{ 'general.cart.cart_count' | t: count: cart.item_count | escape }}"
          {% comment %}
            {% if cart == empty %}
              hidden
            {% endif %}
          {% endcomment %}
        >
          {%- if cart.item_count < 100 -%}
            {{- cart.item_count -}}
          {%- else -%}
            <span class="text-sm">99+</span>
          {%- endif -%}
        </cart-count>
      </a>
      {% comment %} <div class="wishlist-header-link">
        <a href="{{ routes.account_url }}" class="wkh-button">
          <span class="wkh-icon">
            {% render 'icon-heart' %}
          </span>
          <span class="wkh-counter">0</span>
        </a>
      </div> {% endcomment %}
      {% comment %} Flits Wishlist added by team start {% endcomment %}
      <div class="wishlist-header-link">
         {% if customer and customer.metafields.Flits.wishlisted_products and customer.metafields.Flits.wishlisted_products != "-1" %}
          {% assign flits_wishlist_count = customer.metafields.Flits.wishlisted_products | split:',' | size %}
          {% else %}
          {% assign flits_wishlist_count = 0 %}
          {% endif %}
        <a href="{{ routes.account_url }}/#wishlist" onclick="window.redirectToWishTab(event); return false;" class="flits-custom-header-wishlist flits-header-wishlist flits_header_wishlist_icon">
          <span class="flits-wishlist-icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 17.5L16.9813 10.4187C17.7139 9.68609 18.1255 8.69238 18.1255 7.65625C18.1255 6.62011 17.7139 5.62641 16.9813 4.89375C16.2486 4.16109 15.2549 3.74948 14.2188 3.74948C13.1826 3.74948 12.1889 4.16109 11.4563 4.89375L10 6.25L8.54378 4.89375C7.81112 4.16109 6.81742 3.74948 5.78128 3.74948C4.74514 3.74948 3.75144 4.16109 3.01878 4.89375C2.28612 5.62641 1.87451 6.62011 1.87451 7.65625C1.87451 8.69238 2.28612 9.68609 3.01878 10.4187L10 17.5Z" stroke="#202020" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="flits-wishlist-count" {% unless flits_wishlist_count > 0  %}style="visibility: hidden;"{%endunless %}>{{ flits_wishlist_count | strip }}</span>
        </a>
      </div>

      {%- if shop.customer_accounts_enabled -%}
        <a
          id="kpuserdesktop"
          href="javascript:void(0);"
          onclick="handleKpAndShopifyLogin(window.location.href);"
          class="account-button hidden lg:flex items-center justify-center sign-in-button"
        >
          {% if customer %}
            <span>{{ customer.first_name | default: customer.name | default: 'Account' }}</span>
          {% else %}
            <span>Sign in</span>
          {% endif %}
          {% comment %} {%- render 'icon-account', size: 'large' -%} {% endcomment %}
          {% if customer -%}
            <span class="customer_name_head hidden">{{ customer.name }}</span>
          {%- endif %}
          <span class="visually-hidden">
            {%- liquid
              if customer
                echo 'customer.account_fallback' | t
              else
                echo 'customer.log_in' | t
              endif
            -%}
          </span>
        </a>
      {%- endif -%}
      {% comment %} <button type="button" id="get-app-btn-mobile" class="get-app-btn-mobile">Get the app</button> {% endcomment %}
    </div>
  </div>
</header>
<div class="fixed-overlay z-10"></div>
{%- render 'menu-drawer', section: section, blocks: section.blocks -%}
{%- if section.settings.enable_timer -%}
  <script>
    (function () {
      // Update CSS variable for announcement bar height
      function updateAnnouncementBarHeight() {
        requestAnimationFrame(function () {
          const bars = document.querySelectorAll('.announcement-bar-timer:not(.is-hidden)');
          if (bars.length > 0) {
            const bar = bars[0];
            const height = bar.offsetHeight;
            document.documentElement.style.setProperty('--announcement-bar-height', height + 'px');
          } else {
            document.documentElement.style.setProperty('--announcement-bar-height', '0px');
          }
        });
      }

      // Initialize height immediately for visible bars
      updateAnnouncementBarHeight();

      function initCountdown(sectionId, startDate, startTime, endDate, endTime) {
        const bar = document.getElementById('announcement-bar-' + sectionId);
        const countdown = document.getElementById('countdown-' + sectionId);
        if (!bar || !countdown) return;

        const daysEl = countdown.querySelector('[data-days]');
        const hoursEl = countdown.querySelector('[data-hours]');
        const minutesEl = countdown.querySelector('[data-minutes]');
        const secondsEl = countdown.querySelector('[data-seconds]');

        // Parse dates
        const startDateTime = startDate && startTime ? new Date(startDate + 'T' + startTime) : null;
        const endDateTime = new Date(endDate + 'T' + endTime);

        function padZero(num) {
          return num < 10 ? '0' + num : num.toString();
        }

        function updateCountdown() {
          const now = new Date();

          // Check if we should show the bar based on start date
          if (startDateTime && now < startDateTime) {
            bar.classList.add('is-hidden');
            updateAnnouncementBarHeight();
            return;
          }

          const distance = endDateTime - now;

          if (distance < 0) {
            bar.classList.add('is-hidden');
            updateAnnouncementBarHeight();
            clearInterval(timer);
            return;
          }

          // Show bar if it was hidden due to start time
          if (bar.classList.contains('is-hidden') && !localStorage.getItem(storageKey)) {
            bar.classList.remove('is-hidden');
            updateAnnouncementBarHeight();
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          if (daysEl) daysEl.textContent = padZero(days);
          if (hoursEl) hoursEl.textContent = padZero(hours);
          if (minutesEl) minutesEl.textContent = padZero(minutes);
          if (secondsEl) secondsEl.textContent = padZero(seconds);
        }

        updateCountdown();
        const timer = setInterval(updateCountdown, 1000);
      }

      // Close functionality
      window.closeAnnouncementBar = function (sectionId) {
        const bar = document.getElementById('announcement-bar-' + sectionId);
        if (bar) {
          bar.classList.add('is-hidden');
          localStorage.setItem('announcement-bar-closed-' + sectionId, 'true');
          updateAnnouncementBarHeight();
        }
      };

      // Initialize on page load
      document.addEventListener('DOMContentLoaded', function () {
        const bars = document.querySelectorAll('[data-section-id]');
        bars.forEach(function (bar) {
          const sectionId = bar.getAttribute('data-section-id');
          const startDate = bar.getAttribute('data-start-date');
          const startTime = bar.getAttribute('data-start-time');
          const endDate = bar.getAttribute('data-end-date');
          const endTime = bar.getAttribute('data-end-time');

          if (endDate && endTime) {
            initCountdown(sectionId, startDate, startTime, endDate, endTime);
          }
        });

        // Update height after initialization
        setTimeout(updateAnnouncementBarHeight, 100);

      });

      // Update height on window resize
      let resizeTimeout;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(updateAnnouncementBarHeight, 100);
      });

      // Reinitialize on Shopify theme editor events
      if (Shopify && Shopify.designMode) {
        document.addEventListener('shopify:section:load', function (event) {
          const bar = event.target.querySelector('[data-section-id]');
          if (bar) {
            const sectionId = bar.getAttribute('data-section-id');
            const startDate = bar.getAttribute('data-start-date');
            const startTime = bar.getAttribute('data-start-time');
            const endDate = bar.getAttribute('data-end-date');
            const endTime = bar.getAttribute('data-end-time');

            // Clear any stored close state in theme editor
            localStorage.removeItem('announcement-bar-closed-' + sectionId);

            if (endDate && endTime) {
              initCountdown(sectionId, startDate, startTime, endDate, endTime);
            }

            setTimeout(updateAnnouncementBarHeight, 100);
          }
        });

        document.addEventListener('shopify:section:unload', function () {
          setTimeout(updateAnnouncementBarHeight, 100);
        });
      }
    })();
  </script>
{% endif %}
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const appBtn = document.getElementById('get-app-btn-mobile');
    if (!appBtn) return;

    appBtn.addEventListener('click', function () {
      const userAgent = navigator.userAgent || navigator.vendor || window.opera;

      if (/android/i.test(userAgent)) {
        window.location.href = 'https://play.google.com/store/apps/details?id=com.powerlook.in.android';
      } else if (/iPad|iPhone|iPod/.test(userAgent)) {
        window.location.href = 'https://apps.apple.com/in/app/powerlook-mens-fashion/id6504237550';
      } else {
        // fallback (desktop)
        window.location.href = 'https://powerlook.in/';
      }
    });
  });
</script>
