        <p class="FooterLink_borderBottom__U9C94" style="display:block;"></p>
      {% endif %}
      <div class="footer__bottom ">
        {% liquid
          assign enable_country_selector = false
          assign enable_language_selector = false
          assign show_social = false

          if section.settings.enable_country_selector and localization.available_countries.size > 1
            assign enable_country_selector = true
          endif

          if section.settings.enable_language_selector and localization.available_languages.size > 1
            assign enable_language_selector = true
          endif

          if section.settings.show_social and has_social_icons
            assign show_social = true
          endif
        %}
        <motion-element class="block two_column_divide" data-motion="fade-up" data-motion-delay="50">
          <div class="footer__bottom-row flex justify-between items-center">
            {% comment %}
              <div class="footer__copyright">
                <p class="footer__copyright-content">
                  &copy; {{ 'now' | date: '%Y' }}
                  <a class="link-underline" href="{{ routes.root_url }}">{{ shop.name }}</a>.
                  <span>{{ powered_by_link }}</span>
                </p>

                {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                  <div class="footer__follow-on-shop">
                    {% comment %} TODO: enable theme-check once `login_button` is accepted as valid filter {% endcomment %}
                    {% # theme-check-disable %}
                    {{ shop | login_button: action: 'follow' }}
                    {% # theme-check-enable %}
                  </div>
                {%- endif -%}
              </div>
            {% endcomment %}
            {% comment %}
              <div class="rb-faq-shopify-section">

                <div class="rb-faq-container">

                    <div class="rb-faq-container-item">
                        <input style="display:none!important;" type="checkbox" id="tab{{forloop.index}}" class="tab-toggle">
                        <label for="tab{{forloop.index}}" class="rb-faq-question">Popular Categories</label>
                        <div class="rb-faq-answer">sssasasaa{{block.settings.answer}}</div>
                    </div>

                    <div class="rb-faq-container-item">
                        <input style="display:none!important;" type="checkbox" id="tab{{forloop.index}}" class="tab-toggle">
                        <label for="tab{{forloop.index}}" class="rb-faq-question">Popular Categories</label>
                        <div class="rb-faq-answer">sssasasaa{{block.settings.answer}}</div>
                    </div>
                    {%for block in section.blocks  limit: 2 %}
                    {% endfor %}
                </div>
              </div>
            {% endcomment %}

            <div class="expandable-wrapper">
              {% comment %} <div class="collapsible-section">
                <button class="toggle-button" data-target="trending-items">
                  <span class="section-heading">Popular Categories</span>
                  <span class="expand-indicator">+</span>
                </button>
                <div class="collapsible-panel" id="trending-items">
                  <div class="panel-content">
                    <!-- Nested Accordion -->
                    <div class="nested-accordion">
                      <div class="nested-section">
                        <button class="nested-toggle" data-nested-target="electronics-sub">
                          <span class="nested-title">T-Shirts For Men</span>
                          <span class="nested-indicator">+</span>
                        </button>
                        <div class="nested-panel" id="electronics-sub">
                          <div class="nested-content">
                          {% assign nav_menu = linklists[section.settings.footmenu] %}
                            {% if nav_menu.links.size > 0 %} 
                                {% for section_link in nav_menu.links %}
                                  {% if section_link.links.size > 0 %}
                                    <div class="filter-section mb-6">
                                      <h4 class="filter-heading font-bold mb-2">{{ section_link.title }}</h4>
                                      <ul class="filter-links flex flex-wrap items-center text-sm text-gray-800">
                                        {% for sublink in section_link.links %}
                                          <li>
                                            <a href="{{ sublink.url }}" class="hover:underline">
                                              {{ sublink.title }}
                                            </a>
                                          </li>
                                        {% endfor %}
                                      </ul>
                                    </div>
                                  {% endif %}
                                {% endfor %} 
                            {% endif %}
                          </div>
                        </div>
