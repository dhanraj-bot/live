          ></a>
        </div>
        <p class="FooterLink_borderBottom__U9C94" style="display:block;"></p>
        <div class=" container FooterLink_socialContainer__MHNrm">
          <div class="FooterLink_subContainer__gJ0AU black-theme">
            <p class="footer-content-text">100% Secure Payment:</p>
            <img
              alt=""
              loading="lazy"
	              width="132"
	              height="24"
              decoding="async"
              data-nimg="1"
              style="color:transparent"
	              srcset="https://cdn.shopify.com/s/files/1/0750/2685/8234/files/download_6_b8308b47-7ca6-46f9-b48a-9098a19233a2.png?v=1773404502 1x, https://cdn.shopify.com/s/files/1/0750/2685/8234/files/download_6_b8308b47-7ca6-46f9-b48a-9098a19233a2.png?v=1773404502 2x"
