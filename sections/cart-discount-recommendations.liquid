}
.product-card__content.product_discount_main_data {
    padding: 12px 0 0;
}
p#offer-text-content{
    margin: 0;
}
.cart-discount-recommendations {
  padding-top: 20px !important;
  padding-bottom: 20px !important;
}
@media (max-width: 767px) {
.discount-recommendations__underline-img{
    margin: 1rem auto 0;
    max-width: 150px;
}
.discount-recommendations__title, .discount-recommendations__subtitle {
    font-size: 20px;
}
.product-card__actions_divider span.product-card__price {
