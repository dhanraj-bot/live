{% comment %}
  Dynamic Cart Discount Recommendations Section  
  Matches Related Products design with slider support
{% endcomment %}

{%- liquid
  assign columns = section.settings.columns
  assign columns_mobile = section.settings.columns_mobile | plus: 0
  assign enable_slider = false
  assign enable_swipe_mobile = false
  assign recommendation_limit = 12
  assign recommendation_pool_limit = recommendation_limit | times: 2
  assign recommendation_pool_count = 0
  assign recommendation_pool_json = ''
  assign target_collection_handles = section.settings.target_collections | split: ','

  assign columns_tablet = columns | minus: 1
  if columns < 3
    assign columns_tablet = columns
  endif

  if section.settings.swipe_on_mobile
    assign enable_swipe_mobile = true
  endif

  assign item_css_class = 'f-column'
  if section.settings.enable_slider
    assign enable_slider = true
    assign item_css_class = item_css_class | append: ' swiper-slide'
  endif

  for collection_handle_raw in target_collection_handles
    if recommendation_pool_count >= recommendation_pool_limit
      break
    endif

    assign collection_handle = collection_handle_raw | strip
    if collection_handle == blank
      continue
    endif

    assign recommendation_collection = collections[collection_handle]
    if recommendation_collection == blank
      continue
    endif

    for product in recommendation_collection.products
      if recommendation_pool_count >= recommendation_pool_limit
        break
      endif

      assign product_in_cart = false
      for item in cart.items
        if item.product_id == product.id
          assign product_in_cart = true
          break
        endif
      endfor

      if product_in_cart or product.variants.size == 0
        continue
      endif

      if recommendation_pool_json != blank
        assign recommendation_pool_json = recommendation_pool_json | append: ','
      endif

      capture recommendation_product_json
        assign featured_image_url = ''
        if product.featured_media and product.featured_media.preview_image
          assign featured_image_url = product.featured_media.preview_image | image_url: width: 720
        elsif product.featured_image
          assign featured_image_url = product.featured_image | image_url: width: 720
        endif

        echo '{'
        echo '"id":' | append: product.id | append: ','
        echo '"title":' | append: product.title | json | append: ','
        echo '"handle":' | append: product.handle | json | append: ','
        echo '"url":' | append: product.url | json | append: ','
        echo '"featured_image":' | append: featured_image_url | json | append: ','
        echo '"options":['
        for option in product.options_with_values
          if forloop.index0 > 0
            echo ','
          endif
          echo '{'
          echo '"name":' | append: option.name | json | append: ','
          echo '"position":' | append: forloop.index
          echo '}'
        endfor
        echo '],'
        echo '"variants":['
        for variant in product.variants
          if forloop.index0 > 0
            echo ','
          endif

          assign variant_image_url = ''
          if variant.featured_media and variant.featured_media.preview_image
            assign variant_image_url = variant.featured_media.preview_image | image_url: width: 720
          elsif variant.image
            assign variant_image_url = variant.image | image_url: width: 720
          endif

          echo '{'
          echo '"id":' | append: variant.id | append: ','
          echo '"available":' | append: variant.available | append: ','
          echo '"price":' | append: variant.price | append: ','
          if variant.compare_at_price
            echo '"compare_at_price":' | append: variant.compare_at_price | append: ','
          else
            echo '"compare_at_price":null,'
          endif
          echo '"title":' | append: variant.title | json | append: ','
          echo '"option1":' | append: variant.option1 | json | append: ','
          echo '"option2":' | append: variant.option2 | json | append: ','
          echo '"option3":' | append: variant.option3 | json | append: ','
          echo '"featured_image":' | append: variant_image_url | json
          echo '}'
        endfor
        echo ']'
        echo '}'
      endcapture

      assign recommendation_pool_json = recommendation_pool_json | append: recommendation_product_json
      assign recommendation_pool_count = recommendation_pool_count | plus: 1
    endfor
  endfor
-%}

<script src="{{ 'product-slider.js' | asset_url }}" defer="defer"></script>
{% if cart.item_count > 0 %}
{% unless cart == empty %}
<section class="section section-{{ section.id }} cart-discount-recommendations color-{{ section.settings.color_scheme }}" 
  data-section-id="{{ section.id }}"
  data-section-type="cart-discount-recommendations"
  data-discount-enabled="{{ section.settings.enable_discount }}"
  data-discount-tier1-type="{{ section.settings.discount_tier1_type }}"
  data-discount-tier1-value="{{ section.settings.discount_tier1_value }}"
  data-discount-tier1-min="{{ section.settings.min_quantity_tier1 }}"
  data-discount-tier1-code="{{ section.settings.discount_tier1_code }}"
  data-discount-tier2-enabled="{{ section.settings.enable_discount_tier2 }}"
  data-discount-tier2-type="{{ section.settings.discount_tier2_type }}"
  data-discount-tier2-value="{{ section.settings.discount_tier2_value }}"
  data-discount-tier2-min="{{ section.settings.min_quantity_tier2 }}"
  data-discount-tier2-code="{{ section.settings.discount_tier2_code }}"
  data-target-collections="{{ section.settings.target_collections }}"
  data-target-types="{{ section.settings.target_product_types }}"
  data-columns="{{ columns }}"
  data-columns-tablet="{{ columns_tablet }}"
  data-enable-slider="{{ enable_slider }}"
  data-recommendation-limit="{{ recommendation_limit }}"
  data-show-edd="{{ settings.edd_show_on_cards }}"
  data-edd-standard-icon="{% if settings.edd_standard_delivery_icon != blank %}{{ settings.edd_standard_delivery_icon | image_url: width: 48 }}{% endif %}"
  data-edd-tomorrow-icon="{% if settings.edd_next_day_delivery_icon != blank %}{{ settings.edd_next_day_delivery_icon | image_url: width: 48 }}{% endif %}"
  data-edd-standard-heading="{{ settings.edd_standard_delivery_heading | default: 'Get it by : 2-5 Days' }}"
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; {% if section.settings.background_image != blank %}background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}'); background-size: cover; background-position: center; background-repeat: no-repeat;{% endif %}; display: block;">
  <script type="application/json" data-initial-cart>
    {
      "item_count": {{ cart.item_count }},
      "items": [
        {%- for item in cart.items -%}
          {
            "product_id": {{ item.product_id }},
            "product_type": {{ item.product_type | json }},
            "vendor": {{ item.vendor | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
  <script type="application/json" data-recommendation-pool>[{{ recommendation_pool_json }}]</script>

  <div class="discount-recommendations__header text-center">
    {% if section.settings.heading != blank %}
      <h2 class="discount-recommendations__title {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="discount-recommendations__subtitle {{ section.settings.heading_size }}">
        {{ section.settings.subheading }}
      </p>
    {% endif %}
    {% if section.settings.underline_image != blank %}
      <div class="discount-recommendations__underline-img">
        <img src="{{ section.settings.underline_image | image_url: width: 300 }}" alt="" width="300" height="auto" loading="lazy">
      </div>
    {% else %}
      <div class="discount-recommendations__underline"></div>
    {% endif %}
  </div>

  <div class="page-width">

  <div class="discount-recommendations__offer flex items-center justify-center" id="discount-offer-message" style="display: none;">
    <p class="offer-text" id="offer-text-content">
      <!-- Dynamic message will be inserted here -->
    </p>
  </div>

  <product-slider
    class="relative swiper-show-nav-on-hover"
    data-section-id="{{ section.id }}"
    {% if enable_slider %}
      data-enable-slider="true"
      data-items="{{ columns }}"
      data-tablet-items="{{ columns_tablet }}"
      data-calc-button-position="true"
    {% endif %}
  >
    <div class="products-grid-wrap{% if enable_slider %} swiper swiper-equal-height{% endif %}{% if enable_swipe_mobile %} swipe-mobile swipe-mobile--{{ columns_mobile }}-cols{% endif %}">
      {% comment %} <div id="products-grid" class="products-grid f-grid f-grid-{{ columns_mobile }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns }}-cols f-grid--gap-{{ section.settings.column_gap }} f-grid--row-gap-{{ section.settings.row_gap }}{% if enable_slider %} swiper-wrapper{% endif %}{% if enable_swipe_mobile %} swipe-mobile__inner{% endif %}"> {% endcomment %}
        <!-- Products will be loaded here -->
      {% comment %} </div> {% endcomment %}
       <div id="products-grid" class="products-grid f-grid f-grid-{{ columns_mobile }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns }}-cols f-grid--gap-{{ section.settings.column_gap }} f-grid--row-gap-{{ section.settings.row_gap }}{% if enable_slider %} swiper-wrapper{% endif %}{% if enable_swipe_mobile %} swipe-mobile__inner{% endif %}">
        {% for i in (1..4) %}
          <div class="{{ item_css_class }}">
            <div class="cart-rec-skeleton-card">
              <div class="cart-rec-skeleton-image"></div>
              <div class="cart-rec-skeleton-line cart-rec-skeleton-line--title"></div>
              <div class="cart-rec-skeleton-line cart-rec-skeleton-line--price"></div>
            </div>
          </div>
        {% endfor %}

      </div>
    </div>

    {%- if enable_slider -%}
      <div class="swiper-controls swiper-controls--{{ section.settings.controls_position }} hidden md:block">
        <button class="swiper-button-prev btn" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
          {% render 'icon-slider-prev' %}
        </button>
        <button class="swiper-button-next btn" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
          {% render 'icon-slider-next' %}
        </button>
      </div>
    {%- endif -%}
  </product-slider>

  <div class="discount-recommendations__empty text-center" id="recommendations-empty" style="display: none;">
    <p>{{ section.settings.empty_message | default: 'No recommendations available at the moment.' }}</p>
  </div>

  </div>
</section>
{% endunless %}
{% endif %}
<style>
  .cart-discount-recommendations {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    position: relative;
  }
  .discount-recommendations__title {
    color: {{ section.settings.text_color | default: '#333333' }};
    letter-spacing: normal;
  }

  .discount-recommendations__subtitle {
    color: {{ section.settings.primary_color | default: '#00A67E' }};
    margin-bottom: 0.5rem;
    letter-spacing: normal;
  }

  .discount-recommendations__underline {
    width: 100px;
    height: 3px;
    background-color: {{ section.settings.primary_color | default: '#00A67E' }};
    margin: 1rem auto;
  }

  .discount-recommendations__underline-img {
    margin: 0 auto;
    max-width: 200px;
    display: flex;
  }

  .discount-recommendations__underline-img img {
    width: 100%;
    height: auto;
  }

  .cart-discount-recommendations .products-grid-wrap{
    margin-top: 20px;
  }
  .discount-recommendations__header.text-center{
    margin-bottom: 20px;
}
  .offer-icon {
    font-size: 1.5rem;
  }

  .offer-amount {
    color: {{ section.settings.primary_color | default: '#00A67E' }};
  }

  /* Variant selector styling - ONLY for recommendation cards, NOT cart items */
  .cart-discount-recommendations .variant-selector {
    width: max-content;
    font-size: 12px;
    background-color: #fff;
    cursor: pointer;
    transition: border-color 0.15s ease-in-out;
    padding: 3px;
    padding-right:16px;
  }
  .product-card__actions_divider span.product-card__compare-price {
    text-decoration: line-through;
    opacity: .5;
}
.product-card__price-wrapper.flex.items-center.gap-2{
    flex-wrap: wrap;
    row-gap: 0;
}
  .cart-discount-recommendations .variant-selector:hover {
    border-color: #d1d5db;
  }

  .cart-discount-recommendations .variant-selector:focus {
    outline: none;
    border-color: {{ section.settings.primary_color | default: '#00A67E' }};
    box-shadow: 0 0 0 1px {{ section.settings.primary_color | default: '#00A67E' }};
  }

  .cart-discount-recommendations .variant-selector option:disabled {
    color: #9ca3af;
  }

  .cart-discount-recommendations .product-card__variant {
    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .cart-discount-recommendations .variant-label {
    font-size: 12px;
    color: #4B5563;
    font-weight: 400;
  }
  .product-card__actions_divider {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
button.product-card__add-btn {
    background: #F3F4F6;
    border: none;
    padding: 15px;
}
.product-card__actions_divider span.product-card__price{
    font-weight: 500;
    font-size: 16px;
    line-height: normal;
}
.product-card__actions_divider span.product-card__discount {
    color: #07A865;
    font-weight: 500;
    width: 100%;
}
.product_discount_main_data h3.product-card__title {
    font-family: var(--font-pcard-title-family);
    font-style: var(--font-pcard-title-style);
    font-weight: var(--font-pcard-title-weight);
    font-size: var(--font-pcard-title-size, 1.6rem);
    text-transform: var(--font-pcard-title-transform);
