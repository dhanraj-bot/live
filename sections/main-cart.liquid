  // Function to check if current discount is still valid after cart changes
  function checkDiscountValidity(cartData) {
    // Get current discount code if any
    const currentDiscountCode = getCurrentDiscountCode();
    
    if (currentDiscountCode) {
      // Check if discount is still valid with new cart state
      validateDiscountCode(currentDiscountCode, cartData);
    }
  }

  // Function to get current discount code from cart
  function getCurrentDiscountCode() {
    // Check if there's a discount applied
    const discountRow = document.querySelector('.wk-order-summary .price-row.discount');
    if (discountRow && discountRow.style.display !== 'none') {
      const discountLabel = document.getElementById('discount-label');
      if (discountLabel) {
        const labelText = discountLabel.textContent;
        // Extract discount code from label (assuming format: "(Title – CODE)")
        const match = labelText.match(/–\s*([A-Z0-9]+)\)/);
        if (match) {
          return match[1];
        }
      }
    }
    return null;
  }

  // Function to validate discount code with current cart state
  function validateDiscountCode(discountCode, cartData) {
    // Get cart totals for validation
    const cartTotal = cartData.total_price / 100; // Convert to dollars
    const cartQuantity = cartData.item_count;
    
    // Find the discount button for this code
    const discountButton = document.querySelector(`[data-discount-code="${discountCode}"]`);
    if (!discountButton) return;
    
    // Check if discount is still valid based on cart state
    let isValid = true;
    let reason = '';
    
    // Check minimum quantity requirements
    const minQuantity = discountButton.dataset.minQuantity;
    if (minQuantity && cartQuantity < parseInt(minQuantity)) {
      isValid = false;
      reason = `Minimum ${minQuantity} items required`;
    }
    
    // Check minimum value requirements
    const minValue = discountButton.dataset.minValue;
    if (minValue && cartTotal < parseFloat(minValue)) {
      isValid = false;
      reason = `Minimum ₹${minValue} required`;
    }
    
    // If discount is no longer valid, remove it
    if (!isValid) {
     // console.log(`Discount ${discountCode} no longer valid: ${reason}`);
      removeInvalidDiscount(discountCode, reason);
    }
  }

  // Function to remove invalid discount
  function removeInvalidDiscount(discountCode, reason) {
    // Show user notification
    alert(`Discount ${discountCode} has been removed: ${reason}`);
    
    // Remove discount via API
    removeDiscountCode(discountCode);
  }

  // Function to remove discount code
  function removeDiscountCode(discountCode) {
    // Get cart token
    fetch('/cart.js')
      .then(response => response.json())
      .then(cartData => {
        const cartToken = cartData.token;
        
        // Remove discount via GraphQL API
        const storefrontAccessToken = "df3b1660e6859f510b854dc282eccdf9";
        
        fetch("https://powerlook-apparels.myshopify.com/api/2024-10/graphql.json", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "x-shopify-storefront-access-token": storefrontAccessToken,
          },
          body: JSON.stringify({
            query: `
              mutation cartDiscountCodesUpdate($id: ID!, $discountCodes:[String!]) {
                cartDiscountCodesUpdate(cartId: $id, discountCodes: $discountCodes) {
                  cart {
