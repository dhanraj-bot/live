{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --mobile-cart-checkout-offset: 0px;
  }
{%- endstyle -%}
{{ 'cart.css' | asset_url | stylesheet_tag }}
{{ 'component-custom-card.css' | asset_url | stylesheet_tag }}
{{ 'checkout-offer-popup.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'checkout-offer-popup.js' | asset_url }}" defer="defer"></script>
{{ 'wishlist-feature.css' | asset_url | stylesheet_tag }}

{%- if linklists['gift-wrapping'].links != blank and linklists['gift-wrapping'].links.first.type == 'product_link' -%}
  <script src="{{ 'gift-wrapping.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<div class="cart section--padding{% if cart == empty %} is-empty{% endif %} {% unless cart == empty %} cart-background{% endunless %}">
  <div class="page-width">
    {% if section.settings.show_title %}
      <div class="cart__header text-center">
        <h1 class="cart__title hd2">
          <motion-element data-motion="fade-up" class="inline-flex">{{ 'sections.cart.title' | t }}</motion-element>
        </h1>
      </div>
    {% endif %}
    <div class="cart__empty text-center grid gap-5">
      <div class="flex items-center justify-center">
        {% if section.settings.empty_cart_web != blank %}
          {% assign img = section.settings.empty_cart_web %}
          <img
            src="{{ img | image_url: width: 600 }}"
            width="{{ img.width }}"
            height="{{ img.height }}"
            alt="Empty cart"
            class="hidden md:block"
            loading="lazy"
          >
        {% endif %}

        {% if section.settings.empty_cart_mweb != blank %}
          {% assign img_m = section.settings.empty_cart_mweb %}
          <img
            src="{{ img_m | image_url: width: 400 }}"
            width="{{ img_m.width }}"
            height="{{ img_m.height }}"
            alt="Empty cart"
            class="block md:hidden"
            loading="lazy"
          >
        {% endif %}
      </div>
      <div class="flex gap-5 items-center justify-center flex-col cart__empty-header">
        <h2 class="empty-cart-heading">{{ 'sections.cart.empty' | t }}</h2>
        <a href="/" class="shop-now">Start Shopping</a>
        {%- if settings.cart_empty_message != blank -%}
          <div class="rte text-lg hidden">{{ settings.cart_empty_message }}</div>
        {%- endif -%}
      </div>
      {%- if settings.collection_list != blank -%}
        <div class="try-these">Try These Collections</div>
        <div class="swipe-mobile">
          <div class="f-grid f-grid-4-cols f-grid--gap-medium f-grid--row-gap-large swipe-mobile__inner-cart">
            {%- for collection in settings.collection_list -%}
              {%- liquid
                assign first_product_in_collection = collection.products[0]
                assign collection_image = first_product_in_collection.featured_image

                if first_product_in_collection.featured_image == blank
                  assign collection_image = collection.featured_image
                endif
              -%}
              <div class="f-column">
                <div class="blocks-radius custom-card">
                  <a href="{{ collection.url }}" class="flex flex-col">
                    <div class="custom-card__media media-wrapper">
                      {%- if collection_image != blank -%}
                        {{
                          collection_image
                          | image_url: width: 1100
                          | image_tag:
                            loading: 'lazy',
                            class: 'motion-reduce',
                            widths: '165, 360, 535, 750, 940, 1100',
                            is: 'image-lazy'
                        }}
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                    <div class="custom-card__info blocks-radius-bottom-left-right flex items-center gap-2 z-1">
                      <h3 class="h4 flex flex-grow cart-collection-title">{{ collection.title | capitalize }}</h3>
                      <button
                        class="flex"
                        style="border:none; padding: 0; height: 24px;"
                        aria-label="{{ collection.title }}"
                      >
                        {% render 'icon-arrow-right' %}
                        {% comment %}
                          <svg
                            class="icon icon--medium"
                            width="20"
                            height="20"
                            viewBox="0 0 20 20"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M5 15L15 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M6.875 5H15V13.125" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        {% endcomment %}
                      </button>
                    </div>
                  </a>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <a class="btn btn--primary cart__empty-header" href="{{ routes.all_products_collection_url }}">
          {{- 'general.cart.continue_shopping' | t -}}
        </a>
      {%- endif -%}
    </div>
    {% if cart.item_count > 0 %}
      <div class="shopping-cart-title" colspan="1" scope="col">Shopping Cart ({{ cart.item_count }})</div>
    {% endif %}
    {%- if cart.item_count > 0 -%}
      <main-cart id="MainCart-{{ section.id }}" class="block">
        <form class="cart__form" action="{{ routes.cart_url }}" method="POST" id="cart">
          {% render 'cart-milestone-progress' %}
          {%- liquid
            for block in section.blocks
              if block.type == 'free_shipping_goal'
                if settings.free_shipping_minimum_amount != blank
                  assign minimum_amount = settings.free_shipping_minimum_amount | remove: ' '
                  render 'free-shipping-goal', minimum_amount: minimum_amount
                endif
              endif
            endfor
          -%}

          {%- liquid
            for block in section.blocks
              if block.type == 'estimate_delivery'
                render 'estimate-delivery', block: block
              endif
            endfor
          -%}

          {%- liquid
            if linklists['gift-wrapping'].links != blank and linklists['gift-wrapping'].links.first.type == 'product_link'
              assign gift_wrapping = linklists['gift-wrapping'].links.first
              assign gift_wrap_id = gift_wrapping.object.variants.first.id
              assign gift_wraps_in_cart = 0
              for item in cart.items
                if item.id == gift_wrap_id
                  assign gift_wraps_in_cart = item.quantity
                  break
                endif
              endfor
              assign items_in_cart = cart.item_count | minus: gift_wraps_in_cart
            endif
          -%}

          {% if section.settings.showoffertext %}
            <div class="offer_cart_title_main">{{ section.settings.offer_texts }}</div>
          {% endif %}
          {% comment %} <div class="shopping-cart-title" colspan="1" scope="col">Shopping Cart ({{ cart.item_count }} Items)</div> {% endcomment %}

          <cart-items>
            <div role="table" class="w-full" style="background-color:#FFF;padding:16px;">
              {%- liquid
                comment
                  Use cart.total_discount (official Liquid). cart.discount_total_price is not a documented
                  cart property and can be nil on SSR — then cap never activates after refresh.
                endcomment
                assign cart_discount_cap_active = false
                assign cap_dn = section.settings.cap_discount_name
                assign cap_dn2 = section.settings.cap_discount_name_2
                assign cap_da = section.settings.cap_discount_amount
                assign cap_da2 = section.settings.cap_discount_amount_2
                assign cap_dn_up = cap_dn | upcase
                assign cap_dn_up2 = cap_dn2 | upcase
                assign cart_cap_cents = 0
                for da in cart.discount_applications
                  assign da_title_up = da.title | upcase
                  assign da_code_up = da.code | default: '' | upcase
                  if cap_dn != blank and cap_da > 0 and cart_cap_cents == 0
                    if da_title_up == cap_dn_up or da_code_up == cap_dn_up
                      assign cart_cap_cents = cap_da | times: 100
                    endif
                  endif
                  if cap_dn2 != blank and cap_da2 > 0 and cart_cap_cents == 0
                    if da_title_up == cap_dn_up2 or da_code_up == cap_dn_up2
                      assign cart_cap_cents = cap_da2 | times: 100
                    endif
                  endif
                endfor
                if cart_cap_cents > 0 and cart.total_discount > cart_cap_cents
                  assign cart_discount_cap_active = true
                endif
              -%}
              <div>
                {%- for item in cart.items -%}
                  {%- liquid
                    assign is_gift_wrap_item = false
                    if gift_wrap_id != null and item.id == gift_wrap_id
                      assign is_gift_wrap_item = true
                    endif

                    assign has_qty_rules = false
                    if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                      assign has_qty_rules = true
                    endif

                    assign has_vol_pricing = false
                    if item.variant.quantity_price_breaks.size > 0
                      assign has_vol_pricing = true
                    endif
                  -%}

                  {%- if has_qty_rules or has_vol_pricing -%}
                    {%- capture qty_rules_vol_pricing -%}
                        {%- if has_qty_rules -%}
                          <div
                            class="quantity__rules text-sm"
                          >
                            {%- if item.variant.quantity_rule.increment > 1 -%}
                              <span class="divider">
                                {{-
                                  'products.product.quantity.multiples_of'
                                  | t: quantity: item.variant.quantity_rule.increment
                                -}}
                              </span>
                            {%- endif -%}
                            {%- if item.variant.quantity_rule.min > 1 -%}
                              <span class="divider">
                                {{-
                                  'products.product.quantity.minimum_of'
                                  | t: quantity: item.variant.quantity_rule.min
                                -}}
                              </span>
                            {%- endif -%}
                            {%- if item.variant.quantity_rule.max != null -%}
                              <span class="divider font-body-bold">
                                {{-
                                  'products.product.quantity.maximum_of'
                                  | t: quantity: item.variant.quantity_rule.max
                                -}}
                              </span>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                        {%- if has_vol_pricing -%}
                          {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
                          <volume-pricing class="block parent-display blocks-radius-md" id="Volume-{{ section.id }}">
                            <span class="caption block">{{ 'products.product.volume_pricing.title' | t }}</span>
                            <ul class="list-unstyled">
                              <li class="blocks-radius-md">
                                <span>{{ item.variant.quantity_rule.min }}+</span>
                                {%- liquid
                                  if settings.currency_code_enabled
                                    assign price = item.variant.price | money_with_currency
                                  else
                                    assign price = item.variant.price | money
                                  endif
                                -%}
                                <span> {{ 'sections.quick_order_list.each_html' | t: money: price }}</span>
                              </li>
                              {%- for price_break in item.variant.quantity_price_breaks -%}
                                <li class="blocks-radius-md">
                                  <span>
                                    {{- price_break.minimum_quantity -}}
                                    <span aria-hidden="true">+</span>
                                  </span>
                                  {%- liquid
                                    if settings.currency_code_enabled
                                      assign price_break_price = price_break.price | money_with_currency
                                    else
                                      assign price_break_price = price_break.price | money
                                    endif
                                  -%}
                                  <span>{{ 'sections.quick_order_list.each_html' | t: money: price_break_price }}</span>
                                </li>
                              {%- endfor -%}
                            </ul>
                          </volume-pricing>
                        {%- endif -%}
                      {%- endcapture -%}
                  {%- endif -%}

                  {%- capture cart_item -%}
                      <div class="cart-item" id="CartItem-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                        <div class="cart-item__product">
                          <div class="flex items-start ">
                            {%- if item.image -%}
                              <div style="position:relative;">
                                  <a class="cart-item__media blocks-radius-sm media-wrapper" href="{{ item.url }}" tabindex="-1">
                                    {{- item.image | image_url: width: item.image.width | image_tag: loading: 'lazy', widths: '180,360,540', is: 'image-lazy' -}}
                                  </a>
                                  {% assign inventory = item.variant.inventory_quantity %}
                                  <div class="cart-product-urgency">
                                    
                                    {% if inventory > 0 and inventory <= 5 %}
                                      <span class="cart-badge low-stock">
                                        <span class="cart-badge__battery">
                                          <span class="cart-badge__battery-level"></span>
                                        </span>

                                        {{ inventory }} LEFT
                                      </span>
                                    {% endif %}
                                  </div> 
                              </div>
                            {%- endif -%}
                            <div class="cart-item__product--info flex flex-col items-start gap-3 flex-grow">
                              <div class="flex flex-col gap-2 w-full">
                                <div class="flex flex-col gap-1 ">
                                  <div class="flex lg:items-center justify-between w-full gap-1 ">
                                    <div class="cart-item-price-mobile-wrapper">
                                      <div class="flex flex-col gap-2 selling-fast-wrapper">
                                        {% assign inventory = item.variant.inventory_quantity %}
                                          {% if inventory>5 and inventory <=10 %}
                                          <div class="cart-product-selling-fast">
                                            {% if inventory > 5 and inventory <= 10 %}
                                              <span class="selling-fast">
                                                Selling Fast
                                              </span>
                                            {% endif %}
                                          </div>
                                          {%  endif %}
                                          <a href="{{ item.url }}" class="cart-item__title text-pcard-title reversed-link">{{- item.product.title | escape -}}</a>
                                      </div>

                                      
                                      <div class="cart-item__total lg:table-cell hidden lg:block" style="max-height:20px;">
                                        <span class="font-body-bolder cart-item-total-price-desktop">
                                        {%- liquid
                                          if cart_discount_cap_active
                                            if settings.currency_code_enabled
                                              echo item.original_line_price | money_with_currency
                                            else
                                              echo item.original_line_price | money
                                            endif
                                          else
                                            if settings.currency_code_enabled
                                              echo item.final_line_price | money_with_currency
                                            else
                                              echo item.final_line_price | money
                                            endif
                                          endif
                                        -%}
                                        </span>
                                      </div>
                                    </div>

                                    <a id="Loader-{{ section.id }}-{{ item.index | plus: 1 }}"{% unless is_gift_wrap_item %} is="cart-remove-item"{% else %} is="gift-wrap-remove-item"{% endunless %} class="btn--link items-center cart-remove-mobile justify-center relative " data-index="{{ item.index | plus: 1 }}" style="width:16px; height: 16px !important; display:none;">
                                      <span>{% render 'icon-remove' %}</span>
                                      {% render 'loading-spinner' %}
                                    </a>
                                <button
                                  type="button"
                                  class="remove-cart-item-modal-btn remove-mobile"
                                  {% comment %} flits support added code from here {% endcomment %}
                                   data-index="{{ item.index | plus: 1 }}"
                                    data-product-id="{{ item.product.id }}"
                                    data-product-handle="{{ item.product.handle }}"
                                    data-product-title="{{ item.product.title | escape }}"
                                    data-product-image="{{ item.image | image_url: width: 300 }}"
                                    data-product-wsl-count="{{ item.product.metafields.Flits.wsl-count }}"
                                  data-index="{{ item.index | plus: 1 }}"
                                  {% comment %} till here {% endcomment %}
                                  >
                                  {% render 'icon-remove' %}
                                </button>
                                  </div>
                                    <div class="cart-item__prices ">
                                    {%- liquid
                                      assign money_price = item.original_price | money
                                      if settings.currency_code_enabled
                                        assign money_price = item.original_price | money_with_currency
                                      endif
                                      assign compare_price = item.variant.compare_at_price
                                      assign original_price = item.variant.price
                                    -%}
                                    {%- if cart_discount_cap_active -%}
                                      {%- liquid
                                        assign price = item.original_price
                                      -%}
                                      <div class="price text-right flex flex-wrap items-center gap-x-2  ">
                                        {{- money_price -}}
                                      </div>
                                    {%- elsif item.original_price != item.final_price -%}
                                      {%- liquid
                                        assign price = item.final_line_price | divided_by: item.quantity
                                      -%}
                                      <div class="price text-right flex flex-wrap items-center gap-x-2  price--on-sale">
                                        <span class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</span>
                                        <span class="price__regular">
                                          {%- liquid 
                                            if settings.currency_code_enabled
                                              echo item.final_price | money_with_currency
                                            else
                                              echo item.final_price | money
                                            endif  
                                          -%}
                                        </span>
                                        <s class="price__sale font-body text-subtext cart-price-sale">{{ money_price }}</s>
                                        <span class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</span>
                                      </div>
                                    {%- else -%}
                                      {%- liquid
                                        assign price = item.final_line_price | divided_by: item.quantity
                                      -%}
                                      <div class="price text-right flex flex-wrap items-center gap-x-2">
                                        {{- money_price -}}
                                      </div>
                                    {%- endif -%}
                                {% if compare_price > original_price %}
                                  <span class="compare-price" style="text-decoration: line-through; font-size:12px; color: #252931; opacity: .8; font-family:'Montserrat';">
                                    {{ compare_price | money }}
                                  </span>

                                  {% assign discount = compare_price | minus: original_price | times: 100 | divided_by: compare_price %}
                                  <span class="cart__discount" style="color: #3DA577; font-size:12px; font-weight: 500; font-family: 'Montserrat';">
                                    ({{ discount | round }}% OFF)
                                  </span>
                                {% endif %}
                                      {%- if item.variant.available and item.unit_price_measurement -%}
                                        <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                                        <span class="unit-price flex items-center font-body text-sm text-subtext">
                                          {%- liquid
                                            capture unit_price_base_unit
                                              if item.variant.unit_price_measurement
                                                if item.variant.unit_price_measurement.reference_value != 1
                                                  echo item.variant.unit_price_measurement.reference_value
                                                endif
                                                echo item.variant.unit_price_measurement.reference_unit
                                              endif
                                            endcapture
                                          -%}
                                          ({{ item.variant.unit_price | money }}
                                          <span aria-hidden="true">/</span>
                                          <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
                                          {{ unit_price_base_unit }})
                                          </span>
                                      {%- endif -%}
                                    </div>
                                  </div>
                                   
                                </div>
                                {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != null -%}
                                  <div class="cart-item__options">
                                
                                 {%- if item.product.has_only_default_variant == false -%}
                                      {% assign current_variant_id = item.variant.id %}

                                      {%- comment -%}
                                        Build a list of variant IDs for the same product that are already
                                        present in the cart (excluding the current line item).
                                      {%- endcomment -%}
                                      {% assign taken_variant_ids = '' %}
                                      {% for ci in cart.items %}
                                        {% if ci.product_id == item.product.id and ci.variant_id != current_variant_id %}
                                          {% assign taken_variant_ids = taken_variant_ids | append: ci.variant_id | append: ',' %}
                                        {% endif %}
                                      {% endfor %}
                                      {% assign taken_ids_array = taken_variant_ids | split: ',' %}

                                      <select name="variant-dropdown" class="variant-selector" data-line="{{ forloop.index }}" data-current-id="{{ current_variant_id }}">
                                        {% assign size_list = 'XS,S,M,L,XL,2XL,3XL,4XL,5XL,XXL,XXXL,XXXXL,XXXXXL,28,30,32,34,36,38,40,42,44,46,48,50,28-30,30-32,32-34,34-36,36-38,38-40,40-42,42-44' | split: ',' %}
                                        {% for variant in item.product.variants %}
                                          {% if variant.available %}
                                            {%- comment -%} skip sizes already chosen on other lines of this same product {%- endcomment -%}
                                            {% assign v_id_str = variant.id | append: '' %}
                                            {% if taken_ids_array contains v_id_str %}
                                              {% continue %}
                                            {% endif %}

                                            {% assign label_parts = variant.title | split: ' / ' %}
                                            {% assign display_label = '' %}
                                            {%- for part in label_parts -%}
                                              {% assign clean_part = part | strip | upcase %}
                                              {% if size_list contains clean_part %}
                                                {% assign display_label = clean_part %}
                                              {% endif %}
                                            {%- endfor -%}

                                            {% if display_label != '' %}
                                              {% case display_label %}
                                                {% when 'XXL' %}{% assign display_label = '2XL' %}
                                                {% when 'XXXL' %}{% assign display_label = '3XL' %}
                                                {% when 'XXXXL' %}{% assign display_label = '4XL' %}
                                                {% when 'XXXXXL' %}{% assign display_label = '5XL' %}
                                              {% endcase %}

                                              {%- comment -%} keep your low-inventory disable logic {%- endcomment -%}
                                              {% assign disable_option = false %}
                                              {% if variant.inventory_quantity == 1 %}
                                                {% for cart_item in cart.items %}
                                                  {% if cart_item.variant_id == variant.id %}
                                                    {% assign disable_option = true %}
                                                  {% endif %}
                                                {% endfor %}
                                              {% endif %}

                                              <option value="{{ variant.id }}"
                                                {% if variant.id == current_variant_id %}selected{% endif %}
                                                {% if disable_option %}disabled{% endif %}>
                                                <span style="color:#4B5563 !important; font-size:11px;">Size:</span>{{ display_label }}
                                              </option>
                                            {% endif %}
                                          {% endif %}
                                        {% endfor %}
                                      </select>
                                    {%- endif -%}



                                    {%- for property in item.properties -%}
                                      {%- assign property_first_char = property.first | slice: 0 -%}
                                      {%- if property.last != blank and property_first_char != '_' -%}
                                        <div class="flex gap-1 text-sm text-subtext">
                                          <dt>{{ property.first }}:&nbsp;</dt>
                                          <dd class="m-0">
                                            {%- if property.last contains '/uploads/' -%}
                                              <a href="{{ property.last }}" class="link" target="_blank" aria-describedby="a11y-new-window-message">
                                                {{- property.last | split: '/' | last -}}
                                              </a>
                                            {%- else -%}
                                              {{- property.last -}}
                                            {%- endif -%}
                                          </dd>
                                        </div>
                                      {%- endif -%}
                                    {%- endfor -%}
                                    {%- if item.selling_plan_allocation != null -%}
                                      <p class="text-sm text-subtext">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                                    {%- endif -%}
                                  <div class="flex items-center gap-3 mobile_qty">
                                    {%- unless is_gift_wrap_item -%}
                                      <quantity-input class="cart-quantity quantity">
                                        <label class="visually-hidden" for="Quantity-{{ section.id }}-{{ item.index | plus: 1 }}"></label>
                                        <button type="button" name="minus" class="quantity__button {% if item.quantity <= 1 %}disabled_minus{% endif %}" aria-label="{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}">
                                          <svg width="16" height="16" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M2.6875 7H12.3125" stroke="#B60013" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                          </svg>
                                        </button>
                                        <input class="quantity__input"
                                          type="number"
                                          name="updates[]"
                                          value="{{ item.quantity }}"
                                          aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                          id="Quantity-{{ section.id }}-{{ item.index | plus: 1 }}"
                                          data-index="{{ item.index | plus: 1 }}"
                                          size="2"
                                          inputmode="numeric"
                                          autocomplete="off"
                                          data-quantity-variant-id="{{ item.variant.id }}"
                                          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                          min="0"
                                          data-min="{{ item.variant.quantity_rule.min }}"
                                          {% if item.variant.quantity_rule.max != null %}
                                            max="{{ item.variant.quantity_rule.max }}"
                                          {% endif %}
                                          step="{{ item.variant.quantity_rule.increment }}"
                                        />
                                        <button type="button" name="plus" class="quantity__button" aria-label="{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}">
                                          <svg width="16" height="16" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M2.6875 7H12.3125" stroke="#B60013" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
