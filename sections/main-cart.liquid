      const cartDiscountElement = cartItemRow.querySelector('.cart__discount');
      
      if (comparePriceElement && cartDiscountElement) {
        const comparePriceText = comparePriceElement.textContent.trim();
        const cartDiscountText = cartDiscountElement.textContent.trim();
        
