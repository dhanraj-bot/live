<script>
  // ===== CENTRALIZED CART DATA MANAGER =====
  // This caches cart data and prevents multiple simultaneous fetches
  (function() {
    'use strict';

    if (window.CartDataManager) {
      return; // Already initialized
    }

    window.CartDataManager = {
      cache: null,
      cacheTimestamp: null,
      cacheDuration: 2000, // Cache for 2 seconds
      pendingFetch: null,
      fetchInProgress: false,
      listeners: new Set(),
      lastFetchTime: 0,
      minFetchInterval: 300, // Minimum 300ms between fetches
      
      // Get cart data with caching
      getCart: async function(forceRefresh = false) {
        const now = Date.now();
        
        // Return cached data if valid
        if (!forceRefresh && this.cache && this.cacheTimestamp && (now - this.cacheTimestamp) < this.cacheDuration) {
          console.log('🎯 Returning cached cart data (age: ' + (now - this.cacheTimestamp) + 'ms)');
          return this.cache;
        }
        
        // Prevent too frequent fetches
        if (!forceRefresh && (now - this.lastFetchTime) < this.minFetchInterval) {
          console.log('⏸️ Fetch throttled, using existing cache');
          return this.cache || this.pendingFetch;
        }
        
        // If fetch is in progress, wait for it
        if (this.pendingFetch) {
          console.log('⏳ Fetch in progress, waiting...');
          return this.pendingFetch;
        }
        
        // Start new fetch
        console.log('🔄 Fetching fresh cart data...');
        this.fetchInProgress = true;
        this.lastFetchTime = now;
        
        this.pendingFetch = fetch('/cart.js')
          .then(response => response.json())
          .then(cartData => {
            this.updateCache(cartData);
            this.fetchInProgress = false;
            this.pendingFetch = null;
            console.log('✅ Cart data fetched and cached');
            return cartData;
          })
          .catch(error => {
            console.error('❌ Error fetching cart:', error);
            this.fetchInProgress = false;
            this.pendingFetch = null;
            throw error;
          });
        
        return this.pendingFetch;
      },
      
      // Update cache with new data
      updateCache: function(cartData) {
        this.cache = cartData;
        this.cacheTimestamp = Date.now();
        this.notifyListeners(cartData);
      },
      
      // Invalidate cache
      invalidateCache: function() {
        console.log('🗑️ Cache invalidated');
        this.cache = null;
        this.cacheTimestamp = null;
      },
      
      // Add listener for cart updates
      addListener: function(callback) {
        this.listeners.add(callback);
      },
      
      // Remove listener
      removeListener: function(callback) {
        this.listeners.delete(callback);
      },
      
      // Notify all listeners
      notifyListeners: function(cartData) {
        this.listeners.forEach(callback => {
          try {
            callback(cartData);
          } catch (error) {
            console.error('Error in cart listener:', error);
          }
        });
      },
      
      // Get cached data synchronously (returns null if not cached)
      getCached: function() {
        const now = Date.now();
        if (this.cache && this.cacheTimestamp && (now - this.cacheTimestamp) < this.cacheDuration) {
          return this.cache;
        }
        return null;
      }
    };
    
    console.log('✅ CartDataManager initialized');
  })();
  
  // ===== CENTRALIZED CART REFRESH MANAGER =====
  // This prevents multiple initializations and manages all cart refresh operations
  if (window.cartRefreshManager) {
    //console.log('Cart refresh manager already exists, skipping initialization...');
  } else {
    window.cartRefreshManager = {
      initialized: false,
      systems: new Set(),
      
      // Register a system
      registerSystem: function(systemName) {
        if (this.systems.has(systemName)) {
          //console.log(`System ${systemName} already registered, skipping...`);
          return false;
        }
        this.systems.add(systemName);
       // console.log(`System ${systemName} registered successfully`);
        return true;
      },
      
      // Initialize the manager
      initialize: function() {
        if (this.initialized) {
        //  console.log('Cart refresh manager already initialized, skipping...');
          return;
        }
        this.initialized = true;
      //  console.log('Cart refresh manager initialized successfully');
      }
    };
    
    // Initialize the manager
    window.cartRefreshManager.initialize();
  }

  // ===== MAIN CART FUNCTIONS =====

  function initVariantSelectors() {
    // Check if already initialized
    if (window.variantSelectorsInitialized) {
     // console.log('Variant selectors already initialized, skipping...');
      return;
    }
    window.variantSelectorsInitialized = true;
  }

  // Function to refresh cart data and update all UI elements
  async function refreshCartData() {
    try {
      // Prevent multiple simultaneous refreshes
      if (window.cartRefreshInProgress) {
        console.log('Cart refresh already in progress, skipping...');
        return null;
      }
      
      window.cartRefreshInProgress = true;
      
      // Use CartDataManager instead of direct fetch
      const cartData = await window.CartDataManager.getCart(true); // Force refresh
      
      console.log('Cart refreshed:', cartData);
      
      updateCartPageState(cartData);
      
      // Handle empty cart state
      if (cartData.item_count === 0) {
        console.log('Cart is empty, showing empty cart state');
        
        // Show empty cart message
        const cartSection = document.querySelector('.cart');
        if (cartSection) {
          cartSection.classList.add('is-empty');
        }
        
        // Hide cart content
        const cartContent = document.querySelector('main-cart');
        if (cartContent) {
          cartContent.style.display = 'none';
        }
        
        // Show empty cart content
        const emptyCartContent = document.querySelector('.cart__empty');
        if (emptyCartContent) {
          emptyCartContent.style.display = 'block';
        }
        
      } else {
        // Show cart content
        const cartSection = document.querySelector('.cart');
        if (cartSection) {
          cartSection.classList.remove('is-empty');
        }
        
        const cartContent = document.querySelector('main-cart');
        if (cartContent) {
          cartContent.style.display = 'flex';
        }
        
        const emptyCartContent = document.querySelector('.cart__empty');
        if (emptyCartContent) {
          emptyCartContent.style.display = 'none';
        }
        
        // Update cart totals and items
        updateCartTotals(cartData);
        updateCartItemsDisplay(cartData);
      }
      
      // Update discount buttons state
      if (typeof updateDiscountButtonsState === 'function') {
        updateDiscountButtonsState(cartData);
      }
      
      console.log('Cart refresh completed, checking discount status...');
      
      // Ensure discount persistence after cart refresh
      if (window.ensureDiscountPersistence) {
        setTimeout(() => {
          window.ensureDiscountPersistence();
        }, 400);
      }
      
      // Also sync discount display UI
      if (window.syncDiscountDisplayOnCartUpdate) {
        setTimeout(() => {
          console.log('Calling syncDiscountDisplayOnCartUpdate after cart refresh');
          window.syncDiscountDisplayOnCartUpdate();
        }, 600);
      }
      
      // Check current discount status first to get the correct state
      if (window.checkCurrentDiscountStatus) {
        setTimeout(() => {
          window.checkCurrentDiscountStatus();
        }, 300);
      }
      
      // Then reinitialize discount system if the function exists
      if (window.reinitializeDiscountSystem) {
        setTimeout(() => {
          window.reinitializeDiscountSystem();
        }, 400);
      }
      
      // Dispatch cart updated event only once
      if (!window.lastCartUpdateTime || (Date.now() - window.lastCartUpdateTime) > 100) {
        window.lastCartUpdateTime = Date.now();
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: cartData } }));
      }
      
      return cartData;
    } catch (error) {
      console.error('Error refreshing cart data:', error);
      return null;
    } finally {
      // Reset the flag after a short delay to allow for rapid successive updates
      setTimeout(() => {
        window.cartRefreshInProgress = false;
      }, 100);
    }
  }

  // Function to update cart count in header
  function updateCartCount(itemCount) {
    const cartCountElements = document.querySelectorAll('.cart-count, .cart-count-badge, [data-cart-count], .cart__count');
    cartCountElements.forEach(element => {
      element.textContent = itemCount;
    });
    
    const shoppingCartTitle = document.querySelector('.shopping-cart-title');
    if (shoppingCartTitle) {
      shoppingCartTitle.textContent = `Shopping Cart (${itemCount})`;
      shoppingCartTitle.style.display = itemCount > 0 ? '' : 'none';
    }

    // Update cart title if it shows item count
    const cartTitle = document.querySelector('.cart__title');
    if (cartTitle && cartTitle.textContent.includes('Items')) {
      cartTitle.textContent = `Shopping Cart (${itemCount} Items)`;
    }
  }

  function updateCartPageState(cartData) {
    if (!cartData) return;

    const itemCount = Number(cartData.item_count) || 0;
    const cartSection = document.querySelector('.cart');
    const cartContent = document.querySelector('main-cart');
    const emptyCartContent = document.querySelector('.cart__empty');

    updateCartCount(itemCount);

    if (cartSection) {
      cartSection.classList.toggle('is-empty', itemCount === 0);
      cartSection.classList.toggle('cart-background', itemCount > 0);
    }

    if (cartContent) {
      cartContent.style.display = itemCount > 0 ? '' : 'none';
    }

    if (emptyCartContent) {
      emptyCartContent.style.display = itemCount === 0 ? '' : 'none';
    }
  }

  // Function to update cart totals
  function updateCartTotals(cartData) {
    const format = (amount) => `₹${(amount / 100).toFixed(0)}`;
    
    // Update cart footer subtotal
    const footerSubtotal = document.querySelector('.cart__footer--subtotal .totals__subtotal-value');
    if (footerSubtotal) {
      footerSubtotal.textContent = format(cartData.items_subtotal_price);
    }
    
    // Update cart footer total
    const footerTotal = document.querySelector('.cart__footer--total .totals__total-value');
    if (footerTotal) {
      footerTotal.textContent = format(cartData.total_price);
    }
    
    // Update any other total elements
    const totalElements = document.querySelectorAll('[data-cart-total], .cart-total, .cart__total');
    totalElements.forEach(element => {
      element.textContent = format(cartData.total_price);
    });

    // Update order summary if it exists
    if (window.updateOrderSummaryFromDiscount) {
      window.updateOrderSummaryFromDiscount(cartData);
    }

    // Also update discount summary if the function exists
    if (window.updateDiscountSummaryFromCart) {
      window.updateDiscountSummaryFromCart(cartData);
    }
    
    // Force update order summary to ensure discount row shows
    if (window.forceUpdateOrderSummary) {
      window.forceUpdateOrderSummary(cartData);
    }
  }

  // Function to update cart items display
  function updateCartItemsDisplay(cartData) {
    // Cart markup can be either a real table (with <tbody>) or a div-based layout (role="table").
    // Support both so coupon/discount refresh updates item prices reliably.
    const cartItemsContainer =
      document.querySelector('cart-items tbody') || document.querySelector('cart-items');
    if (!cartItemsContainer) return;

    const format = (amount) => `₹${(amount / 100).toFixed(0)}`;
    const capped =
      typeof window.shouldCapDiscount === 'function' && window.shouldCapDiscount(cartData);

    // Update each cart item
    cartData.items.forEach((item, index) => {
      const cartItemRow = cartItemsContainer.querySelector(`#CartItem-${index + 1}`);
      if (!cartItemRow) return;

      // Capping: keep Liquid-rendered unit/compare prices — scripts must not repaint line prices.
      if (capped) {
        const quantityInput = cartItemRow.querySelector('input[name="updates[]"]');
        if (quantityInput) {
          quantityInput.value = item.quantity;
        }
        const lineTotalSpans = cartItemRow.querySelectorAll('.cart-item__total span.font-body-bolder');
        lineTotalSpans.forEach((lineTotalSpan) => {
          lineTotalSpan.textContent = format(item.original_line_price);
        });
        cartItemRow.querySelectorAll('[data-item-price], [data-item-total]').forEach((element) => {
          if (element.dataset.itemPrice) {
            element.textContent = format(item.original_price);
          } else if (element.dataset.itemTotal) {
            element.textContent = format(item.original_line_price);
          }
        });
        return;
      }

      // All unit-price blocks in this row (product column + desktop price column)
      const priceElements = cartItemRow.querySelectorAll('.cart-item__prices .price');
      priceElements.forEach((priceElement) => {
        const comparePriceElement = priceElement.querySelector('.compare-price');
        const cartDiscountElement = priceElement.querySelector('.cart__discount');

        priceElement.innerHTML = '';

        const priceRegularSpan = document.createElement('span');
        priceRegularSpan.className = 'price__regular';

        const priceSaleSpan = document.createElement('s');
        priceSaleSpan.className = 'price__sale font-body text-sm text-subtext';

        if (capped) {
          priceElement.classList.remove('price--on-sale');
          priceRegularSpan.textContent = format(item.original_price);
          priceSaleSpan.style.display = 'none';
          priceElement.appendChild(priceRegularSpan);
        } else if (item.original_price !== item.final_price) {
          priceElement.classList.add('price--on-sale');
          priceRegularSpan.textContent = format(item.final_price);
          priceSaleSpan.textContent = format(item.original_price);
          priceSaleSpan.style.display = 'inline';
          priceElement.appendChild(priceRegularSpan);
          priceElement.appendChild(priceSaleSpan);
        } else {
          priceElement.classList.remove('price--on-sale');
          priceRegularSpan.textContent = format(item.original_price);
          priceSaleSpan.style.display = 'none';
          priceElement.appendChild(priceRegularSpan);
        }

        if (comparePriceElement) priceElement.appendChild(comparePriceElement);
        if (cartDiscountElement) priceElement.appendChild(cartDiscountElement);
      });

      // Compare-at / variant promo badge (use original unit price when cap hides cart discount on lines)
      const comparePriceElements = cartItemRow.querySelectorAll('.compare-price');
      const cartDiscountElements = cartItemRow.querySelectorAll('.cart__discount');
      const unitForCompare = capped ? item.original_price : item.final_price;

      comparePriceElements.forEach((comparePriceElement, i) => {
        const cartDiscountElement = cartDiscountElements[i];
        if (!cartDiscountElement) return;

        const existingComparePriceText = comparePriceElement.textContent.trim();
        if (existingComparePriceText && existingComparePriceText !== '') {
          const priceMatch = existingComparePriceText.match(/₹?([\d,.]+)/);
          if (priceMatch) {
            const compareAtPrice = Math.round(parseFloat(priceMatch[1].replace(/,/g, '')) * 100);
            if (compareAtPrice > unitForCompare) {
              comparePriceElement.textContent = format(compareAtPrice);
              comparePriceElement.style.display = 'inline';
              const discountPercentage = Math.round(
                ((compareAtPrice - unitForCompare) / compareAtPrice) * 100
              );
              cartDiscountElement.textContent = `(${discountPercentage}% OFF)`;
              cartDiscountElement.style.display = 'inline';
            } else {
              comparePriceElement.style.display = 'none';
              cartDiscountElement.style.display = 'none';
            }
          } else {
            comparePriceElement.style.display = 'none';
            cartDiscountElement.style.display = 'none';
          }
        } else {
          comparePriceElement.style.display = 'none';
          cartDiscountElement.style.display = 'none';
        }
      });

      const quantityInput = cartItemRow.querySelector('input[name="updates[]"]');
      if (quantityInput) {
        quantityInput.value = item.quantity;
      }

      const lineTotalSpans = cartItemRow.querySelectorAll('.cart-item__total span.font-body-bolder');
      lineTotalSpans.forEach((lineTotalSpan) => {
        lineTotalSpan.textContent = capped
          ? format(item.original_line_price)
          : format(item.final_line_price);
      });

      const allPriceElements = cartItemRow.querySelectorAll(
        '[data-item-price], [data-item-total], [data-item-compare-price]'
      );
      allPriceElements.forEach((element) => {
        const dataType = element.dataset.itemPrice
          ? 'price'
          : element.dataset.itemTotal
            ? 'total'
            : element.dataset.itemComparePrice
              ? 'compare-price'
              : null;

        if (dataType === 'price') {
          element.textContent = capped ? format(item.original_price) : format(item.final_price);
        } else if (dataType === 'total') {
          element.textContent = capped
            ? format(item.original_line_price)
            : format(item.final_line_price);
        }
      });
    });
  }

  // Function to initialize compare prices and cart discounts on page load
  function initializeComparePricesAndDiscounts() {
    const cartItemsContainer =
      document.querySelector('cart-items tbody') || document.querySelector('cart-items');
    if (!cartItemsContainer) return;

