/* Battery outline */
.cart-badge__battery {
  position: relative;
  width: 14px;
  height: 8px;
  border: 1px solid #fff;
  /* border-radius: 4px; */
  display: inline-block;
  box-sizing: border-box;
}

/* Battery terminal */
.cart-badge__battery::after {
  content: "";
  position: absolute;
  right: -4px;
  top: 1px;
  width: 2px;
  height: 4px;
  background: #fff;
  /* border-radius: 1px; */
}

/* Battery fill */
.cart-badge__battery-level {
  position: absolute;
  top: 1px;
  left: 1px;
  height: 4px;
  width: 4px;
  background: #fff;
  /* border-radius: 2px; */
  animation: batteryBlink 1s infinite;
}

/* Blink animation */
@keyframes batteryBlink {
  0% {
    opacity: 1;
  }

  100% {
    opacity: 0;
  }
}


