  // Remove href attributes from cart removal links to prevent fallback navigation
  function removeCartRemovalHrefs() {
    const cartRemoveLinks = document.querySelectorAll('a[is="cart-remove-item"], a[is="gift-wrap-remove-item"], .cart-item__remove');
    
    cartRemoveLinks.forEach(link => {
      // Store original href for debugging but remove it to prevent navigation
      if (link.href && (link.href.includes('url_to_remove') || link.href.includes('/cart/change'))) {
        link.dataset.originalHref = link.href;
        link.removeAttribute('href');
        // Make it look like a button
        link.style.cursor = 'pointer';
        link.style.textDecoration = 'none';
      }
    });
