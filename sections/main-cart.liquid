  // Function to update discount buttons state based on current cart
  function updateDiscountButtonsState(cartData) {
   // console.log('updateDiscountButtonsState called with cart data:', cartData);
    
    const discountButtons = document.querySelectorAll('.apply-discount-button');
   // console.log('Found discount buttons:', discountButtons.length);
    
    discountButtons.forEach(button => {
      const discountCode = button.dataset.discountCode || button.dataset.code;
      if (!discountCode) return;
      
    //  console.log('Checking button for code:', discountCode);
      
      // Check if this discount is currently applied
      const isCurrentlyApplied = isDiscountApplied(discountCode, cartData);
    //  console.log('Is discount applied:', isCurrentlyApplied);
      
      // Update button state
      if (isCurrentlyApplied) {
      //  console.log('Setting button to Remove for code:', discountCode);
        button.textContent = "Remove";
        button.dataset.buttonState = "remove";
      } else {
      //  console.log('Setting button to Apply for code:', discountCode);
        button.textContent = "Apply";
        button.dataset.buttonState = "apply";
      }
      
      // Check if discount is valid for current cart state
      const isValid = isDiscountValidForCart(discountCode, cartData);
      button.disabled = !isValid;
      
      if (!isValid) {
        button.textContent = "Invalid";
        button.style.opacity = "0.5";
      } else {
        button.style.opacity = "1";
      }
    });
  }

  // Function to check if discount is currently applied
  function isDiscountApplied(discountCode, cartData) {
   // console.log('isDiscountApplied called for code:', discountCode, 'with cart data:', cartData);
   // console.log('discount_applications:', cartData.discount_applications);
   // console.log('cart_level_discount_applications:', cartData.cart_level_discount_applications);
   // console.log('total_discount:', cartData.total_discount);
    
    if (cartData.discount_applications && cartData.discount_applications.length > 0) {
      const isApplied = cartData.discount_applications.some(app => 
        app.code === discountCode || app.title.includes(discountCode)
      );
    //  console.log('Found in discount_applications:', isApplied);
      return isApplied;
    }
    
    // Also check cart_level_discount_applications
    if (cartData.cart_level_discount_applications && cartData.cart_level_discount_applications.length > 0) {
      const isApplied = cartData.cart_level_discount_applications.some(app => 
        app.code === discountCode || app.title.includes(discountCode)
      );
   //   console.log('Found in cart_level_discount_applications:', isApplied);
      return isApplied;
    }
    
    // Check if there's any discount at all
    if (cartData.total_discount > 0) {
    //  console.log('Total discount > 0, but no specific applications found');
    }
    
    return false;
  }

  // Function to check if discount is valid for current cart state
  function isDiscountValidForCart(discountCode, cartData) {
    const cartTotal = cartData.total_price / 100;
    const cartQuantity = cartData.item_count;
    
    // Get discount requirements from button data
    const discountButton = document.querySelector(`[data-discount-code="${discountCode}"]`);
    if (!discountButton) return false;
    
    // Check minimum quantity
    const minQuantity = discountButton.dataset.minQuantity;
    if (minQuantity && cartQuantity < parseInt(minQuantity)) {
      return false;
    }
    
    // Check minimum value
    const minValue = discountButton.dataset.minValue;
    if (minValue && cartTotal < parseFloat(minValue)) {
      return false;
    }
    
    return true;
  }

  // Initialize cart refresh system
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setupCartRefreshListeners();
      initVariantSelectors();
      initializeComparePricesAndDiscounts();
      removeCartRemovalHrefs(); // Remove href attributes to prevent page reloads
    });
  } else {
    setupCartRefreshListeners();
    initVariantSelectors();
    initializeComparePricesAndDiscounts();
    removeCartRemovalHrefs(); // Remove href attributes to prevent page reloads
  }

  // Also initialize after cart updates
  document.addEventListener('cart:updated', function(event) {
    // If cart data is passed in event, update cache to prevent redundant fetches
    if (event.detail && event.detail.cart && window.CartDataManager) {
      window.CartDataManager.updateCache(event.detail.cart);
    }

    if (event.detail && event.detail.cart) {
      updateCartPageState(event.detail.cart);
    }
    
    initVariantSelectors();
    initializeComparePricesAndDiscounts();
    removeCartRemovalHrefs(); // Re-apply after dynamic content updates
  });
  
  document.addEventListener('cart:refresh', function(event) {
    // If cart data is passed in event, update cache
    if (event.detail && event.detail.cart && window.CartDataManager) {
      window.CartDataManager.updateCache(event.detail.cart);
    }
    
    initVariantSelectors();
    initializeComparePricesAndDiscounts();
    removeCartRemovalHrefs(); // Re-apply after dynamic content updates
  });

  // Export functions for external use
  window.refreshCartData = refreshCartData;
  window.updateCartCount = updateCartCount;
  window.updateCartTotals = updateCartTotals;
  window.updateCartItemsDisplay = updateCartItemsDisplay;
  window.refreshComparePricesAndDiscounts = refreshComparePricesAndDiscounts;
  window.initializeComparePricesAndDiscounts = initializeComparePricesAndDiscounts;

  window.onload = function() { 
   window.CartDataManager.getCart()
    .then(cartData => {
      const cartTotal = cartData.total_price / 100;
      const cartQuantity = cartData.item_count; 

      if (cartQuantity === 0) { 
        //alert("Cart is empty → removing discount");  
        if (window.removeDiscountCode) {
          window.removeDiscountCode(null, cartData.discount_applications?.[0]?.code || "");
        }
      }
    })
    .catch(err => console.error("Error checking cart on load:", err));
  };

  (function () {
    const mobileMedia = window.matchMedia('(max-width: 768px)');
    let recommendationWrapper = null;
    let originalParent = null;
    let originalNextSibling = null;

    function getRecommendationWrapper() {
      if (recommendationWrapper && recommendationWrapper.isConnected) {
        return recommendationWrapper;
      }

      const recommendationSection = document.querySelector('[data-section-type="cart-discount-recommendations"]');
      if (!recommendationSection) {
        return null;
      }

      recommendationWrapper =
        recommendationSection.closest('.shopify-section') ||
        recommendationSection.closest('[id^="shopify-section-"]') ||
        recommendationSection;

      if (!originalParent) {
        originalParent = recommendationWrapper.parentNode;
        originalNextSibling = recommendationWrapper.nextElementSibling;
      }

      return recommendationWrapper;
    }

    function moveRecommendationsForMobile() {
      const slot = document.querySelector('#MainCart-{{ section.id }} [data-cart-mobile-recommendations-slot]');
      const sectionWrapper = getRecommendationWrapper();

      if (!slot || !sectionWrapper || !originalParent) {
        return;
      }

      if (mobileMedia.matches) {
        if (slot.nextElementSibling !== sectionWrapper) {
          slot.insertAdjacentElement('afterend', sectionWrapper);
        }
        return;
      }

      if (originalNextSibling && originalNextSibling.parentNode === originalParent) {
        originalParent.insertBefore(sectionWrapper, originalNextSibling);
      } else {
        originalParent.appendChild(sectionWrapper);
      }
    }

    function initializeCartRecommendationPlacement() {
      moveRecommendationsForMobile();

      if (mobileMedia.addEventListener) {
        mobileMedia.addEventListener('change', moveRecommendationsForMobile);
      } else if (mobileMedia.addListener) {
        mobileMedia.addListener(moveRecommendationsForMobile);
      }

      document.addEventListener('cart:updated', moveRecommendationsForMobile);
      document.addEventListener('cart:refresh', moveRecommendationsForMobile);
      document.addEventListener('shopify:section:load', moveRecommendationsForMobile);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeCartRecommendationPlacement);
    } else {
      initializeCartRecommendationPlacement();
    }
  })();

  (function () {
    const mobileMedia = window.matchMedia('(max-width: 768px)');
    let checkoutBarObserver = null;
    let orderSummaryObserver = null;
    let fallbackListenerAttached = false;

    function getCheckoutBarElements() {
      const sectionRoot = document.getElementById('shopify-section-{{ section.id }}');
      const checkoutBar = sectionRoot?.querySelector('#MainCart-{{ section.id }} .cart__footer--buttons');
      const orderSummary = sectionRoot?.querySelector('.checkout-button-place');

      return { sectionRoot, checkoutBar, orderSummary };
    }

    function setCheckoutBarMode(shouldBeStatic) {
      const { checkoutBar } = getCheckoutBarElements();
      if (!checkoutBar) return;

      checkoutBar.classList.toggle('is-static', shouldBeStatic);
    }

    function updateCheckoutBarMode() {
      const { checkoutBar, orderSummary } = getCheckoutBarElements();
      if (!checkoutBar) return;

      if (!mobileMedia.matches) {
        setCheckoutBarMode(true);
        syncMobileCheckoutOffset();
        return;
      }

      if (!orderSummary) {
        setCheckoutBarMode(false);
        syncMobileCheckoutOffset();
        return;
      }

      const orderSummaryRect = orderSummary.getBoundingClientRect();
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      const summaryVisible = orderSummaryRect.top < viewportHeight && orderSummaryRect.bottom > 0;

      setCheckoutBarMode(summaryVisible);
      syncMobileCheckoutOffset();
    }

    function syncMobileCheckoutOffset() {
      const { sectionRoot, checkoutBar } = getCheckoutBarElements();

      if (!sectionRoot) return;

      if (!mobileMedia.matches || !checkoutBar) {
        sectionRoot.style.setProperty('--mobile-cart-checkout-offset', '0px');
        return;
      }

      const checkoutOffset = checkoutBar.classList.contains('is-static') ? 0 : checkoutBar.offsetHeight;
      sectionRoot.style.setProperty('--mobile-cart-checkout-offset', `${checkoutOffset}px`);
    }

    function teardownOrderSummaryWatchers() {
      if (orderSummaryObserver) {
        orderSummaryObserver.disconnect();
        orderSummaryObserver = null;
      }

      if (fallbackListenerAttached) {
        window.removeEventListener('scroll', updateCheckoutBarMode);
        fallbackListenerAttached = false;
      }
    }

    function watchOrderSummaryVisibility() {
      const { orderSummary } = getCheckoutBarElements();

      teardownOrderSummaryWatchers();
      updateCheckoutBarMode();

      if (!mobileMedia.matches || !orderSummary) {
        syncMobileCheckoutOffset();
        return;
      }

      if ('IntersectionObserver' in window) {
        orderSummaryObserver = new IntersectionObserver((entries) => {
          const entry = entries[0];
          setCheckoutBarMode(entry.isIntersecting);
          syncMobileCheckoutOffset();
        }, {
          threshold: 0
        });

        orderSummaryObserver.observe(orderSummary);
        return;
      }

      window.addEventListener('scroll', updateCheckoutBarMode, { passive: true });
      fallbackListenerAttached = true;
    }

    function watchMobileCheckoutBar() {
      const { checkoutBar } = getCheckoutBarElements();

      if (checkoutBarObserver) {
        checkoutBarObserver.disconnect();
        checkoutBarObserver = null;
      }

      watchOrderSummaryVisibility();
      syncMobileCheckoutOffset();

      if (!mobileMedia.matches || !checkoutBar || !('ResizeObserver' in window)) {
        return;
      }

      checkoutBarObserver = new ResizeObserver(() => {
        updateCheckoutBarMode();
        syncMobileCheckoutOffset();
      });
      checkoutBarObserver.observe(checkoutBar);
    }

    function initializeMobileCheckoutBar() {
      watchMobileCheckoutBar();

      if (mobileMedia.addEventListener) {
        mobileMedia.addEventListener('change', watchMobileCheckoutBar);
      } else if (mobileMedia.addListener) {
        mobileMedia.addListener(watchMobileCheckoutBar);
      }

      window.addEventListener('resize', syncMobileCheckoutOffset);
      document.addEventListener('cart:updated', watchMobileCheckoutBar);
      document.addEventListener('cart:refresh', watchMobileCheckoutBar);
      document.addEventListener('shopify:section:load', watchMobileCheckoutBar);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeMobileCheckoutBar);
    } else {
      initializeMobileCheckoutBar();
    }
  })();
