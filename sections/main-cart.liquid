  // Show quantity error near the input (e.g. when exceeding available stock)
  function showQuantityError(input, message) {
    // Intentionally left almost empty: we silently revert quantity without showing UI errors,
    // to avoid breaking the cart layout when Shopify returns soft errors alongside valid updates.
    if (!input) return;
    input.setCustomValidity('');
  }

  function clearQuantityError(input) {
    if (!input) return;
    input.setCustomValidity('');
    const row = input.closest('div, .cart-item');
    if (row) {
      const errEl = row.querySelector('.cart-quantity-error');
      if (errEl) errEl.style.display = 'none';
    }
  }

  // Set up cart refresh event listeners
  function setupCartRefreshListeners() {
    // Check if already initialized
    if (window.cartRefreshListenersInitialized) {
    //  console.log('Cart refresh listeners already initialized, skipping...');
      return;
    }
    window.cartRefreshListenersInitialized = true;
    
    // Debounce timer for quantity changes
    let quantityChangeTimeout = null;
    
    // Listen for quantity changes with debouncing
    document.addEventListener('change', function(event) {
      if (event.target.matches('input[name="updates[]"]')) {
        const input = event.target;
        const quantity = parseInt(input.value);
        
        if (!isNaN(quantity) && quantity >= 0) {
          // Clear any previous quantity error
          clearQuantityError(input);
          // Clear any pending quantity change
          if (quantityChangeTimeout) {
            clearTimeout(quantityChangeTimeout);
          }
          
          // Show loading state
          input.disabled = true;
          const originalValue = input.value;
          
          // Get the variant ID from the input
          const variantId = input.dataset.quantityVariantId;
          
          // Debounce to prevent multiple rapid changes
          quantityChangeTimeout = setTimeout(() => {
            // Update cart via Shopify API
            fetch('/cart/change.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                id: variantId,
                quantity: quantity
              })
            })
            .then(response => response.json().then(data => ({ ok: response.ok, data })))
            .then(({ ok, data: cartData }) => {
              // Do not update UI with error response (e.g. 422 - quantity not available)
              if (!ok) {
                input.value = originalValue;
                input.disabled = false;
                const errorMessage = cartData.message || cartData.description || 'Requested quantity not available.';
                showQuantityError(input, errorMessage);
                return;
              }
              
              // CRITICAL: Invalidate cache and update it with fresh data
              if (window.CartDataManager) {
                window.CartDataManager.cache = cartData;
                window.CartDataManager.cacheTimestamp = Date.now();
              }
              
              // Update UI with the data we already have (no additional fetch needed)
              updateCartPageState(cartData);
              updateCartTotals(cartData);
              updateCartItemsDisplay(cartData);
              
              // Re-enable input
              input.disabled = false;
              clearQuantityError(input);
              
              // Check if discount is still valid after quantity change
              checkDiscountValidity(cartData);
              
              // Update discount buttons state
              updateDiscountButtonsState(cartData);
              
              // Sync discount display UI after quantity change (uses cached data)
              if (window.forceUpdateAllDiscountElements) {
                setTimeout(() => {
                  console.log('Force updating all discount elements after quantity change');
                  window.forceUpdateAllDiscountElements();
                }, 300);
              } else if (window.syncDiscountDisplayOnCartUpdate) {
                setTimeout(() => {
                  console.log('Calling syncDiscountDisplayOnCartUpdate after quantity change');
                  window.syncDiscountDisplayOnCartUpdate();
                }, 200);
              }
              
              // Dispatch single cart updated event with data
              document.dispatchEvent(new CustomEvent('cart:updated', { 
                detail: { cart: cartData } 
              }));
            })
            .catch(error => {
              // Revert to original value on error
              input.value = originalValue;
              input.disabled = false;
              showQuantityError(input, 'Unable to update quantity. Please try again.');
            });
          }, 300); // 300ms debounce
        }
      }
    });

    // ============================================================
    // REMOVE ITEM MODAL — OPEN & CLOSE HANDLING
    // ============================================================

    (function () {
      const overlay = document.getElementById('removeItemOverlay');
      const modal = document.getElementById('removeItemModal');
      const imgEl = document.getElementById('removeItemImage');
      const flitsWishlistBtn = document.getElementById('flitsWishlistBtn');
      const removeConfirmButton = document.getElementById('removeItemConfirm');
      const removeWishlistButton = document.getElementById('removeItemWishlist');
      let removeLoaderTimeout = null;

      if (!overlay || !modal) return;

      const setRemoveModalLoading = function (isLoading) {
        overlay.classList.toggle('is-loading', isLoading);
        removeConfirmButton?.toggleAttribute('disabled', isLoading);
        removeWishlistButton?.toggleAttribute('disabled', isLoading);
      };

      const closeRemoveModal = function () {
        overlay.classList.remove('open');
        overlay.dataset.pendingLine = '';
        overlay.dataset.pendingVariant = '';
        if (removeLoaderTimeout) {
          window.clearTimeout(removeLoaderTimeout);
          removeLoaderTimeout = null;
        }
        setRemoveModalLoading(false);
      };

      // ----------------------------
      // OPEN MODAL
      // ----------------------------
      document.addEventListener('click', function (event) {
        const btn = event.target.closest('.remove-cart-item-modal-btn');
        if (!btn) return;

        event.preventDefault();
        event.stopPropagation();

        const cartItem = btn.closest('[id^="CartItem-"], .cart-item');

        let itemImage = '';
        let variantId = null;
        let line = null;

        if (cartItem) {
          line = btn.dataset.index || cartItem.dataset.index || cartItem.getAttribute('data-index');

          const img = cartItem.querySelector('.cart-item__media img, img');
          if (img) itemImage = img.src || img.dataset.src || '';

          const qtyInput = cartItem.querySelector('input[data-quantity-variant-id]');
          if (qtyInput) variantId = qtyInput.dataset.quantityVariantId;
        }

        if (!itemImage) {
          itemImage = btn.dataset.productImage || '';
        }

        // store data for confirm step
        overlay.dataset.pendingLine = line || '';
        overlay.dataset.pendingVariant = variantId || '';

        // handle image safely
        if (imgEl) {
          if (itemImage) {
            imgEl.src = itemImage;
            imgEl.style.display = 'block';
          } else {
            imgEl.removeAttribute('src');
            imgEl.style.display = 'none';
          }
        }

        if (flitsWishlistBtn) {
          flitsWishlistBtn.setAttribute('data-flits-product-id', btn.dataset.productId || '');
          flitsWishlistBtn.setAttribute('data-flits-product-handle', btn.dataset.productHandle || '');
          flitsWishlistBtn.setAttribute('data-flits-product-title', btn.dataset.productTitle || '');
          flitsWishlistBtn.setAttribute('data-flits-product-image', itemImage || '');
          flitsWishlistBtn.setAttribute('data-flits-product-wsl-count', btn.dataset.productWslCount || 0);
        }

        setRemoveModalLoading(false);
        overlay.classList.add('open');

        window.setTimeout(function () {
          if (window.Flits?.reloadWidgets) {
            window.Flits.reloadWidgets();
          }
          if (window.flitsApp?.init) {
            window.flitsApp.init();
          }
        }, 500);

        // focus for accessibility
        removeConfirmButton?.focus();
      });

      // ----------------------------
      // CLOSE ON OVERLAY CLICK
      // ----------------------------
      document.addEventListener('click', function (event) {
        if (!overlay.classList.contains('open') || overlay.classList.contains('is-loading')) return;

        if (event.target === overlay) {
          closeRemoveModal();
        }
      });

      // ----------------------------
      // CLOSE ON CROSS BUTTON
      // ----------------------------
      document.getElementById('removeItemClose')?.addEventListener('click', function () {
        if (overlay.classList.contains('is-loading')) return;
        closeRemoveModal();
      });

      removeConfirmButton?.addEventListener('click', function () {
        if (overlay.classList.contains('is-loading')) return;

        const pendingLine = overlay.dataset.pendingLine;
        if (!pendingLine) return;

        const cartItems = document.querySelector('cart-items');
        if (!cartItems || typeof cartItems.updateQuantity !== 'function') {
          closeRemoveModal();
          return;
        }

        setRemoveModalLoading(true);
        overlay.classList.add('open');
        removeLoaderTimeout = window.setTimeout(function () {
          closeRemoveModal();
        }, 10000);
        cartItems.updateQuantity(pendingLine, 0);
      });

      removeWishlistButton?.addEventListener('click', function () {
        const pendingLine = overlay.dataset.pendingLine;
        const cartItem =
          document.getElementById(`CartItem-${pendingLine}`) ||
          document.querySelector(`.cart-item[data-index="${pendingLine}"]`);
        const wishlistTrigger = cartItem?.querySelector(
          '.wkh-save-for-later, .guest-wishlist-login-btn, .flits-collection-page-wishlist-button'
        );

        closeRemoveModal();

        if (wishlistTrigger) {
          wishlistTrigger.click();
        }
      });

      // ----------------------------
      // CLOSE ON ESC KEY
      // ----------------------------
      document.addEventListener('keydown', function (event) {
        if (overlay.classList.contains('is-loading')) return;
        if (event.key === 'Escape') {
          closeRemoveModal();
        }
      });

      document.addEventListener('cart:updated', function () {
        if (overlay.classList.contains('is-loading')) {
          closeRemoveModal();
        }
      });

    })();

    document.addEventListener('click', function(event) {
      // Look for remove buttons with comprehensive selectors
      const removeButton = event.target.closest('[is="cart-remove-item"], [is="gift-wrap-remove-item"], .cart-item__remove, a[href*="url_to_remove"], a[href*="/cart/change"]');

      if (removeButton) {
        if (removeButton.matches('[is="cart-remove-item"], [is="gift-wrap-remove-item"]')) {
          return;
        }

        // CRITICAL: Prevent default browser behavior immediately
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();
        
        console.log('Remove button clicked, prevented default behavior');
        
        const line = removeButton.dataset.index;
        if (!line) {
          console.error('No line index found for removal');
          return;
        }
        
        // Show loading state
        removeButton.style.opacity = '0.5';
        removeButton.style.pointerEvents = 'none';
        
        // Get variant ID if available for more reliable removal
        const cartItem = removeButton.closest('div[id^="CartItem-"], .cart-item');
        let variantId = null;
        
        if (cartItem) {
          const quantityInput = cartItem.querySelector('input[data-quantity-variant-id]');
          if (quantityInput) {
            variantId = quantityInput.dataset.quantityVariantId;
          }
        }
        
        // MoEngage tracking - Fire before removal with dynamic data
        if (cartItem && typeof Moengage !== 'undefined') {
          // Fetch current cart data to get accurate values using CartDataManager
          window.CartDataManager.getCart()
          .then(cartData => {
            // Find the cart item data by variant ID or line index
            let cartItemData = null;
            
            // Method 1: Find by variant ID
            if (variantId) {
              cartItemData = cartData.items.find(item => item.variant_id == variantId);
            }
            
            // Method 2: Find by line index (line is 1-based, array is 0-based)
            if (!cartItemData && line) {
              cartItemData = cartData.items[parseInt(line) - 1];
            }
            
            // Method 3: Find by DOM index as fallback
            if (!cartItemData) {
              const cartItemIndex = Array.from(cartItem.parentElement.children).indexOf(cartItem);
              cartItemData = cartData.items[cartItemIndex];
            }
            
            if (cartItemData) {
              // Parse variant title for color and size
              let color = 'N/A';
              let size = 'N/A';
              if (cartItemData.variant_title) {
                const variantParts = cartItemData.variant_title.split('/').map(part => part.trim());
                if (variantParts.length >= 2) {
                  color = variantParts[0];
                  size = variantParts[1];
                } else if (variantParts.length === 1) {
                  size = variantParts[0];
                }
              }
              
              // Fire MoEngage event with accurate cart data
              Moengage.track_event("Removed From Cart", {
                "Product ID": cartItemData.sku || cartItemData.id,
                "Product Name": cartItemData.product_title || cartItemData.title,
                "Category Name": cartItemData.product_type || 'N/A',
                //"Category ID": cartItemData.product_type.id || 'N/A',
                "Quantity": cartItemData.quantity,
                "Price": (cartItemData.final_price / 100).toFixed(2),
                //"Discount": (cartItemData.final_price / 100).toFixed(2),
                "Currency": cartData.currency || 'USD',
                "Color": color,
                "Size": size,
                "Image": cartItemData.featured_image?.url || cartItemData.image || 'N/A'
              });
              
              console.log('MoEngage event fired with dynamic data: Removed From Cart', cartItemData);
            } else {
              console.warn('Could not find cart item data for MoEngage tracking');
            }
          })
          .catch(error => {
            console.error('Error fetching cart data for MoEngage:', error);
          });
        }
        
        // Use variant ID if available, otherwise use line number
        const removePayload = variantId ? 
          { id: variantId, quantity: 0 } : 
          { line: parseInt(line), quantity: 0 };
        
        //console.log('Removing item with payload:', removePayload);
        
        // Remove item via Shopify API
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(removePayload)
        })
        .then(response => {
          if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
          }
          return response.json();
        })
        .then(cartData => {
          console.log('Item removed successfully:', cartData);
          
          // Refresh cart data without page reload
          refreshCartData();
          
          // Check if discount is still valid after removal
          checkDiscountValidity(cartData);
          
          // Update discount buttons state
          updateDiscountButtonsState(cartData);
          
          // Sync discount display UI after item removal
          if (window.syncDiscountDisplayOnCartUpdate) {
            setTimeout(() => {
             // console.log('Calling syncDiscountDisplayOnCartUpdate after item removal');
              window.syncDiscountDisplayOnCartUpdate();
            }, 800);
          }
          
        })
        .catch(error => {
          //console.error('Error removing item:', error);
          
          // Restore button state on error
          removeButton.style.opacity = '1';
          removeButton.style.pointerEvents = 'auto';
          
          // Show user-friendly error message
          //alert('There was an error removing the item. Please try again.');
        });
      }
    });

    // Listen for cart form submissions
    const cartForm = document.querySelector('#cart');
    if (cartForm) {
      cartForm.addEventListener('submit', function(event) {
        var isCheckout = event.submitter && (event.submitter.name === 'checkout' || event.submitter.id === 'cart-checkout-btn');
        if (isCheckout) {
          event.preventDefault();
          var checkoutUrl = (event.submitter && event.submitter.getAttribute('data-checkout-url')) || '/checkout';
          var fetchCart = window.CartDataManager && typeof window.CartDataManager.getCart === 'function'
            ? window.CartDataManager.getCart()
            : fetch('/cart.js').then(function(r) { return r.json(); });
          fetchCart.then(function(cartData) {
            if (cartData && cartData.item_count > 0) {
              var currency = cartData.currency || 'INR';
              var value = parseFloat((cartData.total_price / 100).toFixed(2));
              if (typeof Moengage !== 'undefined') {
                var moengageProducts = (cartData.items || []).map(function(item) {
                  return {
                    productId: item.product_id,
                    variantId: item.variant_id,
                    itemTitle: item.product_title || item.title,
                    variantTitle: item.variant_title || '',
                    quantity: item.quantity,
                    price: (item.final_price / 100).toFixed(2),
                    currency: currency
                  };
                });
                {% comment %} Moengage.track_event('Started_Checkout', {
                  'No. Of Products': cartData.item_count,
                  'Total Amount': value,
                  'Currency': currency,
                  'Product Details': moengageProducts
                }); {% endcomment %}
              }
            }
           // alert('Events fired: MoEngage Checkout Started');
            setTimeout(function() { window.location.href = checkoutUrl; }, 150);
          }).catch(function() {
            window.location.href = checkoutUrl;
          });
          return;
        }

        event.preventDefault();
        
        // Handle form submission and refresh cart (only for "Update" button, not checkout)
        const formData = new FormData(cartForm);
        fetch('/cart/update.js', {
