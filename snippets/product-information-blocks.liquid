                          <div class="specs-item specs-item-right">
                            <div>{{ item | split: ':' | first }}</div>
                            <div>
                              <strong>{{ item | split: ':' | last | strip }}</strong>
                            </div>
                          </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                {% else %}
                  {{ block.settings.content }}
                  {{ block.settings.custom_liquid }}
                  {{ block.settings.page.content }}
                {% endif %}
              </div>
