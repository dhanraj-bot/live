                  <div class="product-info-icon-container">
                    {% render 'icons', icon: block.settings.icon, size: 'large' %}
                  </div>
                  <div class="accordion-details__summary_title_sub collapsible-tab-heading">
                    <h2 class="h4 inline-richtext">
                      {{ block.settings.heading | default: block.settings.page.title | escape }}
                    </h2>
                    <p class="accordion-details__summary_title_sub_text">
                      {{ block.settings.subheading }}
                    </p>
                  </div>
