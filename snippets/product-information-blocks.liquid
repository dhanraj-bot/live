{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign product_info_block_spacing = section.settings.product_info_block_spacing | default: 24
  assign product_info_separator_spacing = section.settings.product_info_separator_spacing | default: 24
  assign product_info_block_spacing_mobile = section.settings.product_info_block_spacing_mobile | default: 24
  assign product_info_separator_spacing_mobile = section.settings.product_info_separator_spacing_mobile | default: 24
-%}

<style>
    #ProductInfo-{{ section.id }} .product__blocks > *:empty {
      display: none;
    }
    #ProductInfo-{{ section.id }} .product__block--custom_liquid:has(.zipcode_product_page:empty) {
      display: none;
    }
    #ProductInfo-{{ section.id }} .product__blocks {
      display: flex;
      flex-direction: column;
      gap: var(--product-info-block-spacing, 24px);
    }

    .pdp-price-sep {
      margin-block: var(--product-info-separator-spacing, 4px);
    }

    @media (max-width: 768px) {
      #ProductInfo-{{ section.id }} .product__blocks {
        gap: var(--product-info-block-spacing-mobile, 24px);
      }

      .pdp-price-sep {
        margin-block: var(--product-info-separator-spacing-mobile, 4px);
      }
    }
    .product-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

  .product-badge {
    display: inline-flex;
    align-items: center;
    justify-content: start;
    font-size: 12px;
    font-weight: 600;
    font-family: 'Montserrat',sans-serif;
    letter-spacing: 1.2px;
    line-height: 16px;


    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  /* .product-badge:hover {
    transform: translateY(-2px);

    box-shadow:
      0 8px 18px rgba(0,0,0,0.18),
      inset 0 1px 0 rgba(255,255,255,0.1);
  } */
  .product-badge--rich-text :is(p, ul, ol) {
    margin: 0;
  }
  .product-badge.gold {
    background: linear-gradient(
      135deg,
      #6b4d0f 0%,
      #c89b3c 35%,
      #f4d27a 50%,
      #b8862b 75%,
      #5a3f0c 100%
    );

    color: #1a1a1a;
    border: 1px solid rgba(255, 223, 140, 0.35);
  }
  .product-badge.brown {
    background: linear-gradient(
      135deg,
      #2b1d16 0%,
      #5a3b2e 30%,
      #8b5e3c 60%,
      #c08a5b 100%
    );

    color: #fff;
    font-family: 'Montserrat',sans-serif;
  }
  .product-badge.green {
    background: linear-gradient(
      135deg,
      #06281f 0%,
      #0f5132 35%,
      #198754 70%,
      #57c785 100%
    );

    color: #ffffff;
    border: 1px solid rgba(124,255,196,0.18);
  }
  .product-badge.olive {
    background: linear-gradient(
      135deg,
      #2d321f 0%,
      #4b5320 40%,
      #6b7a2f 70%,
      #8a9a46 100%
    );

    color: #f8f6ef;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .product-badge.black-gold {
    background: linear-gradient(
      135deg,
      #0f0f0f 0%,
      #1b1b1b 45%,
      #3a2c12 100%
    );

    color: #f3d27a;
    border: 1px solid rgba(243,210,122,0.22);
  }
  .product-badge.forest {
    background: linear-gradient(
      135deg,
      #0b1d13 0%,
      #163624 40%,
      #285c42 75%,
      #4d8b68 100%
    );

    color: #f5fff8;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .pdp-rating-wrapper{
    max-height: 20px;
  }
  @media(max-width: 768px){
    .pdp-rating-wrapper{
      display: none;
    }
  }
</style>

<div
  id="ProductInfo-{{ section.id }}"
  data-section="{{ section.id }}"
  data-url="{{ product.url }}"
  class="product__info-container{% if enable_sticky_info %} sticky-element{% endif %}"
  style="
    --product-info-block-spacing: {{ product_info_block_spacing }}px;
    --product-info-separator-spacing: {{ product_info_separator_spacing }}px;
    --product-info-block-spacing-mobile: {{ product_info_block_spacing_mobile }}px;
    --product-info-separator-spacing-mobile: {{ product_info_separator_spacing_mobile }}px;
  "
>
  <div class="product__blocks accordion-parent">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          <div class="product__block product__block--{{ block.type }}">
            {% render block %}
          </div>
        {%- when 'text' -%}
          <div
            class="product__block rte product__block--{{ block.type }} {{ block.settings.customClass }}"
            {{ block.shopify_attributes }}
          >
            <h2 class="product__text inline-richtext m-0{% if block.settings.text_style == 'uppercase' %} text-upper{% elsif block.settings.text_style == 'subtitle' %} text-upper text-subtext{% endif %}">
              {{- block.settings.text -}}
            </h2>
          </div>
        {%- when 'title' -%}
          <div
            class="product__block product__block--{{ block.type }}"
            {{ block.shopify_attributes }}
          >
            <div class="product__title_with_badge">
              <h1 class="product__title_pdp {{ block.settings.heading_size }}">{{ product.title | escape }}</h1>
              <div class="product__block_share flex items-center sku_with_title">
                <script src="{{ 'product-share.js' | asset_url }}" defer="defer"></script>
                {%- liquid
                  assign share_modal_id = 'PopupModal-Sharing-' | append: section.id
                  assign share_url = product.selected_or_first_available_variant.url | default: product.url | prepend: request.origin
                -%}
                <button
                  class="btn btn--with-icon btn--plain share-icon"
                  aria-controls="{{ share_modal_id }}"
                  aria-haspopup="dialog"
                >
                  {% render 'share-icon-button' %}
                </button>
                <basic-modal id="{{ share_modal_id }}" class="drawer modal share_popup_modal">
                  <div class="fixed-overlay" aria-controls="{{ share_modal_id }}"></div>
                  <div class="drawer__inner">
                    <button
                      class="drawer__close-btn"
                      aria-controls="{{ share_modal_id }}"
                      aria-label="{{ 'accessibility.close' | t }}"
                    >
                      {% render 'icon-close' %}
                    </button>
                    <div class="drawer__body v-scrollable h-full">
                      <div class="product__sharing">
                        <h3 class="product__sharing--title h5">{{ 'products.product.share' | t }}</h3>
                        <product-share class="product__sharing--inputs" id="ProductShare-{{ section.id }}">
                          <label for="ProductShare-{{ section.id }}" class="visually-hidden">
                            {{- 'products.product.share_label' | t -}}
                          </label>
                          <input
                            id="ProductShare-{{ section.id }}"
                            type="text"
                            class="form-control"
                            value="{{ share_url }}"
                            readonly
                          >
                          <button class="btn btn-copy" data-copied-text="{{ 'general.share.copied' | t }}">
                            {{ 'general.share.copy' | t }}
                          </button>
                        </product-share>
                        {% render 'social-sharing',
                          url: product.url,
                          share_image: product.featured_media.preview_image
                        %}
                      </div>
                    </div>
                  </div>
                </basic-modal>
              </div>
            </div>
            <a href="{{ product.url }}" class="product__title">
              <h2 class="h1">
                {{ product.title | escape }}
              </h2>
            </a>
          </div>
          {% if product.metafields.loox.avg_rating %}
            <div class="pdp-rating-wrapper">
              <div class="loox-custom-rating-pdp product_top_starrating">
                <svg
                  class="loox-icon"
                  viewBox="0 0 24 24"
                  data-lx-fill="full"
                  style="color: #E7B854"
                  role="presentation"
                >
                  <use href="#looxicons-rating-icon"></use>
                </svg>
                <span class="rating">{{ product.metafields.loox.avg_rating }}</span>
                <span class="reviews-text"
                  ><span class="reviews-separator">|</span> {{ product.metafields.loox.num_reviews }} Reviews</span
                >
              </div>
            </div>
          {% endif %}
        {%- when 'product_badge' -%}
          {% assign badge = product.metafields.custom.product_badges %}
          {% if badge %}
            <div
              class="product__block product__block--{{ block.type }}"
              {{ block.shopify_attributes }}
            >
              <div class="product-badges">
                <div class="product-badge product-badge--rich-text">
                  {{ badge | metafield_tag }}
                </div>
              </div>
            </div>
          {% endif %}
        {%- when 'seprator' -%}
          <div class="product__block product__block--{{ block.type }}">
            <div class="seprator "><hr class="pdp-price-sep"></div>
          </div>
        {%- when 'price' -%}
          <div
            class="product__block product__block--{{ block.type }} "
            {{ block.shopify_attributes }}
          >
            <div id="price-{{ section.id }}" role="status" class="price_timer_align ">
              <div class="flex items-center justify-between gap-3 price-rating-container">
                {%- render 'price',
                  product: product,
                  use_variant: true,
                  show_sale_badge: false,
                  price_class: 'f-price--pdp'
                -%}
                {% comment %}
                  {% if product.metafields.loox.avg_rating %}
                    <div class="loox-custom-rating-pdp product_top_starrating">
                      <svg
                        class="loox-icon"
                        viewBox="0 0 24 24"
                        data-lx-fill="full"
                        style="color: #E7B854"
                        role="presentation"
                      >
                        <use href="#looxicons-rating-icon"></use>
                      </svg>
                      <span class="rating">{{ product.metafields.loox.avg_rating }}</span>
                      <span class="reviews-text"
                        ><span class="reviews-separator">|</span> {{ product.metafields.loox.num_reviews }} Reviews</span
                      >
                    </div>
                  {% endif %}
                {% endcomment %}
              </div>
              {%- if product.quantity_price_breaks_configured? -%}
                <div class="volume-pricing-note" id="VolumeNote-{{ section.id }}">
                  <span class="text-sm text-subtext">{{ 'products.product.volume_pricing.note' | t }}</span>
                </div>
              {%- endif -%}
              {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
              {%- form 'product', product, id: product_form_installment_id, class: 'installment' -%}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                {{ form | payment_terms }}
              {%- endform -%}
              <div class="rte product__block--text tax_text_data desktop_tax_text_data">
                <p class="product__text inline-richtext ">Tax included.</p>
              </div>
              {% if show_sale_timer %}
                <div class="product_timer_data countdown__wrapper">
                  <span>{{ saletext }}</span>
                  {% render 'countdown-timer',
                    id: section.id,
                    type: type,
                    duration: duration,
                    time: time,
                    style: style,
                    number_size: number_size,
                    motion_delay: motion_delay,
                    show_days: true,
                    custom_class: 'block col_countdowntimer'
                  %}
                </div>
              {% endif %}
            </div>
          </div>
        {%- when 'inventory' -%}
          <div
            class="product__block product__block--{{ block.type }}{% if block.settings.text_style == 'uppercase' %} text-upper{% elsif block.settings.text_style == 'subtitle' %} text-upper text-subtext{% endif %}{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} hidden{% endif %}"
            {{ block.shopify_attributes }}
            id="Inventory-{{ section.id }}"
            role="status"
          >
            {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
              {%- liquid
                assign inventory_quantity = product.selected_or_first_available_variant.inventory_quantity

                if inventory_quantity > 0
                  if inventory_quantity <= block.settings.inventory_threshold
                    assign inventory_status = 'low-stock'
                    if block.settings.show_inventory_quantity
                      if inventory_quantity == 1
                        assign inventory_message = 'products.product.inventory_low_stock_one_item_html' | t: quantity: inventory_quantity
                      else
                        assign inventory_message = 'products.product.inventory_low_stock_many_items_html' | t: quantity: inventory_quantity
                      endif
                    else
                      assign inventory_message = 'products.product.inventory_low_stock' | t
                    endif
                  else
                    assign inventory_status = 'in-stock'
                    if block.settings.show_inventory_quantity
                      assign inventory_message = 'products.product.inventory_in_stock_show_count_html' | t: quantity: inventory_quantity
                    else
                      assign inventory_message = 'products.product.inventory_in_stock' | t
                    endif
                  endif
                else
                  if product.selected_or_first_available_variant.inventory_policy == 'continue'
                    assign inventory_status = 'in-stock'
                    assign inventory_message = 'products.product.inventory_out_of_stock_continue_selling' | t
                  else
                    assign inventory_status = 'out-of-stock'
                    assign inventory_message = 'products.product.inventory_out_of_stock' | t
                  endif
                endif
              %}
              <p class="product__inventory product__inventory--{{ inventory_status }}">
                <span class="product__inventory-icon"></span>
                <span class="product__inventory-text">{{- inventory_message -}}</span>
              </p>
              {% comment %}
                {%- if inventory_status == 'low-stock' and inventory_quantity < block.settings.inventory_threshold -%}
                  <progress-bar
                    class="product__inventory-stock-bar progress-bar"
                    data-value="{{ inventory_quantity }}"
                    data-max="{{ block.settings.inventory_threshold }}"
                  ></progress-bar>
                {%- endif -%}
              {% endcomment %}
            {%- endif -%}
          </div>
        {%- when 'description' -%}
          {%- if product.description != blank -%}
            <div
              class="product__block product__block--{{ block.type }} rte"
              {{ block.shopify_attributes }}
            >
              {{ product.description }}
            </div>
          {%- endif -%}
        {%- when 'size_chart' -%}
          <div class="product__block product__block--{{ block.type }}" {{ block.shopify_attributes }}>
            {% render 'size-chart', block: block %}
          </div>

        {%- when 'spec_collapsible_tab' -%}
          <div
            class="product__block product__block--{{ block.type }} "
            {{ block.shopify_attributes }}
          >
            <div class="specification-details">
              <div class="specification-details__summary flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <h2 class="h4 inline-richtext">
                    {{ block.settings.heading | default: block.settings.page.title | escape }}
                  </h2>
                </div>
              </div>
              <div class="specification-details__content rte">
                <style>
                  .product__block.product__block--collapsible_tab,
                  .product__block.product__block--retuns_refund_tab {
                    {% comment %} margin-top: calc(var(--product-blocks-gap) * -1); {% endcomment %}
                  }
                  .product__block .accordion-details__summary {
                    padding-bottom: 10px;
                  }
                </style>
                <div class="product-specifications ">
                  <div class="spec-column">
                    <div class="MoreDetailsSection_specificationRoot__H4vEW">
                      {% if product.metafields.magento.fit %}
                        <div class="MoreDetailsSection_specificationContainer__UarA0">
                          <h6>Fit</h6>
                          <p>{{ product.metafields.magento.fit }}</p>
                        </div>
                      {% endif %}
                      {% if product.metafields.magento.collar %}
                        <div class="MoreDetailsSection_specificationContainer__UarA0">
                          <h6>Collar</h6>
                          <p>{{ product.metafields.magento.collar }}</p>
                        </div>
                      {% endif %}
                      {% if product.metafields.magento.occasion %}
                        <div class="MoreDetailsSection_specificationContainer__UarA0">
                          <h6>Occasion</h6>
                          <p>{{ product.metafields.magento.occasion }}</p>
                        </div>
                      {% endif %}
                      {% assign printed_sleeves = '' %}
                      {% for variant in product.variants %}
                        {% assign sleeves_value = variant.metafields.magento.sleeves %}
                        {% if sleeves_value and printed_sleeves contains sleeves_value %}
                          <!-- {# do nothing - already printed #} -->
                        {% elsif sleeves_value %}
                          <div class="MoreDetailsSection_specificationContainer__UarA0">
                            <h6>Sleeves</h6>
                            <p>{{ sleeves_value }}</p>
                          </div>
                          {% assign printed_sleeves = printed_sleeves | append: sleeves_value | append: ',' %}
                        {% endif %}
                      {% endfor %}
                      {% if product.metafields.magento.neck %}
                        <div class="MoreDetailsSection_specificationContainer__UarA0">
                          <h6>Neck</h6>
                          <p>{{ product.metafields.magento.neck }}</p>
                        </div>
                      {% endif %}

                      {% if product.metafields.magento.fabric %}
                        <div class="MoreDetailsSection_specificationContainer__UarA0">
                          <h6>Fabric</h6>
                          <p>{{ product.metafields.magento.fabric }}</p>
                        </div>
                      {% endif %}
                      {% if product.metafields.magento.pattern_coverage %}
                        <div class="MoreDetailsSection_specificationContainer__UarA0">
                          <h6>Pattern Coverage</h6>
                          <p>{{ product.metafields.magento.pattern_coverage }}</p>
                        </div>
                      {% endif %}
                      {% if product.metafields.magento.stretch %}
                        <div class="MoreDetailsSection_specificationContainer__UarA0">
                          <h6>Stretch</h6>
                          <p>{{ product.metafields.magento.stretch }}</p>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {%- when 'information_note' -%}
          {% if block.settings.notecontent != blank %}
            <div
              class="cstm_variant_selection_note product__block product__block--{{ block.type }}"
              {{ block.shopify_attributes }}
              style="display: none;"
            >
              <span class="cstm_variant_selection_note_icon_text">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 17.5C14.1421 17.5 17.5 14.1421 17.5 10C17.5 5.85786 14.1421 2.5 10 2.5C5.85786 2.5 2.5 5.85786 2.5 10C2.5 14.1421 5.85786 17.5 10 17.5Z" stroke="#D63242" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9.375 9.375C9.54076 9.375 9.69973 9.44085 9.81694 9.55806C9.93415 9.67527 10 9.83424 10 10V13.125C10 13.2908 10.0658 13.4497 10.1831 13.5669C10.3003 13.6842 10.4592 13.75 10.625 13.75" stroke="#D63242" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9.6875 6.125C9.92912 6.125 10.125 6.32088 10.125 6.5625C10.125 6.80412 9.92912 7 9.6875 7C9.44588 7 9.25 6.80412 9.25 6.5625C9.25 6.32088 9.44588 6.125 9.6875 6.125Z" fill="#D63242" stroke="#D63242"/>
                </svg>
                {{ block.settings.notecontent }}
              </span>
            </div>
          {% endif %}
        {%- when 'return-exchange-note' -%}
          {%- liquid
            assign is_no_return = false
            for collection in product.collections
              if collection.metafields.custom.no_return_exchange == true
                assign is_no_return = true
                break
              endif
            endfor
          -%}
          {% if is_no_return == false and block.settings.note_text != blank %}
            <div
              class="product__block product__block--{{ block.type }} {{ block.settings.custom_class }}"
              {{ block.shopify_attributes }}
            >
              <div class="return-exchange-note-content rte">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.9063 12C20.9063 10.2385 20.3839 8.51658 19.4053 7.05196C18.4266 5.58733 17.0357 4.44579 15.4083 3.7717C13.7809 3.09761 11.9901 2.92124 10.2625 3.26489C8.53484 3.60853 6.9479 4.45677 5.70233 5.70233C4.45677 6.9479 3.60853 8.53484 3.26489 10.2625C2.92124 11.9901 3.09761 13.7809 3.7717 15.4083C4.44579 17.0357 5.58733 18.4266 7.05196 19.4053C8.51658 20.3839 10.2385 20.9063 12 20.9063C14.3613 20.9036 16.6251 19.9645 18.2948 18.2948C19.9645 16.6251 20.9036 14.3613 20.9063 12ZM4.28125 12C4.28125 10.4734 4.73395 8.98104 5.5821 7.7117C6.43025 6.44235 7.63575 5.45302 9.04617 4.86881C10.4566 4.28459 12.0086 4.13174 13.5059 4.42957C15.0031 4.7274 16.3785 5.46254 17.458 6.54202C18.5375 7.62151 19.2726 8.99686 19.5704 10.4942C19.8683 11.9914 19.7154 13.5434 19.1312 14.9538C18.547 16.3643 17.5577 17.5698 16.2883 18.4179C15.019 19.2661 13.5266 19.7188 12 19.7188C9.95359 19.7164 7.99166 18.9024 6.54463 17.4554C5.09759 16.0083 4.28361 14.0464 4.28125 12Z" fill="#453D2B"></path>
                  <path d="M12.5938 14.9688H8.4375C8.28003 14.9688 8.12901 15.0313 8.01766 15.1427C7.90631 15.254 7.84375 15.405 7.84375 15.5625C7.84375 15.72 7.90631 15.871 8.01766 15.9823C8.12901 16.0937 8.28003 16.1562 8.4375 16.1562H12.5938C13.5386 16.1562 14.4447 15.7809 15.1128 15.1128C15.7809 14.4447 16.1562 13.5386 16.1562 12.5938C16.1562 11.6489 15.7809 10.7428 15.1128 10.0747C14.4447 9.40658 13.5386 9.03125 12.5938 9.03125H8.4375C8.28003 9.03125 8.12901 9.09381 8.01766 9.20516C7.90631 9.31651 7.84375 9.46753 7.84375 9.625C7.84375 9.78247 7.90631 9.93349 8.01766 10.0448C8.12901 10.1562 8.28003 10.2188 8.4375 10.2188H12.5938C13.2236 10.2188 13.8277 10.469 14.2731 10.9144C14.7185 11.3598 14.9688 11.9639 14.9688 12.5938C14.9688 13.2236 14.7185 13.8277 14.2731 14.2731C13.8277 14.7185 13.2236 14.9688 12.5938 14.9688Z" fill="#453D2B"></path>
                  <path d="M11.2322 6.83021C11.1208 6.7189 10.9698 6.65637 10.8124 6.65637C10.6549 6.65637 10.5039 6.7189 10.3926 6.83021L8.01759 9.20521C7.90628 9.31656 7.84375 9.46755 7.84375 9.625C7.84375 9.78244 7.90628 9.93343 8.01759 10.0448L10.3926 12.4198C10.5046 12.5279 10.6546 12.5878 10.8102 12.5864C10.9659 12.5851 11.1148 12.5226 11.2249 12.4125C11.335 12.3025 11.3975 12.1535 11.3988 11.9979C11.4002 11.8422 11.3403 11.6922 11.2322 11.5802L9.27694 9.625L11.2322 7.66978C11.3435 7.55843 11.406 7.40744 11.406 7.25C11.406 7.09255 11.3435 6.94156 11.2322 6.83021Z" fill="#453D2B"></path>
                </svg>
                {{ block.settings.note_text }}
              </div>
            </div>
          {% endif %}
        {%- when 'dis_code' -%}
          {% comment %} Check which collection the product belongs to {% endcomment %}
          {% assign show_collection1_discount = false %}
          {% assign show_collection2_discount = false %}
          {% assign selected_collection1 = block.settings.collection1 %}
          {% assign selected_collection2 = block.settings.collection2 %}

          {% for collection in product.collections %}
            {% if selected_collection1 != blank and collection.handle == selected_collection1.handle %}
              {% assign show_collection1_discount = true %}
            {% endif %}
