                  {% assign left_column = '' %}
                  {% assign right_column = '' %}

                  {% for spec in specs %}
                    {% assign is_even = forloop.index0 | modulo: 2 %}
                    {% if is_even == 0 %}
                      {% assign left_column = left_column | append: spec | append: '||' %}
                    {% else %}
                      {% assign right_column = right_column | append: spec | append: '||' %}
                    {% endif %}
                  {% endfor %}

                  <div class="product-specs-grid">
                    <div>
                      {% assign left_specs = left_column | split: '||' %}
                      {% for item in left_specs %}
                        {% if item != '' %}
                          <div class="specs-item specs-item-left">
                            <div>{{ item | split: ':' | first }}</div>
                            <div>
                              <strong>{{ item | split: ':' | last | strip }}</strong>
                            </div>
                          </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                    <div>
                      {% assign right_specs = right_column | split: '||' %}
