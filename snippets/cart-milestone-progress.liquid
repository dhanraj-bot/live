{%- liquid
  comment
    cart-milestone-progress.liquid
    Shows a progress bar with milestones driven by discount_coupon blocks.
    The first milestone is always "Free Shipping" (uses settings.free_shipping_minimum_amount).
    Additional milestones come from visible discount_coupon blocks and use the
    same validation rules as cart-discount.liquid.
  endcomment

  assign cart_total = 0
  assign cart_quantity = 0
  assign cart_collections = ','

  for item in cart.items
    assign cart_total = cart_total | plus: item.final_line_price
    assign cart_quantity = cart_quantity | plus: item.quantity

    for col in item.product.collections
      assign collection_token = ',' | append: col.id | append: ','
      unless cart_collections contains collection_token
        assign cart_collections = cart_collections | append: col.id | append: ','
      endunless
    endfor
  endfor

  assign cart_total_money = cart_total | divided_by: 100.0
  assign hide_on_mobile = section.settings.cart_milestone_hide_mobile
  assign free_ship_amount_raw = settings.free_shipping_minimum_amount | append: ''
  assign free_ship_amount = free_ship_amount_raw | replace: ',', '' | replace: '₹', '' | replace: '$', '' | remove: ' ' | plus: 0
  assign free_ship_reached = true

  assign milestone_records = ''
  assign milestone_count = 0
  assign source_index = 0

  for block in section.blocks
    if block.type == 'discount_coupon'
      assign show_to_customer = true
      if block.settings.customer_tag != blank
        assign show_to_customer = false
        if customer
          for tag in customer.tags
            if tag == block.settings.customer_tag
              assign show_to_customer = true
              break
            endif
          endfor
        endif
      endif

      if show_to_customer
        assign min_qty = block.settings.min_quantity | plus: 0
        assign min_val = block.settings.min_value | plus: 0
        assign milestone_label = block.settings.milestone_label | default: block.settings.description | default: block.settings.code
        assign valid_collection = true

        if block.settings.eligible_collections != blank
          assign valid_collection = false
          for selected_col in block.settings.eligible_collections
            assign collection_token = ',' | append: selected_col.id | append: ','
            if cart_collections contains collection_token
              assign valid_collection = true
              break
            endif
          endfor
        endif

        assign milestone_reached = true
        if min_qty > 0 and cart_quantity < min_qty
          assign milestone_reached = false
        endif
        if min_val > 0 and cart_total_money < min_val
          assign milestone_reached = false
        endif
        unless valid_collection
          assign milestone_reached = false
        endunless

        assign sort_group = '3'
        assign sort_metric = 0
        if min_qty > 0
          assign sort_group = '1'
          assign sort_metric = min_qty
        elsif min_val > 0
          assign sort_group = '2'
          assign sort_metric = min_val
        endif

        assign padded_metric = sort_metric | append: '' | prepend: '000000000000' | slice: -12, 12
        assign padded_index = source_index | append: '' | prepend: '000000000000' | slice: -12, 12
        assign safe_code = block.settings.code | replace: '##', '' | replace: '||', ''
        assign safe_label = milestone_label | replace: '##', '' | replace: '||', ''

        capture milestone_record
          echo sort_group
          echo '-'
          echo padded_metric
          echo '-'
          echo padded_index
          echo '##'
          echo safe_code
          echo '##'
          echo safe_label
          echo '##'
          echo min_qty
          echo '##'
          echo min_val
          echo '##'
          if valid_collection
            echo '1'
          else
            echo '0'
          endif
          echo '##'
          if milestone_reached
            echo '1'
          else
            echo '0'
          endif
        endcapture

        assign milestone_records = milestone_records | append: milestone_record | append: '||'
        assign milestone_count = milestone_count | plus: 1
      endif

      assign source_index = source_index | plus: 1
    endif
  endfor

  assign milestone_arr = milestone_records | split: '||' | sort_natural
  assign total_steps = milestone_count | plus: 1

  assign steps_reached = 0
  if free_ship_reached
    assign steps_reached = steps_reached | plus: 1
  endif

  for i in (0..milestone_count)
    assign idx = forloop.index0
    if idx < milestone_count
      assign milestone_entry = milestone_arr[idx]
      assign milestone_fields = milestone_entry | split: '##'
      assign milestone_reached = milestone_fields[6]
      if milestone_reached == '1'
        assign steps_reached = steps_reached | plus: 1
      endif
    endif
  endfor

  assign fill_pct = 0
  assign total_segments = total_steps | minus: 1
  if total_segments > 0
    assign reached_segments = steps_reached | minus: 1
    if reached_segments < 0
      assign reached_segments = 0
    endif

    assign fill_pct = reached_segments | times: 100 | divided_by: total_segments
    if reached_segments >= total_segments
      assign fill_pct = 100
    endif
  endif

  assign hint_found = false
  assign next_hint = ''
  assign next_qty_gap = 0
  assign next_value_gap = 0
  assign next_requires_collection = false

  unless free_ship_reached
    if free_ship_amount > 0
      assign hint_found = true
      assign next_hint = 'free_shipping'
    endif
  endunless

  unless hint_found
    for i in (0..milestone_count)
      assign idx = forloop.index0
      if idx < milestone_count
        assign milestone_entry = milestone_arr[idx]
        assign milestone_fields = milestone_entry | split: '##'
        assign milestone_reached = milestone_fields[6]

        if milestone_reached == '0' and hint_found == false
          assign hint_found = true
          assign next_hint = milestone_fields[2]
          assign next_min_qty = milestone_fields[3] | plus: 0
          assign next_min_val = milestone_fields[4] | plus: 0
          assign next_collection_ok = milestone_fields[5]
          assign next_qty_gap = next_min_qty | minus: cart_quantity
          assign next_value_gap = next_min_val | minus: cart_total_money | ceil

          if next_qty_gap < 0
            assign next_qty_gap = 0
          endif
          if next_value_gap < 0
            assign next_value_gap = 0
          endif
          unless next_collection_ok == '1'
            assign next_requires_collection = true
          endunless
        endif
      endif
    endfor
  endunless
-%}

<style>
  .cart-milestone-wrapper {
    margin-bottom: 16px;
    box-shadow: 4px 5px 34px 0px #0000001A;
  }
  
  .cart-milestone {
    --milestone-dot-size: 17px;
    --milestone-line-size: 2px;
    background: #fff;
    padding: 20px 16px;
    margin-bottom: 0;
  }
  .cart-milestone__track {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    position: relative;
    padding-bottom: 12px;
  }
  .cart-milestone__line-bg {
    position: absolute;
    top: 14px;
    left: 0;
    right: 0;
    height: 2px;
    background: #EEEEEE;
    z-index: 0;
  }
  .cart-milestone__line-fill {
    position: absolute;
    top: 14px;
    left: 0;
    height: 2px;
    background: #189037;
    z-index: 1;
    transition: width 0.4s ease;
  }
  .cart-milestone__track-outer {
    position: relative;
  }
  .cart-milestone__track-lines {
    position: absolute;
    top: calc((var(--milestone-dot-size) - var(--milestone-line-size)) / 2);
    left: calc(var(--milestone-dot-size) / 2);
    right: calc(var(--milestone-dot-size) / 2);
    height: var(--milestone-line-size);
    pointer-events: none;
  }
  .cart-milestone__line-bg-inner {
    position: absolute;
    inset: 0;
    background: #EEEEEE;
  }
  .cart-milestone__line-fill-inner {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: #189037;
    transition: width 0.4s ease;
  }
  .cart-milestone__steps-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }
  .cart-milestone__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
    flex: 1;
    min-width: 0;
  }
  .cart-milestone__step--first {
    align-items: flex-start;
  }
  .cart-milestone__step--last {
    align-items: flex-end;
  }
  .cart-milestone__dot {
    width: var(--milestone-dot-size);
    height: var(--milestone-dot-size);
    border-radius: 50%;
    border: 1px solid #E0E0E0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    position: relative;
    line-height: 0;
    transition: all 0.3s ease;
    
  }
  .cart-milestone__dot--reached {
    background: #189037;
    border-color: #189037;
  }
  .cart-milestone__dot--next {
    border-color: #189037;
    background: #fff;
  }
  .cart-milestone__dot svg {
    width: 10px;
    height: 10px;
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .cart-milestone__dot-inner {
    width: 8px;
    height: 8px;
    background: #189037;
    border-radius: 50%;
    display: block;
    position: absolute;
    top: 49.3%;
    left: 49.2%;
    transform: translate(-50%, -50%);
  }
  .cart-milestone__label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #252931;
    margin-top: 8px;
    text-align: center;
    line-height: 1.3;
    display: block;
    width: 100%;
    max-width: 220px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    {% comment %} padding-left: 8px;
    padding-right:8px; {% endcomment %}
  }
  .cart-milestone-shipping, .cart-other-milestone {
    padding-right:8px;
  }
  .cart-milestone__step--first .cart-milestone__label {
    text-align: left;
  }
  .cart-milestone__step--last .cart-milestone__label {
    text-align: right;
  }
  .cart-milestone__label--reached {
    color: #189037;
    font-weight: 600;
  }
  .cart-milestone__hint {
    background: #189037;
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    text-align: center;
    padding: 4px 6px;
    font-weight: 500;
    font-size: 12px;
    line-height: 140%;

  }
  @media(max-width:768px){
    .cart-milestone-wrapper--hide-mobile {
      display: none !important;
    }

    .cart-milestone-wrapper {
      margin-bottom: 16px;
      box-shadow: 4px 5px 34px 0px #0000001A;
    }
     .cart-milestone__hint {
      background: #189037;
      font-size: 10px;
      line-height: 140%;

    }
    .cart-milestone__label{
      font-size: 10px;
    }
  }
</style>

{%- if cart.item_count > 0 -%}
<div class="cart-milestone-wrapper{% if hide_on_mobile %} cart-milestone-wrapper--hide-mobile{% endif %}">
  <div class="cart-milestone">
    <div class="cart-milestone__track-outer">
      <div class="cart-milestone__track-lines">
        <div class="cart-milestone__line-bg-inner"></div>
        <div class="cart-milestone__line-fill-inner" style="width: {{ fill_pct }}%;"></div>
      </div>
      <div class="cart-milestone__steps-row">
        {%- comment %} Step 1: Free Shipping {%- endcomment %}
        <div class="cart-milestone__step cart-milestone__step--first{% if milestone_count == 0 %} cart-milestone__step--last{% endif %}">
          <div class="cart-milestone__dot {% if free_ship_reached %}cart-milestone__dot--reached{% else %}cart-milestone__dot--next{% endif %}">
            {%- if free_ship_reached -%}
              <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 7L5.5 10.5L12 4" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- else -%}
              {%- if hint_found and next_hint == 'free_shipping' -%}
                <div class="cart-milestone__dot-inner"></div>
              {%- endif -%}
            {%- endif -%}
          </div>
          <span class="cart-milestone__label cart-milestone-shipping {% if free_ship_reached %}cart-milestone__label--reached{% endif %}">
            Free Shipping
          </span>
        </div>

        {%- comment %} Coupon milestone steps {%- endcomment %}
        {%- for i in (1..milestone_count) -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign milestone_entry = milestone_arr[idx] -%}
          {%- assign milestone_fields = milestone_entry | split: '##' -%}
          {%- assign m_reached = milestone_fields[6] -%}
          {%- assign m_label = milestone_fields[2] -%}
          {%- assign is_last_step = false -%}
          {%- if forloop.last -%}{%- assign is_last_step = true -%}{%- endif -%}
          <div class="cart-milestone__step{% if is_last_step %} cart-milestone__step--last{% endif %}">
            <div class="cart-milestone__dot {% if m_reached == '1' %}cart-milestone__dot--reached{% elsif hint_found and next_hint == m_label %}cart-milestone__dot--next{% endif %}">
              {%- if m_reached == '1' -%}
                <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 7L5.5 10.5L12 4" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- else -%}
                {%- if hint_found and next_hint == m_label -%}
                  <div class="cart-milestone__dot-inner"></div>
                {%- endif -%}
              {%- endif -%}
            </div>
            <span class="cart-milestone__label {% if m_reached == '1' %}cart-milestone__label--reached{% endif %} {% unless forloop.last %} cart-other-milestone{% endunless %}">
              {{ m_label }}
            </span>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment %} Hint banner {%- endcomment %}
  {%- if hint_found -%}
    <div class="cart-milestone__hint">
      {%- if next_hint == 'free_shipping' -%}
        {%- assign remaining = free_ship_amount | minus: cart_total_money | ceil -%}
        Add ₹{{ remaining }} more to get <span>Free Shipping</span>
      {%- else -%}
        {%- if next_requires_collection -%}
          Add eligible item(s) to unlock <span>{{ next_hint }}</span>
        {%- elsif next_qty_gap > 0 and next_value_gap > 0 -%}
          Add {{ next_qty_gap }} more item{% if next_qty_gap > 1 %}s{% endif %} and ₹{{ next_value_gap }} more to get <span>{{ next_hint }}</span>
        {%- elsif next_qty_gap > 0 -%}
          Add {{ next_qty_gap }} more item{% if next_qty_gap > 1 %}s{% endif %} to get <span>{{ next_hint }}</span>
        {%- elsif next_value_gap > 0 -%}
          Add ₹{{ next_value_gap }} more to get <span>{{ next_hint }}</span>
        {%- else -%}
          You're eligible for <span>{{ next_hint }}</span> — apply the coupon!
        {%- endif -%}
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
{%- endif -%}
