  // Function to check if manual coupon is valid for current cart
  function checkManualCouponValidity(couponCode) {
    // Get current cart state using CartDataManager
    const fetchPromise = window.CartDataManager 
      ? window.CartDataManager.getCart() 
      : fetch('/cart.js').then(res => res.json());
    
    fetchPromise
      .then(cartData => {
        // Get current button and input from DOM (may have been replaced after re-init)
        const currentManualApplyBtn = document.querySelector("#manualCouponInput + .apply-discount-button");
        const currentInput = document.getElementById("manualCouponInput");
        // Only update button if input still shows this code (user may have typed something else)
        if (currentInput && currentInput.value.trim().toUpperCase() !== couponCode.toUpperCase()) {
          return;
        }
        const cartTotal = cartData.total_price / 100;
        const cartQuantity = cartData.item_count;
        
        // Find the discount button for this code
        const discountButton = document.querySelector(`[data-discount-code="${couponCode.toUpperCase()}"]`);
        
        if (discountButton) {
          // Get discount requirements
          const minQuantity = parseInt(discountButton.dataset.minQuantity) || 0;
          const minValue = parseFloat(discountButton.dataset.minValue) || 0;
          
          // Check if discount is valid for current cart
          let isValid = true;
          let reason = '';
          
          if (minQuantity > 0 && cartQuantity < minQuantity) {
            isValid = false;
            reason = `Minimum ${minQuantity} items required`;
          }
          
          if (minValue > 0 && cartTotal < minValue) {
            isValid = false;
            reason = `Minimum ₹${minValue} required`;
          }
          
          // Update button state using live DOM reference
          if (currentManualApplyBtn) {
            if (isValid) {
              currentManualApplyBtn.textContent = "Apply";
              currentManualApplyBtn.dataset.buttonState = "apply";
              currentManualApplyBtn.disabled = false;
              currentManualApplyBtn.style.opacity = "1";
              currentManualApplyBtn.title = "";
              currentManualApplyBtn.classList.remove('disable-invalid');
            } else {
              currentManualApplyBtn.textContent = "Invalid";
              currentManualApplyBtn.dataset.buttonState = "invalid";
              currentManualApplyBtn.disabled = true;
              currentManualApplyBtn.style.opacity = "0.5";
              currentManualApplyBtn.title = reason;
              currentManualApplyBtn.classList.add('disable-invalid');
            }
          }
        } else {
          // Coupon code not found - keep button enabled so user can try applying (server will reject)
          if (currentManualApplyBtn) {
            currentManualApplyBtn.textContent = "Apply";
            currentManualApplyBtn.dataset.buttonState = "apply";
            currentManualApplyBtn.disabled = false;
            currentManualApplyBtn.style.opacity = "1";
            currentManualApplyBtn.title = "Coupon code not in list – you can still try to apply";
            currentManualApplyBtn.classList.remove('disable-invalid');
          }
        }
      })
      .catch(error => {
        // console.error('Error checking coupon validity:', error);
      });
  }

  // Function to trigger GA4 event for coupon buttons
  function triggerCouponGA4Event(button, manualInputValue = '') {
    const couponCode = button.dataset.discountCode || button.dataset.code || manualInputValue;
    if (couponCode) {
      const buttonText = button.textContent.trim();
      const isRemoving = buttonText === 'Remove';
      
      const eventData = {
        cta_text: button.dataset.buttonState || (isRemoving ? 'remove' : 'apply'),
        content_title: couponCode,
        page_type: '{{ template | handleize }}',
        userID: '{{ customer.id | default: "guest" }}',
        user_type: '{{ customer.tags | join: "," | default: "guest" }}'
      };

      if (typeof gtag === 'function') {
        const eventName = isRemoving ? 'coupon_removed' : 'apply_coupon';
        gtag('event', eventName, eventData);
      }
    }
  }

