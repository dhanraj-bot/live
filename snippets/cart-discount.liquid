          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "x-shopify-storefront-access-token": storefrontAccessToken,
          },
          body: JSON.stringify({
            query: `query { cart(id: "gid://shopify/Cart/${cartToken}") { discountCodes { code applicable } } }`
          })
        });

        const result = await response.json();
        activeCode = result?.data?.cart?.discountCodes?.[0]?.code || '';

        if (activeCode) {
          window.currentAppliedDiscountCode = activeCode;
        }
      } catch (e) {
        // fall through with empty activeCode
      }
    }

    // Re-query buttons after DOM re-render
    const allButtons = document.querySelectorAll('.apply-discount-button');

    allButtons.forEach(btn => {
      const btnCode = (btn.dataset.discountCode || btn.dataset.code || '').toUpperCase();
      const isApplied = activeCode && btnCode && btnCode === activeCode.toUpperCase();
      const wasDisabled = btn.classList.contains('disable-invalid');

      if (isApplied) {
        btn.textContent = 'Remove';
        btn.dataset.buttonState = 'remove';
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.classList.remove('disable-invalid');

        // Re-attach click handler so Remove actually works
        btn.onclick = function(e) {
          e.preventDefault();
          window.applyDiscountCode('', this, activeCode);
        };

        // Mark parent card as applied
        const card = btn.closest('.coupon-card');
        if (card) card.classList.add('is-applied');

      } else if (wasDisabled) {
        btn.textContent = 'Invalid';
        btn.dataset.buttonState = 'invalid';
        btn.disabled = true;
        btn.style.opacity = '0.5';
      } else {
        btn.textContent = 'Apply';
        btn.dataset.buttonState = 'apply';
        btn.disabled = false;
        btn.style.opacity = '1';

        btn.onclick = function(e) {
          e.preventDefault();
          const code = this.dataset.discountCode || this.dataset.code;
          window.applyDiscountCode(code, this, '');
        };

        const card = btn.closest('.coupon-card');
        if (card) card.classList.remove('is-applied');
      }
    });

    // Also update the applied coupon display strip
    if (activeCode) {
      updateDiscountDisplayUI(activeCode);
    }
  };
});

