  // Global function to apply/remove discount codes 
  window.applyDiscountCode = function(code, ele, currentcode) {
    // Get cart token and storefront access token
    const storefrontAccessToken = "df3b1660e6859f510b854dc282eccdf9";
    
    // Get cart token using CartDataManager
    const fetchPromise = window.CartDataManager 
      ? window.CartDataManager.getCart(true) // Force refresh before applying discount
      : fetch('/cart.js').then(res => res.json());
    
    fetchPromise
      .then(cartData => {
        const carttoken = cartData.token;
        
        // Signal to custom.js that this coupon is being handled by the modal system
        if (code) {
          window.couponModalHandled = code;
          // window.currentAppliedDiscountCode = code;
        } else {
          window.currentAppliedDiscountCode = '';
        }
        
        if (ele) {
          ele.classList.add('loader');
          const originalText = ele.textContent;
          ele.textContent = 'Applying...';
          ele.disabled = true;

          // Store original text for restoration
          ele.dataset.originalText = originalText;
        }
        const variables = {
          id: `gid://shopify/Cart/${carttoken}`,
          discountCodes: code ? code.split(',') : [],
        };
        const query = `
          mutation cartDiscountCodesUpdate($id: ID!, $discountCodes:[String!]) {
            cartDiscountCodesUpdate(cartId: $id, discountCodes: $discountCodes) {
              cart {
                id
                discountCodes {
                  code
                  applicable
                }
              }
              userErrors {
                field
                message
              }
            }
          }
        `;

        fetch("https://powerlook-apparels.myshopify.com/api/2024-10/graphql.json", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "x-shopify-storefront-access-token": storefrontAccessToken,
          },
          body: JSON.stringify({ query, variables }),
        })
        .then(response => response.json())
        .then(data => {
          if (ele) {
            ele.classList.remove('loader');
          }
          const cart = data?.data?.cartDiscountCodesUpdate?.cart;
          const errors = data?.data?.cartDiscountCodesUpdate?.userErrors;

          if (errors?.length > 0) {
            const message = errors[0].message || "Invalid discount code.";
            alert(`Failed to apply discount: ${message}`);
            if (ele) {
              ele.textContent = "Invalid";
              ele.disabled = true;
            }

            if (ele) {
              const couponCard = ele.closest('.coupon-card');
              if (couponCard) {
                couponCard.classList.add('disable');
                let errorMsg = couponCard.querySelector('.discount-error-message');
                if (!errorMsg) {
                  errorMsg = document.createElement('div');
                  errorMsg.className = 'discount-error-message';
                  errorMsg.style.color = '#dc3545';
                  errorMsg.style.fontSize = '12px';
                  errorMsg.style.marginTop = '5px';
                  couponCard.appendChild(errorMsg);
                }
                errorMsg.textContent = message;
              }
            }
            return;
          }

          const appliedCode = cart?.discountCodes?.[0]?.code;
          const applicable = cart?.discountCodes?.[0]?.applicable;

          // Immediately update the discount display UI based on the API response
          if (code && applicable) {
            // Discount was successfully applied
            updateDiscountDisplayUI(code);
            window.currentAppliedDiscountCode = code; 
          } else if (!code) {
            // Discount was removed
            updateDiscountDisplayUI('');
          }

          if (code && !applicable) {
            if (ele) {
              ele.textContent = "Invalid";
              ele.disabled = true;
            }
            
            if (ele) {
              const couponCard = ele.closest('.coupon-card');
              if (couponCard) couponCard.classList.add('disable');
            }
            return;
          }

          // Get fresh button references
          const currentDiscountButtons = document.querySelectorAll(".apply-discount-button");
          currentDiscountButtons.forEach((btn) => {
            if (btn.dataset.discountCode === appliedCode) {
              updateButtonState(btn, "remove"); 
            } else {
              updateButtonState(btn, "apply");  
            }
          });

          const manualInput = document.getElementById("manualCouponInput");
          if (manualInput) {
            // Get fresh reference to manual apply button
            const currentManualApplyBtn = document.querySelector("#manualCouponInput + .apply-discount-button");
            if (currentManualApplyBtn) {
              if (manualInput.value.trim().toUpperCase() === appliedCode?.toUpperCase()) {
                updateButtonState(currentManualApplyBtn, "remove");
              } else {
                updateButtonState(currentManualApplyBtn, "apply");
              }
            }
          }

          // Track coupon removal with MoEngage if code was removed
          if (typeof Moengage !== 'undefined' && !code && currentcode) {
            // This means a coupon was removed (code is empty but currentcode exists)
            window.currentAppliedDiscountCode = '';
            window.couponRemovalInProgress = true;
            
            if (!window.couponRemovedEventTracked) {
              window.couponRemovedEventTracked = true;
              Moengage.track_event("Coupon Code Removed", {
                "Coupon Code": currentcode,
                "Page Type": "{{ template | handleize }}",
                "User Type": "{{ customer.tags | join: ',' | default: 'guest' }}"
              });
              
              setTimeout(() => {
                window.couponRemovedEventTracked = false;
              }, 5000);
            }
            
            // Reset the tracking flag when coupon is removed to allow future tracking
            window.couponTrackingDone = false;
            
            // Update discount display UI for removal
            updateDiscountDisplayUI('');
            
            // For removal, immediately hide the discount row and refresh cart
            const discountRowEl = document.querySelector('.wk-order-summary .price-row.discount');
            if (discountRowEl) {
              discountRowEl.style.display = 'none';
            }
            
            // Reset all button states after removal, but respect original disabled state
            const currentDiscountButtons = document.querySelectorAll(".apply-discount-button");
            currentDiscountButtons.forEach((btn) => {
              const wasOriginallyDisabled = btn.classList.contains('disable-invalid');
              
              if (wasOriginallyDisabled) {
                btn.textContent = "Invalid";
                btn.dataset.buttonState = "invalid";
                btn.disabled = true;
                btn.style.opacity = "0.5";
                btn.title = "Discount is not valid to the current cart";
              } else {
                btn.textContent = "Apply";
                btn.dataset.buttonState = "apply";
                btn.disabled = false;
                btn.style.opacity = "1";
                btn.title = "";
              }
            });
            
            // Reset manual input button
            if (manualInput) {
              const currentManualApplyBtn = document.querySelector("#manualCouponInput + .apply-discount-button");
              if (currentManualApplyBtn) {
                manualInput.value = '';
                currentManualApplyBtn.textContent = "Apply";
                currentManualApplyBtn.dataset.buttonState = "apply";
                currentManualApplyBtn.disabled = false;
                currentManualApplyBtn.style.opacity = "1";
                currentManualApplyBtn.title = "";
              }
            }
            
            // Clear any error states
            const errorMessages = document.querySelectorAll('.discount-error-message');
            errorMessages.forEach(msg => msg.remove());
            
              // Update cart items after discount removal
            setTimeout(() => {
              if (window.CartDataManager) {
                window.CartDataManager.invalidateCache();
              }
              
              const updatePromise = window.CartDataManager 
                ? window.CartDataManager.getCart(true) 
                : fetch('/cart.js').then(res => res.json());
              
              updatePromise
                .then(cart => {
                  // Update cart items display
                  if (window.updateCartItemsDisplay) {
                    window.updateCartItemsDisplay(cart);
                  }
                  
                  updateDiscountSummaryFromCart(cart);
                  
                  if (window.updateOrderSummaryFromDiscount) {
                    window.updateOrderSummaryFromDiscount(cart);
                  }
                  
                  if (window.refreshCartData && !window.couponRemovalInProgress) {
                    window.refreshCartData();
                  }
                  
                  if (window.refreshComparePricesAndDiscounts) {
                    window.refreshComparePricesAndDiscounts();
                  }
                  
                  forceUpdateOrderSummary(cart);
                  
                  // Reset the coupon removal progress flag
                  setTimeout(() => {
                    window.couponRemovalInProgress = false;
                  }, 1000);
                });
            }, 500);
            
            // Skip further processing for removal actions
            return;
          }

          // Update discount display UI immediately after successful discount application
          if (code && !currentcode) {
            // Applying new discount
            updateDiscountDisplayUI(code);
          } else if (!code && currentcode) {
            // Removing discount
            updateDiscountDisplayUI('');
          }

          // Close popup modal after updating the display
          closeCouponModal();

          // Track successful coupon application with MoEngage if code was applied
          if (typeof Moengage !== 'undefined' && code && !currentcode) {
            if (!window.couponTrackingDone) {
              window.couponTrackingDone = true;
              
              const trackingPromise = window.CartDataManager 
                ? window.CartDataManager.getCart(true) 
                : fetch('/cart.js').then(res => res.json());
              
              trackingPromise
                .then(cart => {
                  let cartValueBeforeDiscount = 0;
                  let cartValueAfterDiscount = cart.total_price / 100;
                  let totalDiscountAmount = 0;
                  
                  cart.items.forEach(item => {
                    cartValueBeforeDiscount += (item.original_price * item.quantity) / 100;
                  });
                  
                  if (cart.cart_level_discount_applications && cart.cart_level_discount_applications.length > 0) {
                    const cartLevelDiscount = cart.cart_level_discount_applications.reduce((sum, discount) => {
                      return sum + discount.total_allocated_amount;
                    }, 0);
                    totalDiscountAmount += cartLevelDiscount / 100;
                  }
                  
                  cart.items.forEach(item => {
                    if (item.original_price !== item.final_price) {
                      const itemDiscount = (item.original_price - item.final_price) * item.quantity;
                      totalDiscountAmount += itemDiscount / 100;
                    }
                  });
                  
                  if (!window.couponAppliedEventTracked) {
                    window.couponAppliedEventTracked = true;
                    Moengage.track_event("Coupon Code Applied", {
                      "Cart Value Before Discount": Math.round(cartValueBeforeDiscount),
                      "Cart Value After Discount": Math.round(cartValueAfterDiscount),
                      "Coupon Code": code,
                      "Discount Amount": Math.round(totalDiscountAmount),
                      "Page Type": "{{ template | handleize }}",
                      "User Type": "{{ customer.tags | join: ',' | default: 'guest' }}"
                    });
                    
                    setTimeout(() => {
                      window.couponAppliedEventTracked = false;
                    }, 5000);
                  }
                  
                  setTimeout(() => {
                    window.couponTrackingDone = false;
                  }, 5000);
                });
            }
          }
          
          // Update cart items after discount application
          setTimeout(() => {
            // Invalidate cache before fetching
            if (window.CartDataManager) {
              window.CartDataManager.invalidateCache();
            }
            
            const updatePromise = window.CartDataManager 
              ? window.CartDataManager.getCart(true) 
              : fetch('/cart.js').then(res => res.json());
            
            updatePromise
              .then(cart => {
                // Update cart items display first
                if (window.updateCartItemsDisplay) {
                  window.updateCartItemsDisplay(cart);
                }
                
                updateDiscountSummaryFromCart(cart);
                
                if (window.updateOrderSummaryFromDiscount) {
                  window.updateOrderSummaryFromDiscount(cart);
                }
                
                if (window.refreshCartData && !window.mainCartRefreshInProgress) {
                  window.mainCartRefreshInProgress = true;
                  window.refreshCartData();
                  setTimeout(() => {
                    window.mainCartRefreshInProgress = false;
                  }, 1000);
                }
                
                if (window.refreshComparePricesAndDiscounts) {
                  window.refreshComparePricesAndDiscounts();
                }
                
                forceUpdateOrderSummary(cart);
              })
              .catch(error => {
                console.error('Error updating cart after discount:', error);
              });
          }, 500);
        })
        .catch(error => {
          if (ele) {
            ele.classList.remove('loader');
            ele.textContent = ele.dataset.originalText || 'Apply';
            ele.disabled = false;
            delete ele.dataset.originalText;
          }
        });
      })
      .catch(error => {
       // console.error('Error getting cart token:', error);
      });
  };

  // Remove discount function
  window.removeDiscountCode = function(ele, currentcode) {
    const storefrontAccessToken = "df3b1660e6859f510b854dc282eccdf9";

    // Step 1: Get cart token using CartDataManager
    const fetchPromise = window.CartDataManager 
      ? window.CartDataManager.getCart(true) 
      : fetch('/cart.js').then(res => res.json());
    
    fetchPromise
      .then(cartData => {
        const carttoken = cartData.token;

        if (ele) {
          ele.classList.add('loader');
        }

        const variables = {
          id: `gid://shopify/Cart/${carttoken}`,
          discountCodes: []  // Empty array removes discounts
        };

        const query = `
          mutation cartDiscountCodesUpdate($id: ID!, $discountCodes:[String!]) {
            cartDiscountCodesUpdate(cartId: $id, discountCodes: $discountCodes) {
              cart {
                id
                discountCodes {
                  code
                  applicable
                }
              }
              userErrors {
                field
                message
              }
            }
          }
        `;

        // Step 2: Call GraphQL
        fetch("https://powerlook-apparels.myshopify.com/api/2024-10/graphql.json", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "x-shopify-storefront-access-token": storefrontAccessToken,
          },
          body: JSON.stringify({ query, variables }),
        })
        .then(response => response.json())
        .then(data => {
          if (ele) {
            ele.classList.remove('loader');
          }

          const errors = data?.data?.cartDiscountCodesUpdate?.userErrors;
          if (errors?.length > 0) {
            const message = errors[0].message || "Failed to remove discount.";
            alert(`Error: ${message}`);
            return;
          }

          // Discount removed successfully
          window.currentAppliedDiscountCode = '';
          updateDiscountDisplayUI('');

          // Reset button states
          const discountButtons = document.querySelectorAll(".apply-discount-button");
          discountButtons.forEach(btn => {
            btn.textContent = "Apply";
            btn.dataset.buttonState = "apply";
            btn.disabled = false;
            btn.style.opacity = "1";
          }); 

          // Reset manual input field
          const manualInput = document.getElementById("manualCouponInput");
          if (manualInput) {
            const manualBtn = document.querySelector("#manualCouponInput + .apply-discount-button");
            if (manualBtn) {
              manualInput.value = '';
              manualBtn.textContent = "Apply";
              manualBtn.dataset.buttonState = "apply";
              manualBtn.disabled = false;
              manualBtn.style.opacity = "1";
            }
          }

          // Track removal in MoEngage
          if (typeof Moengage !== 'undefined' && currentcode) {
            Moengage.track_event("Coupon Code Removed", {
              "Coupon Code": currentcode,
              "Page Type": "{{ template | handleize }}",
              "User Type": "{{ customer.tags | join: ',' | default: 'guest' }}"
            });
          }

          // Refresh cart after removal
          if (window.CartDataManager) {
            window.CartDataManager.invalidateCache();
          }
          
          const refreshPromise = window.CartDataManager 
            ? window.CartDataManager.getCart(true) 
            : fetch('/cart.js').then(res => res.json());
          
          refreshPromise
            .then(cart => {
              updateDiscountSummaryFromCart(cart);
              if (window.updateOrderSummaryFromDiscount) {
                window.updateOrderSummaryFromDiscount(cart);
              }
              if (window.refreshCartData) {
                window.refreshCartData();
              }
              if (window.updateCartItemsDisplay) {
                window.updateCartItemsDisplay(cart);
              }
              if (window.refreshComparePricesAndDiscounts) {
                window.refreshComparePricesAndDiscounts();
              }
              forceUpdateOrderSummary(cart);

              // Reload page after discount removed & cart refreshed 
              location.reload(); 
            });

        })
        .catch(error => {
          if (ele) {
            ele.classList.remove('loader'); 
          }
          //console.error("Error removing discount:", error);
        });
      })
      .catch(error => {
       // console.error("Error getting cart token:", error);
      });
  };

  discountButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const state = btn.dataset.buttonState;
      const code = btn.dataset.discountCode;
      window.applyDiscountCode(state === "apply" ? code : "", btn, code);
