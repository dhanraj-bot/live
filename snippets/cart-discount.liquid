<script> 
// Refresh cart discount data 
(function() {
  'use strict';
  
  // Configuration
  const config = {
    storefrontAccessToken: "df3b1660e6859f510b854dc282eccdf9",
    shopDomain: "powerlook-apparels.myshopify.com",
    refreshDelay: 500,
    maxRetries: 3,
    retryDelay: 1000
  };

  // State management
  let refreshInProgress = false;
  let lastCartToken = null;
  let currentAppliedDiscount = '';

  // Main cart update event listener
  document.addEventListener('cart:updated', function(evt) {
    console.log('Cart updated event detected:', evt.detail.cart);
    handleCartUpdate(evt.detail.cart);
  });

  // Additional cart refresh listeners
  document.addEventListener('cart:refresh', function(evt) {
    console.log('Cart refresh event detected');
    setTimeout(() => {
      refreshCompleteDiscountSystem();
    }, config.refreshDelay);
  });

  // Handle cart updates with debouncing
  function handleCartUpdate(cartData) {
    if (refreshInProgress) {
      console.log('Refresh already in progress, skipping...');
      return;
    }

    refreshInProgress = true;
    
    setTimeout(() => {
      refreshCompleteDiscountSystem(cartData);
    }, config.refreshDelay);
  }

  // Main function to refresh the complete discount system
  async function refreshCompleteDiscountSystem(providedCartData = null) {
    try {
      console.log('Starting complete discount system refresh...');
      
      // Get fresh cart data
      const cartData = providedCartData || await fetchCartData();
      if (!cartData) {
        console.error('Failed to get cart data');
        refreshInProgress = false;
        return;
      }

      // Update cart-based calculations
      await updateCartBasedCalculations(cartData);
      
      // Refresh discount button states
      await refreshDiscountButtonStates(cartData);
      
      // Update applied discount display
      await updateAppliedDiscountDisplay(cartData);
      
      // Refresh coupon validation
      await refreshCouponValidation(cartData);
      
      // Update order summary
      await updateOrderSummary(cartData);
      
      // Re-initialize event handlers if needed
      reinitializeEventHandlers();
      
      console.log('Complete discount system refresh completed successfully');
      
      
    } catch (error) {
      console.error('Error in refreshCompleteDiscountSystem:', error);
    } finally {
      refreshInProgress = false;
    }
  }

  // Fetch fresh cart data using CartDataManager
  async function fetchCartData() {
    try {
      return window.CartDataManager 
        ? await window.CartDataManager.getCart() 
        : await fetch('/cart.js').then(res => res.json());
    } catch (error) {
      console.error('Error fetching cart data:', error);
      return null;
    }
  }

  // Update cart-based calculations (quantities, totals, collections)
  async function updateCartBasedCalculations(cartData) {
    // Recalculate cart totals and quantities
    const cartTotal = cartData.total_price / 100;
    const cartQuantity = cartData.item_count;
    
    // Update cart collections
    let cartCollections = "";
    cartData.items.forEach(item => {
      if (item.product && item.product.collections) {
        item.product.collections.forEach(col => {
          if (!cartCollections.includes(col.id)) {
            cartCollections += col.id + ",";
          }
        });
      }
    });

    // Store updated values globally for discount validation
    window.cartDiscountData = {
      total: cartTotal,
      quantity: cartQuantity,
      collections: cartCollections,
      items: cartData.items
    };

    console.log('Updated cart calculations:', window.cartDiscountData);
  }

  // Refresh all discount button states based on current cart
  async function refreshDiscountButtonStates(cartData) {
    const discountButtons = document.querySelectorAll('.apply-discount-button');
    const cartTotal = cartData.total_price / 100;
    const cartQuantity = cartData.item_count;
    
    // Get cart collections
    let cartCollections = "";
    cartData.items.forEach(item => {
      if (item.product && item.product.collections) {
        item.product.collections.forEach(col => {
          if (!cartCollections.includes(col.id)) {
            cartCollections += col.id + ",";
          }
        });
      }
    });

    // Get currently applied discount
    const appliedDiscount = await getCurrentAppliedDiscount(cartData);
    
    discountButtons.forEach(button => {
      const buttonCode = button.dataset.discountCode || button.dataset.code;
      const minQuantity = parseInt(button.dataset.minQuantity) || 0;
      const minValue = parseFloat(button.dataset.minValue) || 0;
      
      // Check if this button's discount is currently applied
      const isCurrentlyApplied = buttonCode === appliedDiscount;
      
      // Validate discount eligibility
      let isValid = true;
      let disableReason = '';
      
      // Quantity validation
      if (minQuantity > 0 && cartQuantity < minQuantity) {
        isValid = false;
        disableReason = `Minimum ${minQuantity} items required`;
      }
      
      // Value validation
      if (minValue > 0 && cartTotal < minValue) {
        isValid = false;
        disableReason = `Minimum ₹${minValue} required`;
      }
      
      // Collection validation (if applicable)
      // This would need to be implemented based on your collection validation logic
      
      // Update button state
      updateIndividualButtonState(button, isCurrentlyApplied, isValid, disableReason);
    });

    console.log('Refreshed all discount button states');
  }

  // Update individual button state
  function updateIndividualButtonState(button, isApplied, isValid, disableReason) {
    if (isApplied) {
      // No need to update button state because it getting refresh on remove coupon
    } else if (!isValid) {
      button.textContent = "Invalid";
      button.dataset.buttonState = "invalid";
      button.disabled = true;
      button.style.opacity = "0.5";
      button.title = disableReason;
      button.classList.add('disable-invalid');
    } else {
      button.textContent = "Apply";
      button.dataset.buttonState = "apply";
      button.disabled = false;
      button.style.opacity = "1";
      button.title = "";
      button.classList.remove('disable-invalid');
    }
  }

  // Get currently applied discount from cart or GraphQL
  async function getCurrentAppliedDiscount(cartData) {
    // Check stored code first (most reliable)
    const cartHasDiscount = cartData.total_discount > 0 || 
    (cartData.discount_applications && cartData.discount_applications.length > 0);
  
    if (window.currentAppliedDiscountCode && cartHasDiscount) {
      return window.currentAppliedDiscountCode;
    }
    
    // If cart has no discount, clear the stored code
    if (!cartHasDiscount) {
      window.currentAppliedDiscountCode = '';
      return '';
    }
    
    // Check cart data for discount
    if (cartData.total_discount > 0 && cartData.discount_applications && cartData.discount_applications.length > 0) {
      const discountApp = cartData.discount_applications[0];
      const code = discountApp.code || discountApp.title || '';
      if (code) {
        window.currentAppliedDiscountCode = code;
        return code;
      }
    }

    // Fallback to GraphQL query
    try {
      const cartToken = cartData.token;
      const response = await fetch(`https://${config.shopDomain}/api/2024-10/graphql.json`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-shopify-storefront-access-token": config.storefrontAccessToken,
        },
        body: JSON.stringify({
          query: `
            query {
              cart(id: "gid://shopify/Cart/${cartToken}") {
                discountCodes {
                  code
                  applicable
                }
              }
            }
          `,
        }),
      });
      
      const result = await response.json();
      const discountCode = result?.data?.cart?.discountCodes?.[0]?.code || "";
      if (discountCode) {
        window.currentAppliedDiscountCode = discountCode;
      }
      return discountCode;
      
    } catch (error) {
      console.error("Error fetching applied discount from GraphQL:", error);
      return '';
    }
  }

  // Update the applied discount display UI
  async function updateAppliedDiscountDisplay(cartData) {
    const appliedDiscount = await getCurrentAppliedDiscount(cartData);
    currentAppliedDiscount = appliedDiscount;
    
    if (window.updateDiscountDisplayUI) {
      window.updateDiscountDisplayUI(appliedDiscount);
      console.log('Updated applied discount display:', appliedDiscount);
    }
  }

  // Refresh coupon validation for manual input
  async function refreshCouponValidation(cartData) {
    const manualInput = document.getElementById('manualCouponInput');
    const manualApplyBtn = document.querySelector('#manualCouponInput + .apply-discount-button');
    
    if (manualInput && manualApplyBtn && manualInput.value.trim()) {
      const couponCode = manualInput.value.trim();
      const isValid = await validateCouponForCart(couponCode, cartData);
      
      if (isValid.valid) {
        manualApplyBtn.textContent = "Apply";
        manualApplyBtn.dataset.buttonState = "apply";
        manualApplyBtn.disabled = false;
        manualApplyBtn.style.opacity = "1";
        manualApplyBtn.title = "";
      } else {
        manualApplyBtn.textContent = "Invalid";
        manualApplyBtn.dataset.buttonState = "invalid";
        manualApplyBtn.disabled = true;
        manualApplyBtn.style.opacity = "0.5";
        manualApplyBtn.title = isValid.reason;
      }
    }
  }

  // Validate coupon against current cart state
  async function validateCouponForCart(couponCode, cartData) {
    if (cartData.items.some(item => item.discount_allocations && item.discount_allocations.length > 0)) {
      return { valid: false, reason: 'Cannot combine with already-discounted items' };
    }
    const cartTotal = cartData.total_price / 100;
    const cartQuantity = cartData.item_count;
    
    // Find the discount button for this code to get requirements
    const discountButton = document.querySelector(`[data-discount-code="${couponCode.toUpperCase()}"]`);
    
    if (!discountButton) {
      return { valid: false, reason: 'Coupon code not found' };
    }
    
    const minQuantity = parseInt(discountButton.dataset.minQuantity) || 0;
    const minValue = parseFloat(discountButton.dataset.minValue) || 0;
    
    if (minQuantity > 0 && cartQuantity < minQuantity) {
      return { valid: false, reason: `Minimum ${minQuantity} items required` };
    }
    
    if (minValue > 0 && cartTotal < minValue) {
      return { valid: false, reason: `Minimum ₹${minValue} required` };
    }
    
    return { valid: true, reason: '' };
  }

  // Update order summary with current cart data
  async function updateOrderSummary(cartData) {
    if (window.updateDiscountSummaryFromCart) {
      window.updateDiscountSummaryFromCart(cartData);
    }
    
    if (window.forceUpdateOrderSummary) {
      window.forceUpdateOrderSummary(cartData);
    }
    
    console.log('Updated order summary');
  }

  // Re-initialize event handlers to ensure they work after DOM updates
  function reinitializeEventHandlers() {
    // Remove existing event listeners to prevent duplicates
    const discountButtons = document.querySelectorAll('.apply-discount-button');
    
    discountButtons.forEach(button => {
      // Clone button to remove all event listeners
      const newButton = button.cloneNode(true);
      button.parentNode.replaceChild(newButton, button);
      
      // Add fresh event listener
      newButton.addEventListener('click', function(e) {
        e.preventDefault();
        const state = this.dataset.buttonState;
        const code = this.dataset.discountCode || this.dataset.code;
        
        if (state === 'invalid') {
          return; // Don't process invalid buttons
        }
        
        if (window.applyDiscountCode) {
          const discountCode = state === "apply" ? code : "";
          const currentCode = state === "remove" ? code : "";
          window.applyDiscountCode(discountCode, this, currentCode);
        }
      });
    });

    // Re-initialize manual input handler
    const manualApplyBtn = document.querySelector('#manualCouponInput + .apply-discount-button');
    if (manualApplyBtn) {
      const newManualBtn = manualApplyBtn.cloneNode(true);
      manualApplyBtn.parentNode.replaceChild(newManualBtn, manualApplyBtn);
      
      newManualBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const manualInput = document.getElementById('manualCouponInput');
        const code = manualInput ? manualInput.value.trim() : '';
        
        if (code && window.applyDiscountCode) {
          const state = this.dataset.buttonState;
          const discountCode = state === "apply" ? code : "";
          const currentCode = state === "remove" ? code : "";
          window.applyDiscountCode(discountCode, this, currentCode);
        }
      });
    }

    console.log('Re-initialized event handlers');
  }

  // Force refresh function that can be called externally
  window.forceRefreshDiscountSystem = function() {
    console.log('Force refreshing discount system...');
    refreshCompleteDiscountSystem();
  };

  // Enhanced cart update detection with mutation observer
  function setupEnhancedCartDetection() {
    // Watch for cart drawer updates
    const cartDrawer = document.querySelector('#CartDrawer, .cart-drawer, [data-cart-drawer]');
    if (cartDrawer) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
            console.log('Cart drawer updated, refreshing discount system...');
            setTimeout(() => {
              refreshCompleteDiscountSystem();
            }, config.refreshDelay);
          }
        });
      });
      
      observer.observe(cartDrawer, {
        childList: true,
        subtree: true
      });
    }

    // Watch for quantity input changes
    const quantityInputs = document.querySelectorAll('input[name="quantity"], input[data-quantity-input]');
    quantityInputs.forEach(input => {
      input.addEventListener('change', () => {
        console.log('Quantity changed, will refresh discount system after cart update...');
      });
    });
  }

  // Initialize on DOM ready
  function initializeDiscountRefreshSystem() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        setupEnhancedCartDetection();
        console.log('Discount refresh system initialized');
      });
    } else {
      setupEnhancedCartDetection();
      console.log('Discount refresh system initialized');
    }
  }

  // Start the system
  initializeDiscountRefreshSystem();

  // Expose key functions globally for debugging
  window.discountRefreshSystem = {
    refresh: refreshCompleteDiscountSystem,
    getCurrentDiscount: getCurrentAppliedDiscount,
    validateCoupon: validateCouponForCart,
    getCartData: window.cartDiscountData,
    isRefreshing: () => refreshInProgress
  };

})();
</script>
