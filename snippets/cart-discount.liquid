	<script>
	// Discount cap helper - waits for order-summary.liquid to define globals
	function capAwareDiscount(cart) {
	  if (window.getCappedDiscount) {
    return window.getCappedDiscount(cart);
  }
  if (window.shouldCapDiscount && window.shouldCapDiscount(cart)) {
    return window.DISCOUNT_CAP_CENTS;
  }
  return cart.total_discount;
}
function capAwareTotal(cart) {
  if (window.getCappedTotal) {
    return window.getCappedTotal(cart);
  }
  if (window.shouldCapDiscount && window.shouldCapDiscount(cart)) {
    const excess = cart.total_discount - window.DISCOUNT_CAP_CENTS;
    return cart.total_price + excess;
  }
  return cart.total_price;
	}

	// Open & Close Modal
	function openCouponModal() {
	  const modal = document.getElementById('coupon-modal');
	  if (modal) modal.classList.add('open');
	}
	 
	function closeCouponModal() {
	  const modal = document.getElementById('coupon-modal');
	  if (modal) modal.classList.remove('open');
	}

// Function to update discount display UI
function updateDiscountDisplayUI(appliedCode = '') {
  const viewAllBtn = document.querySelector('.view-all-coupons-btn');
  const appliedCouponsBtn = document.querySelector('.applied-coupons-btn');
  const appliedCurrentCoupon = document.querySelector('.applied_current_coupen');

  // Store the current state to prevent unnecessary updates
  const currentAppliedCode = appliedCurrentCoupon ? appliedCurrentCoupon.textContent.trim() : '';
    
  if (appliedCode && appliedCode.trim() !== '') {
    // Show applied coupon UI 
    
    if (viewAllBtn) {
      viewAllBtn.style.setProperty('display', 'none', 'important');
      viewAllBtn.style.visibility = 'hidden';
     // console.log('Hidden view-all-coupons-btn with !important');
    }
    
    if (appliedCouponsBtn) {
      appliedCouponsBtn.style.setProperty('display', 'flex', 'important');
      appliedCouponsBtn.style.visibility = 'visible';
      appliedCouponsBtn.style.opacity = '1';
     // console.log('Showed applied-coupons-btn with !important');
      
      // Also check computed styles
      const computedStyle = window.getComputedStyle(appliedCouponsBtn); 
    }
    
    if (appliedCurrentCoupon) {
      appliedCurrentCoupon.textContent = appliedCode;
      //console.log('Set applied_current_coupen text to:', appliedCode);
    }
  } else {
    // Hide applied coupon UI 
    if (viewAllBtn) {
      viewAllBtn.style.setProperty('display', 'flex', 'important');
      viewAllBtn.style.setProperty('visibility', 'visible', 'important');
      viewAllBtn.style.setProperty('opacity', '1', 'important');
      //console.log('Showed view-all-coupons-btn with !important');
    }
    
    if (appliedCouponsBtn) {
      appliedCouponsBtn.style.setProperty('display', 'none', 'important');
      appliedCouponsBtn.style.visibility = 'hidden';
     // console.log('Hidden applied-coupons-btn with !important');
    }  
    
    if (appliedCurrentCoupon) {
      appliedCurrentCoupon.textContent = '';
     // console.log('Cleared applied_current_coupen text');
    }  
  }
  
  // Force a visual update to ensure changes are applied
  if (appliedCouponsBtn) {
    appliedCouponsBtn.offsetHeight; // Force reflow
  }
  if (viewAllBtn) {
    viewAllBtn.offsetHeight; // Force reflow
  }
  
  // Additional check after update
  setTimeout(() => {
    if (appliedCode && appliedCode.trim() !== '') {
      const isAppliedVisible = appliedCouponsBtn && window.getComputedStyle(appliedCouponsBtn).display !== 'none';
      const isViewAllHidden = viewAllBtn && window.getComputedStyle(viewAllBtn).display === 'none'; 
      
      if (!isAppliedVisible || !isViewAllHidden) { 
        if (appliedCouponsBtn) {
          appliedCouponsBtn.style.setProperty('display', 'flex', 'important');
          appliedCouponsBtn.classList.add('force-show');
        }
        if (viewAllBtn) {
          viewAllBtn.style.setProperty('display', 'none', 'important');
          viewAllBtn.classList.add('force-hide');
        }
      }
    }
  }, 100); 
	}

	function syncCouponCardState(buttonEl) {
	  const cardEl = buttonEl?.closest?.('.coupon-card');
	  if (!cardEl) return;
	  cardEl.classList.toggle('is-applied', buttonEl.dataset.buttonState === 'remove');
	}
	
	// Function to handle remove coupon click
	function handleRemoveCoupon() {
  // Find the currently applied discount and remove it
  const appliedCurrentCoupon = document.querySelector('.applied_current_coupen');
  
  if (appliedCurrentCoupon && appliedCurrentCoupon.textContent.trim() !== '') {
    const appliedCode = appliedCurrentCoupon.textContent.trim();
    
    // Find the corresponding discount button and trigger remove
    const discountButtons = document.querySelectorAll('.apply-discount-button');
    let foundButton = null;
    
    discountButtons.forEach(btn => {
      if (btn.dataset.discountCode && btn.dataset.discountCode.toUpperCase() === appliedCode.toUpperCase()) {
        foundButton = btn;
      }
    });
    
    if (foundButton) {
      // Trigger the remove action
      if (window.applyDiscountCode) {
        window.applyDiscountCode("", foundButton, appliedCode);
        updateDiscountDisplayUI('');
      } else {
        //console.error('applyDiscountCode function not available');
      }
    } else {
      // If button not found, just remove via API
      if (window.applyDiscountCode) {
        window.applyDiscountCode("", null, appliedCode);
      } else {
        //console.error('applyDiscountCode function not available');
      }
    }
    
    // Immediately update the UI to show loading state
    updateDiscountDisplayUI('');
  }
}

// Add click event listener for remove coupon button
document.addEventListener('click', function(e) {
  if (e.target.classList.contains('remove_coupens')) {
    e.preventDefault();
    handleRemoveCoupon();
  }
});

// Discount HTML show JS
window.addEventListener('load', function () {
  const discountLabelEl = document.getElementById('discount-label');
  const discountRowEl = discountLabelEl?.closest('.price-row.discount');

  if (discountLabelEl && discountRowEl) {
    if (discountLabelEl.textContent.trim() === '') {
      discountRowEl.style.display = 'none';
    } else {
      discountRowEl.style.display = '';
    }
  }

  const applyButtons = document.querySelectorAll('.apply-discount-button');
  applyButtons.forEach(button => {
    button.addEventListener('click', () => {
      if (discountRowEl) {
        discountRowEl.style.display = '';
      }
    });
  });
});

