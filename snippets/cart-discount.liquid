  {% assign cart_total = 0 %}
  {% assign cart_quantity = 0 %}
  {% assign cart_collections = "" %}

  {% for item in cart.items %}
    {% assign cart_total = cart_total | plus: item.final_line_price %}
    {% assign cart_quantity = cart_quantity | plus: item.quantity %}

    {%- for col in item.product.collections -%}
      {% unless cart_collections contains col.id %}
        {% assign cart_collections = cart_collections | append: col.id | append: "," %}
      {% endunless %}
    {%- endfor -%}
  {% endfor %}

		  <div class="available-coupons-wrapper coupon-redesign">
