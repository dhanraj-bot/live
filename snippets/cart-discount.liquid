		        <input type="text" placeholder="Enter Code" id="manualCouponInput" />
		        <button class="apply-manual apply-discount-button"
		          data-discount-code=""
		          data-button-state="apply"
		          data-code=""
		          data-min-quantity="0"
		          data-min-value="0">
		          Apply
		        </button>
		      </div>

          <div class="view-all-wrapper">
          <button class="view-all-coupons-btn" onclick="openCouponModal()">
            {% comment %} <img src="https://cdn.shopify.com/s/files/1/0750/2685/8234/files/discount.avif?v=1754489453" alt="discount" width="" height=""> {% endcomment %}
             {% render 'icon-offer' %}
             <p class="no-coupon-text">No coupon applied</p>
          </button>
          <div class="applied-coupons-btn">
            <span class="applied_current_coupen"></span>Applied
            <span class="remove_coupens" onclick="removeDiscountCode(this, 'COUPONCODE')">{% render 'icon-cross' %}</span>
          </div>
        </div>

		      <div class="coupon-list">
		    {% for block in section.blocks %}
		      {% if block.type == 'discount_coupon' %}
	        {% assign show_to_customer = true %}
        {% if block.settings.customer_tag != blank %}
          {% assign show_to_customer = false %}
          {% if customer %}
            {% for tag in customer.tags %}
              {% if tag == block.settings.customer_tag %}
                {% assign show_to_customer = true %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endif %}
        {% if show_to_customer %}
        {% assign disable_coupon = false %}

        {%- comment -%} Quantity Validation {%- endcomment -%}
        {% if block.settings.min_quantity > 0 and cart_quantity < block.settings.min_quantity %}
          {% assign disable_coupon = true %}
        {% endif %}

        {%- comment -%} Value Validation (cart_total is in cents, so divide by 100) {%- endcomment -%}
        {% assign cart_total_money = cart_total | divided_by: 100 %}
        {% if block.settings.min_value > 0 and cart_total_money < block.settings.min_value %}
          {% assign disable_coupon = true %}
        {% endif %}

        {%- comment -%} Collection Validation {%- endcomment -%}
        {% if block.settings.eligible_collections != blank %}
          {% assign valid_collection = false %}
          {% for selected_col in block.settings.eligible_collections %}
            {% if cart_collections contains selected_col.id %}
              {% assign valid_collection = true %}
            {% endif %}
          {% endfor %}
          {% unless valid_collection %}
            {% assign disable_coupon = true %}
          {% endunless %}
        {% endif %}

	        <div class="coupon-card {% if disable_coupon %}disable{% endif %}">
	          <div class="coupon-card__left">
	            <span class="coupon-card__icon" aria-hidden="true">{% render 'icon-offer' %}</span>
	            <div class="coupon-details">
	              <strong>{{ block.settings.code }}</strong>
	              <p>{{ block.settings.description }}</p>
	            </div>
	          </div>
	          <button 
	            class="apply-btn apply-discount-button{% if disable_coupon %} disable-invalid{% endif %}"
	            data-discount-code="{{ block.settings.code }}"
	            data-button-state="apply"
            data-code="{{ block.settings.code }}"
            data-min-quantity="{{ block.settings.min_quantity }}"
            data-min-value="{{ block.settings.min_value }}"
            {% if disable_coupon %}disabled{% endif %}
          >
          {% if disable_coupon %}
            Invalid
          {% else %}
            Apply
          {% endif %}
          </button>   
          <div class="discount_errormessage">Discount is not valid to the current cart</div>
        </div>
	        {% endif %}
	      {% endif %}
	    {% endfor %}
