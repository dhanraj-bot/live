    // Get current applied discount from GraphQL (source of truth)
    let activeCode = window.currentAppliedDiscountCode || '';

    if (!activeCode) {
      try {
        const cartData = window.CartDataManager
          ? await window.CartDataManager.getCart()
          : await fetch('/cart.js').then(r => r.json());

        const cartToken = cartData.token;

