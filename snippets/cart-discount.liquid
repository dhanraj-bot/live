  function updateButtonState(btn, state) {
    // Check if button has the disable-invalid class directly
    const wasOriginallyDisabled = btn.classList.contains('disable-invalid');
    
    if (state === "remove") {
      btn.textContent = "Remove";
      btn.dataset.buttonState = "remove";
      btn.disabled = false;
      btn.style.opacity = "1";
      btn.title = "";
    } else if (wasOriginallyDisabled) {
      // Keep the original disabled state
      btn.textContent = "Invalid";
      btn.dataset.buttonState = "invalid";
      btn.disabled = true;
      btn.style.opacity = "0.5";
      btn.title = "Discount is not valid to the current cart";
    } else {
      btn.textContent = "Apply";
      btn.dataset.buttonState = "apply";
      btn.disabled = false;
      btn.style.opacity = "1";
      btn.title = "";
    }
  }

  // Reusable: refresh discount/totals UI from current cart state
  function updateDiscountSummaryFromCart(cart) {
    const format = (amount) => `₹${(amount / 100).toFixed(0)}`;
    
    // Check for both discount_applications and total_discount
    const discountApp = cart.discount_applications?.[0];
    const appliedTitle = discountApp?.title || '';
    const appliedCode = discountApp?.code || '';
    const storedCode = window.currentAppliedDiscountCode || '';
    const hasDiscount = cart.total_discount > 0 || (discountApp && discountApp.amount > 0);

    // Update order summary elements with correct selectors
    const subtotalEl = document.querySelector('.wk-order-summary .subtotal-amount');
    const discountRowEl = document.querySelector('.wk-order-summary .price-row.discount');
    const discountLabelEl = document.getElementById('discount-label');
    const discountAmountEl = document.getElementById('discount-amount');
    const totalEl = document.querySelector('.wk-order-summary .total-amount');
    const taxEl = document.querySelector('.wk-order-summary .tax-amount');

    // Update total (adjusted for discount cap)
    if (totalEl) {
      totalEl.textContent = format(capAwareTotal(cart));
    }

    // Update tax
    if (taxEl) {
      if (cart.total_tax > 0) {
        taxEl.textContent = format(cart.total_tax);
      } else {
        taxEl.textContent = 'Included';
      }
    }

    // Update discount section (label text stays as default "(Discount)")
    if (discountRowEl) {
      if (hasDiscount) {
        if (discountLabelEl) {
          discountLabelEl.textContent = '(Discount)';
        }
        if (discountAmountEl) {
          const cappedDiscount = capAwareDiscount(cart);
          discountAmountEl.textContent = `-${format(cappedDiscount)}`;
        }

        discountRowEl.style.display = 'flex';

        const codeToShow = storedCode || appliedCode || appliedTitle || 'DISCOUNT';
        updateDiscountDisplayUI(codeToShow);

      } else {
        discountRowEl.style.display = 'none';
        updateDiscountDisplayUI('');
      }
    }

    const discountList = document.querySelector('.discounts');
    if (discountList) {
      discountList.innerHTML = '';
      if (cart.total_discount > 0) {
        const cappedDiscountForList = capAwareDiscount(cart);
        discountList.innerHTML = `
          <li class="discount text-sm flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-discount icon--extra-small" viewBox="0 0 14 15" fill="none">
              <path d="..." stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="..." fill="currentColor"/>
            </svg>
            <span>${appliedTitle} ${appliedCode ? `– ${appliedCode}` : ''}</span>
            <span class="font-body-bold">(-${format(cappedDiscountForList)})</span>
          </li>
        `;
      }
    }

    const bottomTotalEl = document.querySelector('.totals__subtotal-value');
    if (bottomTotalEl) bottomTotalEl.textContent = format(capAwareTotal(cart));
  }

