{%- liquid
  assign menu_columns = block.settings.menu_columns
  assign promotions_width = block.settings.promotions_width
  assign promotion_columns = block.settings.promotion_columns
  case block.type
    when 'promotion_banner'
      assign promo_images = block.settings.promo_image_1 | append: ',' | append: block.settings.promo_image_2 | append: ',' | append: block.settings.promo_image_3 | append: ',' | append: block.settings.promo_image_4 | append: ',' | append: block.settings.promo_image_5
      assign has_promo = false
      unless promo_images == ',,,,'
        assign has_promo = true
      endunless
    when 'custom_card'
      assign promo_images = block.settings.promo_image_1 | append: ',' | append: block.settings.promo_image_2 | append: ',' | append: block.settings.promo_image_3 | append: ',' | append: block.settings.promo_image_4 | append: ',' | append: block.settings.promo_image_5
      assign has_promo = false
      unless promo_images == ',,,,'
        assign has_promo = true
      endunless
    when 'product_list'
      assign collections = block.settings.collections
      assign product_list = block.settings.product_list
      assign show_menu_column_divider = block.settings.show_menu_column_divider
      assign heading = block.settings.heading
      assign number_of_columns = block.settings.number_of_columns
      assign promotion_columns = number_of_columns
  endcase

  assign use_top_searches_products_layout = false
  if block.type == 'product_list' and block.settings.dropdown_layout == 'top_searches_products'
    assign use_top_searches_products_layout = true
  endif
-%}

{% style %}
  #Mega-menu-item-{{ block.id }} {
    --menu-columns: {{ menu_columns }};
    --promotions-width: {{ promotions_width }}%;
    --promotion-columns: {{ promotion_columns }};
  }
{% endstyle %}
<details
  id="Mega-menu-item-{{ block.id }}"
  is="details-mega"
  trigger="{{ section.settings.menu_trigger }}"
  level="top"
  {{ block.shopify_attributes }}
>
  <summary data-link="{{ link.url }}" class="z-2 font-navigation">
    <span class="menu__item flex items-center relative">
      <span class="reversed-link flex items-center">
        {{- link.title | escape }}
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9.75 4.5L6 8.25L2.25 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </span>
  </summary>
  <div class="mega-menu v-scrollable">
    <div class="mega-menu__container">
      <div class="mega-menu__wrapper">
        {%- if link.links != blank and use_top_searches_products_layout == false -%}
          <div class="mega-menu__list">
            {%- if collections != blank and block.type == 'product_list' -%}
              <div class="mega-menu__item">
                <ul role="list" class="grid gap-3">
                  {%- for collection in collections -%}
                    <li>
                      <a href="{{ collection.url }}" class="h3 reversed-link font-heading">
                        {{- collection.title | escape -}}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
            {%- for childlink in link.links -%}
              <div class="mega-menu__item">
                {%- if show_menu_column_divider -%}
                  <div class="mega-menu__item-wrapper">
                {%- endif -%}

                {%- assign child_image = null -%}
                {% comment %}
                  {%- if childlink.object and childlink.object.image -%}
                  {%- assign child_image = childlink.object.image -%}
                {% endcomment %}
                {%- if childlink.object and childlink.object.products and childlink.object.products[3] -%}
                  {%- assign child_image = childlink.object.products[3].featured_image -%}
                {%- endif -%}

                <div class="flex items-center gap-3 mb-2 childmenu_menuimage">
                  {%- if child_image != blank -%}
                    {{
                      child_image
                      | image_url: width: 80
                      | image_tag: alt: childlink.title, class: 'w-12 h-12', loading: 'lazy'
                    }}
                  {%- endif -%}
                  <a href="{{ childlink.url }}" class="mega-menu__link mega-menu__link--top">
                    {{- childlink.title | escape -}}
                  </a>
                </div>

                {%- if childlink.links != blank -%}
                  <ul class="mega-menu__item-child childmenu_menuimage">
                    {%- for grandchildlink in childlink.links -%}
                      {%- assign grand_image = null -%}
                      {% comment %}
                        {%- if grandchildlink.object and grandchildlink.object.image -%}
                        {%- assign grand_image = grandchildlink.object.image -%}
                      {% endcomment %}
                      {%- if grandchildlink.object
                        and grandchildlink.object.products
                        and grandchildlink.object.products[3]
                      -%}
                        {%- assign grand_image = grandchildlink.object.products[3].featured_image -%}
                      {%- endif -%}

                      <li class="flex items-center gap-2 my-1">
                        {%- if grand_image -%}
                          {{
                            grand_image
                            | image_url: width: 80
                            | image_tag: alt: grandchildlink.title, class: 'w-10 h-10', loading: 'lazy'
                          }}
                        {%- endif -%}
                        <a href="{{ grandchildlink.url }}" class="reversed-link mega-menu__link">
                          {{- grandchildlink.title | escape -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

                {%- if show_menu_column_divider -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- case block.type -%}
          {%- when 'promotion_banner' -%}
            {%- if has_promo -%}
              <div class="mega-menu__promotions mega-menu__promotions-grid">
                {%- for i in (1..5) -%}
                  {%- liquid
                    assign __promo_image = 'promo_image_' | append: i
                    assign __color_scheme = 'color_scheme_' | append: i
                    assign __heading = 'heading_' | append: i
                    assign __subheading = 'subheading_' | append: i
                    assign __heading_size = 'heading_size_' | append: i
                    assign __description = 'description_' | append: i
                    assign __button_label = 'button_label_' | append: i
                    assign __button_style = 'button_style_' | append: i
                    assign __content_position = 'content_position_' | append: i
                    assign __content_alignment = 'content_alignment_' | append: i
                    assign __promotion_link = 'promotion_link_' | append: i

                    assign promo_image = block.settings[__promo_image]
                    assign color_scheme = block.settings[__color_scheme]
                    assign heading = block.settings[__heading]
                    assign subheading = block.settings[__subheading]
                    assign heading_size = block.settings[__heading_size]
                    assign description = block.settings[__description]
                    assign button_label = block.settings[__button_label]
                    assign button_style = block.settings[__button_style]
                    assign content_position = block.settings[__content_position]
                    assign content_alignment = block.settings[__content_alignment]
                    assign promotion_link = block.settings[__promotion_link]

                    if promo_image == blank
                      continue
                    endif
                  -%}
                  <div class="promotion-item" style="--index: {{ forloop.index }};">
                    {% render 'card-image',
                      image: promo_image,
                      image_ratio: 'adapt',
                      color_scheme: color_scheme,
                      heading: heading,
                      heading_size: heading_size,
                      description: description,
                      button_label: button_label,
                      button_style: button_style,
                      content_position: content_position,
                      content_alignment: content_alignment,
                      link: promotion_link,
                      subheading: subheading
                    %}
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- when 'custom_card' -%}
            {%- if has_promo -%}
              <div class="mega-menu__promotions mega-menu__promotions-grid">
                {%- for i in (1..5) -%}
                  {%- liquid
                    assign __promo_image = 'promo_image_' | append: i
                    assign __heading = 'heading_' | append: i
                    assign __heading_size = 'heading_size_' | append: i
                    assign __description = 'description_' | append: i
                    assign __button_style = 'button_style_' | append: i
                    assign __promotion_link = 'promotion_link_' | append: i

                    assign promo_image = block.settings[__promo_image]
                    assign heading = block.settings[__heading]
                    assign heading_size = block.settings[__heading_size]
                    assign description = block.settings[__description]
                    assign promotion_link = block.settings[__promotion_link]

                    if promo_image == blank
                      continue
                    endif
                  -%}
                  <div class="promotion-item" style="--index: {{ forloop.index }};">
                    {% render 'mega-custom-card',
                      heading: heading,
                      heading_size: heading_size,
                      description: description,
                      image: promo_image,
                      link: promotion_link
                    %}
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- when 'product_list' -%}
            {%- liquid
              assign is_carousel = false
              if product_list.count > number_of_columns
                assign is_carousel = true
              endif

              assign left_heading = block.settings.left_menu_heading | default: 'Top Searches'
              assign products_heading = heading
              if products_heading == blank
                assign products_heading = 'Trending Products'
              endif
            -%}
            {%- if use_top_searches_products_layout -%}
              <div class="mega-menu__split-layout">
                <div class="mega-menu__split-links">
                  <h2 class="h5 mega-menu__split-heading">{{ left_heading | escape }}</h2>
                  {%- if link.links != blank -%}
                    <ul role="list" class="mega-menu__split-links-list">
                      {%- for childlink in link.links -%}
                        <li class="flex items-center justify-between">
                          <a href="{{ childlink.url }}" class="reversed-link mega-menu__split-link">
                            {{- childlink.title | escape -}}
                          </a>
                          {%- if forloop.index <= 2 -%}
                            {% render 'icon-trendup' %}
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
                {%- if product_list != blank -%}
                  <div class="mega-menu__split-products">
                    <div class="block w-full">
                      <div class="mega-menu__product-list--header flex items-center justify-between">
                        <h2 class="h5">{{ products_heading | escape }}</h2>
                      </div>
                      <div
                        class="mega-menu__promotions-grid"
                        style="--promotion-columns: 3; grid-template-columns: repeat(3, minmax(0, 1fr));"
                      >
                        {%- for product in product_list -%}
                          <div class="promotion-item promotion-item--product" style="--index: {{ forloop.index }}; max-width: 146px;">
                            <div class="header-dropdown-product">
                              {%- render 'card-product',
                                product: product,
                                enable_quick_view: false,
                                enable_quick_add: false,
                                hide_similar_icon: true
                              -%}
                            </div>
                          </div>
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- elsif product_list != blank -%}
              <div class="mega-menu__promotions">
                <menu-product-list class="block w-full" data-columns="{{ number_of_columns }}">
                  {%- if heading != blank -%}
                    <div
                      class="mega-menu__product-list--header flex items-center justify-between promotion-item--product"
                      style="--index: 1;"
                    >
                      <h2 class="h4 promotion-item">{{ heading | escape }}</h2>
                      {%- if is_carousel -%}
                        <div class="slider-controls promotion-item slider-controls--fraction-group">
                          <button
                            class="swiper-button-prev"
                            name="previous"
                            aria-label="{{ 'general.slider.previous_slide' | t }}"
                          >
                            {%- render 'icon-slider-prev', size: 'small' -%}
                          </button>
                          <div class="swiper-pagination"></div>
                          <button
                            class="swiper-button-next"
                            name="next"
                            aria-label="{{ 'general.slider.next_slide' | t }}"
                          >
                            {%- render 'icon-slider-next', size: 'small' -%}
                          </button>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if is_carousel -%}
                    <div class="swiper swiper-equal-height">
                  {%- endif -%}
                  <div class="{% if is_carousel %}swiper-wrapper{% else %}mega-menu__promotions-grid{% endif %}">
                    {%- for product in product_list -%}
                      <div
                        class="swiper-slide promotion-item promotion-item--product"
                        style="--index: {{ forloop.index }};"
                      >
                        {%- render 'card-product',
                          product: product,
                          enable_quick_view: false,
                          enable_quick_add: false
                        -%}
                      </div>
                    {%- endfor -%}
                  </div>
                  {%- if is_carousel -%}
                    </div>
                  {%- endif -%}
                </menu-product-list>
              </div>
            {%- endif -%}
        {%- endcase -%}
      </div>
    </div>
  </div>
</details>
