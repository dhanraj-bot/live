<style>
.bmlp-wrapper {
  border: 1px solid #E6E6E6;
  padding: 16px;
  margin-bottom: 0px;
  background: #fff;
}

.bmlp-title {
  font-size: 18px;
  font-weight: 500;
  color: #333;
  margin-bottom: 15px;
  line-height: normal;
}

.bmlp-offers-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.bmlp-offer-card {
  background: #F0F9F6;
  padding: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: #606060;
}

.bmlp-offer-icon {
  flex-shrink: 0;
  width: 20%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 8px;
}

.bmlp-offer-icon img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.bmlp-offer-icon svg {
  width: 20px;
  height: 20px;
  fill: #fff;
}

.bmlp-offer-content {
  flex: 1;
  width: 80%;
}

.bmlp-offer-main-text {
  font-size: 15px;
  font-weight: 500;
  line-height: 1.3;
  margin-bottom: 2px;
  color: #009662;
}

.bmlp-offer-sub-text {
  font-size: 11px;
  font-weight: 400;
  line-height: 1.3;
}
.bmlp-wrapper.mobile_view_only {
    display: none;
}
.bmlp-wrapper.desktop_view_only {
    display: none;
}

@media screen and (max-width: 767px) {
  .bmlp-wrapper.desktop_view_only {
    display: none;
  }
  .bmlp-wrapper.mobile_view_only {
    display: none;
  }
  .bmlp-offer-icon {
    width: 15%;
  }
  .bmlp-offer-content {
    width: 85%;
  }
}

@media screen and (max-width: 576px) {
  .bmlp-offers-grid {
    grid-template-columns: 1fr;
  }
  .bmlp-offer-card {
    padding: 10px 12px;
  }
  .bmlp-offer-main-text {
    font-size: 14px;
  }
  .bmlp-offer-sub-text {
    font-size: 11px;
  }
  .bmlp-title {
    font-size: 16px;
  }
}
</style>

{% if section.settings.bmlp_enable %}
<div class="bmlp-wrapper {{ class }}">
  {% if section.settings.bmlp_title != blank %}
    <div class="bmlp-title">{{ section.settings.bmlp_title }}</div>
  {% endif %}

  <div class="bmlp-offers-grid">
    {%- comment -%} Offer 1 {%- endcomment -%}
    {% if section.settings.bmlp_offer1_main_text != blank %}
      <div class="bmlp-offer-card">
        <div class="bmlp-offer-icon">
          {% if section.settings.bmlp_offer1_icon != blank %}
            <img
              src="{{ section.settings.bmlp_offer1_icon | image_url: width: 48 }}" 
              alt="{{ section.settings.bmlp_offer1_main_text | escape }}"
              width="24"
              height="24"
              loading="lazy"
            >
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 7h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v3H4c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zM10 4h4v3h-4V4zm10 16H4V9h16v11z"/>
              <path d="M12 12c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          {% endif %}
        </div>
        <div class="bmlp-offer-content">
          <div class="bmlp-offer-main-text">{{ section.settings.bmlp_offer1_main_text }}</div>
          {% if section.settings.bmlp_offer1_sub_text != blank %}
            <div class="bmlp-offer-sub-text">{{ section.settings.bmlp_offer1_sub_text }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {%- comment -%} Offer 2 {%- endcomment -%}
    {% if section.settings.bmlp_offer2_main_text != blank %}
      <div class="bmlp-offer-card">
        <div class="bmlp-offer-icon">
          {% if section.settings.bmlp_offer2_icon != blank %}
            <img 
              src="{{ section.settings.bmlp_offer2_icon | image_url: width: 48 }}" 
              alt="{{ section.settings.bmlp_offer2_main_text | escape }}"
              width="24"
              height="24"
              loading="lazy"
            >
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 7h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v3H4c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zM10 4h4v3h-4V4zm10 16H4V9h16v11z"/>
              <path d="M12 12c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          {% endif %}
        </div>
        <div class="bmlp-offer-content">
          <div class="bmlp-offer-main-text">{{ section.settings.bmlp_offer2_main_text }}</div>
          {% if section.settings.bmlp_offer2_sub_text != blank %}
            <div class="bmlp-offer-sub-text">{{ section.settings.bmlp_offer2_sub_text }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {%- comment -%} Offer 3 (Optional) {%- endcomment -%}
    {% if section.settings.bmlp_offer3_main_text != blank %}
      <div class="bmlp-offer-card">
        <div class="bmlp-offer-icon">
          {% if section.settings.bmlp_offer3_icon != blank %}
            <img 
              src="{{ section.settings.bmlp_offer3_icon | image_url: width: 48 }}" 
              alt="{{ section.settings.bmlp_offer3_main_text | escape }}"
              width="24"
              height="24"
              loading="lazy"
            >
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 7h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v3H4c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zM10 4h4v3h-4V4zm10 16H4V9h16v11z"/>
              <path d="M12 12c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          {% endif %}
        </div>
        <div class="bmlp-offer-content">
          <div class="bmlp-offer-main-text">{{ section.settings.bmlp_offer3_main_text }}</div>
          {% if section.settings.bmlp_offer3_sub_text != blank %}
            <div class="bmlp-offer-sub-text">{{ section.settings.bmlp_offer3_sub_text }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {%- comment -%} Offer 4 (Optional) {%- endcomment -%}
    {% if section.settings.bmlp_offer4_main_text != blank %}
      <div class="bmlp-offer-card">
        <div class="bmlp-offer-icon">
          {% if section.settings.bmlp_offer4_icon != blank %}
            <img 
              src="{{ section.settings.bmlp_offer4_icon | image_url: width: 48 }}" 
              alt="{{ section.settings.bmlp_offer4_main_text | escape }}"
              width="24"
              height="24"
              loading="lazy"
            >
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 7h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v3H4c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zM10 4h4v3h-4V4zm10 16H4V9h16v11z"/>
              <path d="M12 12c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          {% endif %}
        </div>
        <div class="bmlp-offer-content">
          <div class="bmlp-offer-main-text">{{ section.settings.bmlp_offer4_main_text }}</div>
          {% if section.settings.bmlp_offer4_sub_text != blank %}
            <div class="bmlp-offer-sub-text">{{ section.settings.bmlp_offer4_sub_text }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
{% endif %}