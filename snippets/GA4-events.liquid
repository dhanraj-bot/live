// ADD MONEY CLICK
(function waitForAddMoneyButton() {
const addMoneyBtn = document.querySelector('.wk_add_money_btn.add_money');
const amountInput = document.querySelector('#wk_money_input');

if (addMoneyBtn && amountInput) {
  const pageType = '{{ template | handleize }}';
  const userID   = '{{ customer.id | default: "guest" }}';
  const userType = '{{ customer.tags | join: "," | default: "guest" }}';

  addMoneyBtn.addEventListener('click', function () {
    const walletAmount = parseFloat(amountInput.value);

    if (!walletAmount || walletAmount <= 0) {
   //   console.warn('❌ Invalid wallet amount. GA4 event not fired.');
      return;
    }

    gtag('event', 'add_money_click', {
      cta_text: 'add_money',
      section_name: 'My Wallet',
      wallet_amount: walletAmount,
      page_type: pageType,
      userID: userID,
      user_type: userType
    });

  //  console.log('✅ GA4 Event Sent: add_money_click → ₹' + walletAmount);
  });

 // console.log('✅ Add Money Button listener attached');
} else {
  // Try again after 500ms
  setTimeout(waitForAddMoneyButton, 500);
}
})();
// ADD MONEY CLICK

// ACCOUNT INTERACTION 
document.addEventListener('DOMContentLoaded', function () {
  const pageType = '{{ template | handleize }}';
  const userID = '{{ customer.id | default: "guest" }}';
  const userType = '{{ customer.tags | join: "," | default: "guest" }}';

  // Function to send GA4 account interaction event
  function sendAccountInteraction(tabName) {
