// FILTER INTEGRACTION 
document.querySelector('.face-form')?.addEventListener('change', function () {
  const pageType = '{{ template | handleize }}';
  const userID = '{{ customer.id | default: "guest" }}';
  const userType = '{{ customer.tags | join: "," | default: "guest" }}';

  const priceMinInput = document.querySelector('input[name="filter.v.price.gte"]');
  const priceMaxInput = document.querySelector('input[name="filter.v.price.lte"]');

  const priceMin = priceMinInput?.value || "0";
  const priceMax = priceMaxInput?.value || priceMaxInput?.getAttribute('max') || "0";

  const colorInputs = document.querySelectorAll('input[name="filter.v.t.shopify.color-pattern"]:checked');
  const sizeInputs = document.querySelectorAll('input[name="filter.v.t.shopify.size"]:checked');
  const sleeveInputs = document.querySelectorAll('input[name="filter.v.m.magento.sleeves"]:checked');

  const getLabelText = (input) => {
    const label = document.querySelector(`label[for="${input.id}"]`);
    if (!label) return '';
    return label.textContent.trim().split('(')[0].trim();
  };

  const getUniqueValues = (inputs) => {
    const values = Array.from(inputs).map(getLabelText);
    return [...new Set(values)];
  };

  const selectedColors = getUniqueValues(colorInputs);
  const selectedSizes = getUniqueValues(sizeInputs);
  const selectedSleeves = getUniqueValues(sleeveInputs);

  // Trigger gtag events individually for each selected filter
  selectedColors.forEach(value => {
    gtag('event', 'filter_interactions', {
      cta_text: value,
      section_name: 'color',
      page_type: pageType,
      userID: userID,
      user_type: userType
    });
  //  console.log('GA4 filter_interactions sent for color:', value);
  });

  selectedSizes.forEach(value => {
    gtag('event', 'filter_interactions', {
      cta_text: value,
      section_name: 'size',
      page_type: pageType,
      userID: userID,
      user_type: userType
    });
   // console.log('GA4 filter_interactions sent for size:', value);
  });

  selectedSleeves.forEach(value => {
    gtag('event', 'filter_interactions', {
      cta_text: value,
      section_name: 'sleeves',
      page_type: pageType,
      userID: userID,
      user_type: userType
    });
  //  console.log('GA4 filter_interactions sent for sleeves:', value);
  });

  // Send price range filter event
  if (priceMin !== "0" || priceMax !== "0") {
    const priceRange = `₹${priceMin} to ₹${priceMax}`;
    gtag('event', 'filter_interactions', {
      cta_text: priceRange,
      section_name: 'price',
      page_type: pageType,
      userID: userID,
      user_type: userType
    });
   // console.log('GA4 filter_interactions sent for price:', priceRange);
  }
});
// FILTER INTEGRACTION  

// Reset INTERACTION
document.addEventListener('DOMContentLoaded', function () {
  const pageType = '{{ template | handleize }}';
  const userID = '{{ customer.id | default: "guest" }}';
  const userType = '{{ customer.tags | join: "," | default: "guest" }}';

  function trackResetClick(event) {
    gtag('event', 'reset_interactions', {
      cta_text: 'reset',
      page_type: pageType,
      userID: userID,
      user_type: userType
    });
   // console.log('GA4 Event Sent: reset_interactions');
  }

  // Attach listener to ALL current reset links
  document.querySelectorAll('.facet-clear-all, .facet-remove').forEach(link => {
    link.addEventListener('click', trackResetClick);
  });

  // For dynamically loaded elements (AJAX filtering)
  const observer = new MutationObserver(() => {
    document.querySelectorAll('.facet-clear-all, .facet-remove').forEach(link => {
      if (!link.dataset.ga4Tracked) {
        link.dataset.ga4Tracked = 'true';
        link.addEventListener('click', trackResetClick);
      }
    });
  });

  observer.observe(document.body, { childList: true, subtree: true });
});
// Reset INTERACTION

