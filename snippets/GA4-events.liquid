<script>
// LOGO CLICK EVENT
document.addEventListener('DOMContentLoaded', function () {
  const logo = document.querySelector('.header__logo--image');

  if (logo) {
    logo.addEventListener('click', function () {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'logo_click',
        page_location: window.location.href,
        page_title: document.title,
        page_type: '{{ template }}',
        userID: '{{ customer.id }}',
        user_type: '{{ customer.tags | join: "," }}'
      });
    //  console.log("GA4 Event Sent: logo_click");
    });
  }
// LOGO CLICK EVENT
}); 

// TOP NAVIGATION CLICK
document.addEventListener("DOMContentLoaded", function () {
  const pageType = '{{ template | handleize }}';
  const userID = '{{ customer.id | default: "guest" }}';
  const userType = '{{ customer.tags | join: "," | default: "guest" }}';

  function pushTopNavClick(ctaText, category, selectType) {
    gtag('event', 'top_navigation_click', {
      cta_text: ctaText,
      category: category || "NA",
      select_type: selectType,
      page_type: pageType,
      userID: userID,
      user_type: userType
    });
    //console.log("GA4 Event Sent: top_navigation_click", { ctaText, category, selectType });
  }

  // Header nav summary clicks
  document.querySelectorAll('nav summary').forEach(summary => {
    summary.addEventListener('click', () => {
      const ctaText = summary.textContent.trim();
      pushTopNavClick(ctaText, ctaText, 'header');
    });
  });

  // Mega menu link clicks
  document.querySelectorAll('.mega-menu__link').forEach(link => {
    link.addEventListener('click', () => {
      const ctaText = link.textContent.trim();
      const details = link.closest('details');
      const summary = details?.querySelector('summary');
      const category = summary?.textContent.trim() || "NA";
      pushTopNavClick(ctaText, category, 'header');
    });
  });

  // Dropdown nav link clicks
  document.querySelectorAll('.dropdown__nav a').forEach(link => {
    link.addEventListener('click', () => {
      const ctaText = link.textContent.trim();
      const details = link.closest('details');
      const summary = details?.querySelector('summary');
      const category = summary?.textContent.trim() || "NA";
      pushTopNavClick(ctaText, category, 'header');
    });
  });

  // Mega menu details clicks
  document.querySelectorAll('details.details-mega a').forEach(link => {
    link.addEventListener('click', () => {
      const ctaText = link.textContent.trim();
      const details = link.closest('details.details-mega');
      const summary = details?.querySelector('summary');
      const category = summary?.textContent.trim() || "NA";
      pushTopNavClick(ctaText, category, 'header');
    });
  });

  // Main nav links (direct li > a)
  document.querySelectorAll('nav > ul.flex.flex-wrap > li > a').forEach(link => {
    link.addEventListener('click', () => {
      const ctaText = link.textContent.trim();
      pushTopNavClick(ctaText, 'NA', 'header');
    });
  });

  // Desktop account button
  const desktopAccountBtn = document.querySelector('a.account-button');
  if (desktopAccountBtn) {
    desktopAccountBtn.addEventListener("click", () => {
      const ctaText = desktopAccountBtn.textContent.trim() || "Account";
      pushTopNavClick(ctaText, "my_account_interaction", "header");
    });
  }

  // Hamburger menu toggle button
  const mobileMenu = document.querySelector('#MenuDrawer');
  const hamburgerBtn = document.querySelector('.menu-drawer-button');
  if (hamburgerBtn) {
    hamburgerBtn.addEventListener("click", () => {
      pushTopNavClick("hamburger_menu_toggle", "NA", "hamburger");
    });
  }

  // Hamburger direct links
  if (mobileMenu) {
    mobileMenu.querySelectorAll('a.menu-drawer__item-link').forEach(link => {
      if (!link.closest('details')) {
        link.addEventListener("click", () => {
          const ctaText = link.textContent.trim();
          pushTopNavClick(ctaText, "NA", "hamburger");
        });
      }
    });

    // Hamburger top-level nested links
    mobileMenu.querySelectorAll('details[level="top"] ul > li a').forEach(link => {
      link.addEventListener("click", () => {
        const ctaText = link.textContent.trim();
        const parent = link.closest('details[level="top"]');
        const summary = parent?.querySelector('summary');
        const category = summary ? summary.textContent.trim() : "NA";
        pushTopNavClick(ctaText, category, "hamburger");
      });
    });

    // Hamburger sub-level links
    mobileMenu.querySelectorAll('details[level="top"] details a').forEach(link => {
      link.addEventListener("click", () => {
        const ctaText = link.textContent.trim();
        const topLevel = link.closest('details[level="top"]');
        const summary = topLevel?.querySelector('summary');
        const category = summary ? summary.textContent.trim() : "NA";
        pushTopNavClick(ctaText, category, "hamburger");
      });
    });

    // ✅ NEW: Hamburger Account Button (inside #MenuDrawer)
    const mobileAccountBtn = mobileMenu.querySelector('a.account-button');
    if (mobileAccountBtn) {
      mobileAccountBtn.addEventListener("click", () => {
        const ctaText = mobileAccountBtn.textContent.trim() || "Account";
        pushTopNavClick(ctaText, "my_account_interaction", "hamburger");
      });
    }
  }

  // ✅ NEW: Top Bar Links (Track Order, Store Locator, Contact Us)
  document.querySelectorAll('.top-bar__links nav a').forEach(link => {
    link.addEventListener('click', () => {
      const ctaText = link.textContent.trim();
      pushTopNavClick(ctaText, "top_bar", "header");
    });
  });
});
// TOP NAVIGATION CLICK
  
