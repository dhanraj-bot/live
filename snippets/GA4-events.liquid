// CONTACT US INTERACTION
document.addEventListener('DOMContentLoaded', function () {
  const pageType = '{{ template | handleize }}';
  const userID = '{{ customer.id | default: "guest" }}';
  const userType = '{{ customer.tags | join: "," | default: "guest" }}';

  document.querySelectorAll('.cstm_contact a').forEach(link => {
    link.addEventListener('click', function () {
      let ctaText = '';

      const href = this.getAttribute('href');

      if (href.startsWith('tel:')) {
        ctaText = 'call_now';
      } else if (href.startsWith('https://wa.me')) {
        ctaText = 'chat_now';
      } else if (href.startsWith('mailto:')) {
        ctaText = 'email_now';
      }

      if (ctaText) {
        const eventData = {
          cta_text: ctaText,
          page_type: pageType,
          userID: userID,
          user_type: userType
        };

       // console.log('gtag event - contact_us_interaction:', eventData);
        gtag('event', 'contact_us_interaction', eventData);
      }
    });
  });
});
