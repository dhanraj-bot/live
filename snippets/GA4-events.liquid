            row.querySelector('.price')?.innerText.replace(/[^\d.]/g, '')
          ) || 0,
          quantity: parseInt(
            row.querySelector('input.quantity__input')?.value
          ) || 1,
          discount: 0
        }]
      };

      gtag('event', 'remove_from_cart', payload);
     // console.log('🗑️ GA4 remove_from_cart event fired:', payload);
 
