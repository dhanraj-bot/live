// SELECT ITEM 
document.addEventListener('DOMContentLoaded', function () {
  const productCards = document.querySelectorAll('.product-card');

  productCards.forEach((card, index) => {
    const productLink = card.querySelector('.product-card__title a');

    if (!productLink) return;

    productLink.addEventListener('click', function (e) {
      e.preventDefault();

      const productName = productLink.innerText.trim() || 'NA';
      const productHandle = productLink.getAttribute('href')?.split('/products/')[1] || `product-${index}`;
      const quickView = card.closest('.f-column.card')?.querySelector('quick-view-modal');
      const productId = quickView?.getAttribute('data-variant-sku') || `sku-${index}`;

      const productUrl = `/products/${productHandle}`;
 
      fetch(productUrl)
        .then(response => response.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
 
          const specBlocks = doc.querySelectorAll('.product-specifications .MoreDetailsSection_specificationContainer__UarA0');
          let specifications = [];

          specBlocks.forEach(block => {
            const label = block.querySelector('h6')?.innerText.trim();
            const value = block.querySelector('p')?.innerText.trim();
            if (label && value) {
              specifications.push(`${label}: ${value}`);
            }
          });

          const specFinal = specifications.length ? specifications.join(', ') : 'NA';
 
          let selectedSize = 'NA';
          const sizeInput = doc.querySelector('fieldset[name^="Size"] input[type="radio"]:checked');
          if (sizeInput) {
            selectedSize = sizeInput.value?.trim() || 'NA';
          }
 
          const itemData = {
            item_id: productId,
            item_name: productName,
            item_brand: 'Powerlook',
            item_category: '{{ collection.title | default: 'Shirts' }}',  
            item_category2: 'NA',
            item_category3: specFinal,
            item_category4: selectedSize,
            item_category5: 'Men',
            price: '{{ product.price }}' 
          };
 
          gtag('event', 'select_item', {
            item_list_name: 'All Products',
            item_list_id: 'all_products',
            items: [itemData],
            userID: '{{ customer.id }}',
            user_type: '{{ customer.tags | join: "," | default: "guest" }}'
          });

         // console.log('✅ GA4 select_item sent:', itemData);
 
          setTimeout(() => {
            window.location.href = productUrl;
          }, 300);
        });
    });
  });
}); 
