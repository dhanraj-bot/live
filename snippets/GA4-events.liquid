document.addEventListener('DOMContentLoaded', function () {
const pageType = '{{ template | handleize }}';
const userID = '{{ customer.id | default: "guest" }}';
const userType = '{{ customer.tags | join: "," | default: "guest" }}';

  document.querySelectorAll('.accordion-details__summary').forEach(function (accordion) {
    accordion.addEventListener('click', function () {
      const parent = accordion.closest('details');
      const contentTitle = accordion.innerText.trim();

      // Wait for the browser to update the DOM (open/close toggle)
      requestAnimationFrame(function () {
        const isOpen = parent.hasAttribute('open');

        const eventData = {
          cta_text: isOpen ? 'open' : 'close',
          content_title: contentTitle || 'N/A',
          page_type: pageType,
          userID: userID,
          user_type: userType
        };

        console.log('gtag event - accordian_interaction:', eventData);

        gtag('event', 'accordian_interaction', eventData);
      });
    });
  });
  document.addEventListener('click', function (e) {
    //console.log('clicked');
    const btn = e.target.closest('.apply-discount-button');
    if (!btn) return;

    // Get coupon code from button
    let couponCode = btn.getAttribute('data-discount-code')?.trim();

    // If manual input, read from input field
    if (!couponCode) {
      const couponInput = document.querySelector('#manualCouponInput');
      couponCode = couponInput?.value.trim() || '';
    }

    // Only send if code exists
    if (couponCode) {
      const eventData = {
        cta_text: btn.getAttribute('data-button-state') || 'apply',
        content_title: couponCode,
        page_type: pageType,
        userID: userID,
        user_type: userType
      };

      //console.log('✅ GA4 Event Sent: apply_coupon', eventData);

      if (typeof gtag === 'function') {
        gtag('event', 'apply_coupon', eventData);
      } else {
      //  console.warn('❌ gtag not defined');
      }
    } else {
    //  console.warn('⚠️ No coupon code found for GA event');
    }
  });
});
// ACCORDIAN CLICK

