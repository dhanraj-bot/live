{{ 'component-countdown-timer.css' | asset_url | stylesheet_tag }} 
{{ 'countdown-timer-hide.css' | asset_url | stylesheet_tag }}
<script src="{{ 'countdown-timer.js' | asset_url }}" defer="defer"></script>
{%- liquid
  assign number_size = number_size | default: 'h3'

  assign display_text = false
  assign style = style | default: 'number'
  if style == 'with_text'
    assign display_text = true
  endif

  assign type = type | default: 'fixed_time'
  assign duration = duration | default: 'every_month'
  assign show_days = show_days | default: false
-%}
<countdown-timer
  id="countdown-timer-{{ id }}"
  class="countdown-timer {{ custom_class }}"
  data-type="{{ type }}"
  data-duration="{{ duration }}"
  data-due-date="{{ time }}"
>
  <div class="countdown-timer__inner inline-flex items-center justify-center">
    {%- if show_days -%}
      <div class="countdown-timer__block">
        <div class="countdown-timer__day {{ number_size }} {{ block_class }}" data-timer-day>00</div>
        {%- if display_text -%}
          <span class="text-subtext">{{ 'sections.countdown-timer.days' | t }}</span>
        {%- endif -%}
      </div>
      <span class="timer_space">:</span>
    {%- endif -%}
    <div class="countdown-timer__block">
      <div class="countdown-timer__hour {{ number_size }} {{ block_class }}" data-timer-hour>00</div>
      {%- if display_text -%}
        <span class="text-subtext">{{ 'sections.countdown-timer.hours' | t }}</span>
      {%- endif -%} 
    </div>
    <span class="timer_space">:</span>
    <div class="countdown-timer__block">
      <div class="countdown-timer__minute {{ number_size }} {{ block_class }}" data-timer-minute>00</div>
      {%- if display_text -%}
        <span class="text-subtext">{{ 'sections.countdown-timer.minutes' | t }}</span>
      {%- endif -%} 
    </div>
    <span class="timer_space">:</span>
    <div class="countdown-timer__block">
      <div class="countdown-timer__sec {{ number_size }} {{ block_class }}" data-timer-second>00</div>
      {%- if display_text -%}
        <span class="text-subtext">{{ 'sections.countdown-timer.seconds' | t }}</span>
      {%- endif -%} 
    </div>
  </div>
</countdown-timer>
