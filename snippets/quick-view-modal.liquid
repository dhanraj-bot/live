{% comment %}
  Renders quick view modal for the given product

  Accepts:
  - modal_id: {String} Unique id for modal
  - product: {Object} Product object

  Usage:
  {% render 'quick-view-modal', modal_id: modal_id, product: product %}
{% endcomment %}
<quick-view-modal
  id="{{ modal_id }}"
  class="quick-view drawer drawer--right"
  data-product-url="{{ product.url }}"
  data-product-id="{{ product.id }}"
  data-variant-sku="{{ product.selected_or_first_available_variant.sku }}"
  data-product-title="{{ product.title | escape }}"
  data-collection-title="{{ product.collections.first.title | escape }}"
  data-collection-id="{{ product.collections.first.id }}"
  data-shop-currency="{{ shop.currency }}"
  hidden
>
  <div class="fixed-overlay" aria-controls="{{ modal_id }}"></div>
  <div class="drawer__inner">
    <button
      class="drawer__close-btn"
      aria-controls="{{ modal_id }}"
      aria-label="{{ 'accessibility.close' | t }}"
    >
      {% render 'icon-close' %}
    </button>
    {%- render 'loading-spinner' -%}
    <div class="drawer__body v-scrollable h-full quick-view__content"></div>
  </div>
</quick-view-modal>