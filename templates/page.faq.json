          "type": "collapsible_item",
          "settings": {
            "icon": "none",
            "heading": "How do I place a return or exchange request?",
            "content": "<p>To initiate a return or exchange:</p><ol><li>Log in to your <strong>Powerlook account<br/></strong></li><li>Go to <strong>My Orders<br/></strong></li><li>Select the order and click on <strong>Return or Exchange<br/></strong></li><li>Choose the reason and select the required size for exchange.<br/></li><li>Follow the pickup instructions displayed<br/></li></ol><p><strong>Return Conditions:</strong></p><ul><li>Product must be <strong>unused and unwashed<br/><br/></strong></li><li>Original <strong>tags and packaging must be intact<br/><br/></strong></li></ul><p>All returns are subject to a <strong>quality check</strong></p>",
            "custom_liquid": "",
            "page": "",
            "open": false
          }
        },
