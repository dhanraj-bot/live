        "collapsible_item_FarwJq": {
          "type": "collapsible_item",
          "settings": {
            "icon": "none",
            "heading": "What if my return pincode is not serviceable (Self-Courier)?",
            "subheading": "",
            "content": "<p>If pickup is not available, please self-ship the product to:</p><p><strong>Prozo Distribution Pvt. Ltd.<br/></strong> Building B, Infinity Logipark<br/> Kalyan Padgha Road, Amane<br/> Bhiwandi – 421302<br/> Dist. Thane, Maharashtra</p><ul><li>Pack the product securely to avoid loss/damage in transit.</li><li>Mention your Order ID and registered mobile number on the package.</li><li>Items must be unused, with original tags and packaging intact.</li><li>Once we receive and verify the product(s), we’ll process a full refund within 48 hours. No ₹100 reverse pickup charge will be deducted.</li><li>Do not use The Professional Couriers for returns — they are unreliable.</li><li>We recommend using India Post Speed Post for safe and cost-effective shipping</li></ul>",
            "custom_liquid": "",
            "page": "",
            "open": false
          }
        },
