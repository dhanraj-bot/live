{% for group in robots.default_groups %}
  {{- group.user_agent }}

  {%- for rule in group.rules -%}
    {{ rule }}
  {%- endfor -%}

  {%- comment -%} Custom no-crawl additions for the wildcard (all crawlers) group {%- endcomment -%}
  {%- if group.user_agent.value == '*' -%}
    {{ 'Disallow: /checkout' }}
    {{ 'Disallow: /login' }}
    {{ 'Disallow: /*/login' }}
    {{ 'Disallow: /account/myorders' }}
    {{ 'Disallow: /*/account/myorders' }}
  {%- endif -%}

  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}
{% endfor %}